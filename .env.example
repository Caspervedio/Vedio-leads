# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── CVR Datakilde ─────────────────────────────────────────────────────────────
# "cvrapi"      → cvrapi.dk (gratis, virker med det samme, ingen konto nødvendig)
# "datafordeler" → Virks officielle Elasticsearch API (kræver gratis konto på datafordeler.dk)
CVR_PROVIDER=cvrapi

# ── Datafordeler (kun nødvendig hvis CVR_PROVIDER=datafordeler) ────────────────
DATAFORDELER_USER=
DATAFORDELER_PASS=
DATAFORDELER_KEY=

# ── AI — Anthropic (kræves for Deal Risk AI og Revenue Intelligence AI) ────────
# Hent din nøgle på: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Enrichment APIs (valgfrie) ────────────────────────────────────────────────
# Clearbit: https://clearbit.com
CLEARBIT_KEY=

# Apollo.io: https://apollo.io
APOLLO_KEY=

# Phantombuster: https://phantombuster.com
PHANTOMBUSTER_KEY=

# ── Twilio (valgfri — kræves for live-opkald via browser) ─────────────────────
# Opret konto på https://twilio.com og aktivér Voice SDK
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TWIML_APP_SID=
TWILIO_API_KEY=

# ── Google Login + Kalender / Gmail ───────────────────────────────────────────
# Opret OAuth2-klient på https://console.cloud.google.com
# Tilladte redirect URIs skal inkludere BEGGE linjer nedenfor:
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_LOGIN_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/mail/callback

# ── n8n webhook (valgfri — kan også sættes i UI) ──────────────────────────────
N8N_WEBHOOK_URL=
