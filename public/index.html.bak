// ICP scores + pipeline state + notes per CVR (in-memory, saved to storage)
let icpScores={},pipeline={},leadNotes={},leadTags={},leadFollowup={},leadAssigned={},leadActivities={};
let leadContacts={},leadDeal={},leadHistory={};
let pipelines={sdr:{},ae:{}},activePane='ae';
// Calls module
let callLog=[],demoLog=[],callScripts=[];
let activeCall=null,callTimerInt=null,callElapsed=0;
let activeCallPane='calls';
let activeScript=null;
let selectedDemo=null;
let autoDial=false,autoDialIdx=0,autoDialQueue=[];
let res=[],leads=[],lists=[{id:'all',name:'Alle leads'}],aList='all',aView='search';
let selCo=null,ckd=new Set(),sC='name',sD=1,techSel=new Set(),stageSel=new Set();
let nUrl='',sbOpen=true,isServerMode=false,apiTotal=0,apiFrom=0,apiProvider='cvrapi';
let currentUser=null,authToken='';

const PIPELINE_DEFS={
  sdr:{
    label:'SDR Pipeline',
    stages:['Ny','Kontaktet','Kvalificeret','Møde booket','Ikke interesseret'],
    colors:{'Ny':{bg:'#e0f2fe',tc:'#0369a1'},'Kontaktet':{bg:'#fef9c3',tc:'#854d0e'},'Kvalificeret':{bg:'#f0fdf4',tc:'#15803d'},'Møde booket':{bg:'#f3e8ff',tc:'#7c3aed'},'Ikke interesseret':{bg:'#fee2e2',tc:'#991b1b'}}
  },
  ae:{
    label:'AE Pipeline',
    stages:['Demo Booket','Tilbud sendt','Forhandling','Vundet','Tabt'],
    colors:{'Demo Booket':{bg:'#e0f2fe',tc:'#0369a1'},'Tilbud sendt':{bg:'#fef9c3',tc:'#854d0e'},'Forhandling':{bg:'#fff7ed',tc:'#c2410c'},'Vundet':{bg:'#dcfce7',tc:'#166534'},'Tabt':{bg:'#fee2e2',tc:'#991b1b'}}
  }
};
function initPipelinePane(){
  const role=(currentUser?.role||'').toLowerCase();
  if(role==='sdr') activePane='sdr';
  else if(role==='ae') activePane='ae';
  else activePane='ae'; // Admin defaults to AE, can switch via UI
}
function switchPane(pane){activePane=pane;rDeals();}

// ── AUTH HELPERS ─────────────────────────────────────────────────────────────
function ah(extra){return Object.assign({'Content-Type':'application/json'},authToken?{'Authorization':'Bearer '+authToken}:{},extra||{});}

function lsKey(k){return currentUser?`vl_${currentUser.id}_${k}`:`vl_${k}`;}

function showLogin(){
  document.getElementById('login-overlay').style.display='flex';
  document.getElementById('app').style.display='none';
  setTimeout(()=>document.getElementById('login-email').focus(),100);
}

function applyAvatarToEl(el, user){
  if(!el)return;
  if(user.avatar){
    el.innerHTML='<img src="'+user.avatar+'" style="width:100%;height:100%;object-fit:cover;border-radius:50%;display:block">';
    el.style.background='transparent';
    el.style.fontSize='0';
  } else {
    el.innerHTML='';
    const initials=user.name.split(' ').map(n=>n[0]).join('').slice(0,2).toUpperCase();
    el.textContent=initials;
    el.style.background=user.color||'var(--p1)';
    el.style.fontSize='';
  }
}

function showApp(){
  document.getElementById('login-overlay').style.display='none';
  document.getElementById('app').style.display='flex';
  if(currentUser){
    const up=document.getElementById('user-profile');
    const av=document.getElementById('user-avatar');
    const nm=document.getElementById('user-name');
    const rb=document.getElementById('user-role-badge');
    if(up)up.style.display='block';
    applyAvatarToEl(av,currentUser);
    if(nm)nm.textContent=currentUser.name;
    if(rb){rb.textContent=currentUser.role;rb.className='role-badge '+({SDR:'role-sdr',AE:'role-ae',Admin:'role-admin'}[currentUser.role]||'role-ae');}
  }
}

async function doLogin(){
  const email=document.getElementById('login-email').value.trim();
  const pw=document.getElementById('login-pw').value;
  const errEl=document.getElementById('login-err');
  errEl.style.display='none';
  if(!email||!pw){errEl.textContent='Udfyld email og adgangskode';errEl.style.display='block';return;}
  try{
    const r=await fetch('/api/auth/login',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email,password:pw})});
    if(!r.ok){const d=await r.json().catch(()=>({}));errEl.textContent=d.error||'Login mislykkedes';errEl.style.display='block';return;}
    const d=await r.json();
    authToken=d.token;
    currentUser=d.user;
    localStorage.setItem('vl_token',authToken);
    showApp();
    await loadUserState();
    sv('dashboard');
    setTimeout(()=>{
      ['q','q-ex','f-ci','f-cx','qs'].forEach(id=>{const el=document.getElementById(id);if(el)el.addEventListener('input',debounce(applyF,350));});
    },80);
  }catch(err){errEl.textContent='Serverfejl — er serveren kørende?';errEl.style.display='block';}
}

async function logout(){
  try{await fetch('/api/auth/logout',{method:'POST',headers:ah()});}catch(e){}
  authToken='';currentUser=null;
  localStorage.removeItem('vl_token');
  icpScores={};pipeline={};leadNotes={};leadTags={};leadFollowup={};leadActivities={};
  leadContacts={};leadDeal={};leadHistory={};
  callLog=[];demoLog=[];callScripts=[];
  if(callTimerInt){clearInterval(callTimerInt);callTimerInt=null;}
  activeCall=null;callElapsed=0;selectedDemo=null;
  leads=[];lists=[{id:'all',name:'Alle leads'}];
  showLogin();
}

async function loadUserState(){
  try{
    const d=await fetch('/api/leads',{headers:ah()}).then(r=>r.json());
    leads=d.leads||[];
    lists=[{id:'all',name:'Alle leads'},...(d.lists||[]).filter(l=>l.id!=='all')];
    nUrl=d.n8nUrl||'';
  }catch(e){}
  // Load calls/demos/scripts from server
  if(isServerMode&&authToken){
    try{ callLog=await fetch('/api/calls',{headers:ah()}).then(r=>r.json()); }catch(e){callLog=[];}
    try{ demoLog=await fetch('/api/demos',{headers:ah()}).then(r=>r.json()); }catch(e){demoLog=[];}
    try{ callScripts=await fetch('/api/scripts',{headers:ah()}).then(r=>r.json()); }catch(e){callScripts=[];}
    if(callScripts.length>0) activeScript=callScripts[0];
  }
  // Per-user localStorage meta
  try{
    const ic=localStorage.getItem(lsKey('icp'));
    const pp=localStorage.getItem(lsKey('pipe'));
    const nt=localStorage.getItem(lsKey('notes'));
    const tg=localStorage.getItem(lsKey('tags'));
    const fu=localStorage.getItem(lsKey('fu'));
    const nu=localStorage.getItem(lsKey('n8n'));
    const ac=localStorage.getItem(lsKey('acts'));
    const ct=localStorage.getItem(lsKey('contacts'));
    const dv=localStorage.getItem(lsKey('deal'));
    const hs=localStorage.getItem(lsKey('hist'));
    if(ic)icpScores=JSON.parse(ic);
    if(pp)pipeline=JSON.parse(pp);
    // Load dual pipelines with backward-compat migration
    const rawPipes=localStorage.getItem(lsKey('pipes'));
    if(rawPipes){
      try{const p=JSON.parse(rawPipes);pipelines={sdr:p.sdr||{},ae:p.ae||{}};}catch(e){}
    } else if(pp){
      const SDR_S=new Set(['Ny','Kontaktet','Kvalificeret']);
      pipelines={sdr:{},ae:{}};
      Object.entries(pipeline).forEach(([cvr,stage])=>{
        if(SDR_S.has(stage))pipelines.sdr[cvr]=stage;else pipelines.ae[cvr]=stage;
      });
    }
    if(nt)leadNotes=JSON.parse(nt);
    if(tg)leadTags=JSON.parse(tg);
    if(fu)leadFollowup=JSON.parse(fu);
    if(nu&&!nUrl)nUrl=nu;
    if(ac)leadActivities=JSON.parse(ac);
    if(ct)leadContacts=JSON.parse(ct);
    if(dv)leadDeal=JSON.parse(dv);
    if(hs)leadHistory=JSON.parse(hs);
  }catch(e){}
  initPipelinePane();
  // Seed demo pipeline data once if empty
  if(Object.keys(pipelines.ae).length===0&&leads.length>0&&!localStorage.getItem('vl_demo_seeded')){
    const aeStages=['Demo Booket','Tilbud sendt','Forhandling','Vundet','Tabt'];
    const plans=['Core','Pro','Enterprise'];
    const demoLeads=leads.slice(0,12);
    demoLeads.forEach((l,i)=>{
      pipelines.ae[l.cvr]=aeStages[i%aeStages.length];
      if(!leadDeal[l.cvr])leadDeal[l.cvr]={};
      leadDeal[l.cvr].plan=plans[i%3];
    });
    localStorage.setItem('vl_demo_seeded','1');
    save();
  }
  rSB();applyF();updateTaskBadge();
}

(async()=>{
  // Handle Google OAuth redirect: /?token=xxx or /?error=xxx
  const urlParams=new URLSearchParams(location.search);
  const urlToken=urlParams.get('token');
  const urlError=urlParams.get('error');
  if(urlToken){
    localStorage.setItem('vl_token',urlToken);
    history.replaceState({},'','/');
  }
  if(urlError){
    history.replaceState({},'','/');
    showLogin();
    const errEl=document.getElementById('login-err');
    if(errEl){errEl.textContent=decodeURIComponent(urlError);errEl.style.display='block';}
    return;
  }
  // Detect if running via server
  try{
    const status=await fetch('/api/status');
    if(status.ok){
      isServerMode=true;
      const sd=await status.json().catch(()=>({}));
      apiProvider=sd.provider||'cvrapi';
      // Server supports auth — try stored token
      const storedToken=urlToken||localStorage.getItem('vl_token');
      if(storedToken){
        const me=await fetch('/api/auth/me',{headers:{'Authorization':'Bearer '+storedToken}});
        if(me.ok){
          authToken=storedToken;
          currentUser=await me.json();
          showApp();
          await loadUserState();
          sv('dashboard');
          setTimeout(()=>{
            ['q','q-ex','f-ci','f-cx','qs'].forEach(id=>{const el=document.getElementById(id);if(el)el.addEventListener('input',debounce(applyF,350));});
          },80);
          return;
        } else {
          localStorage.removeItem('vl_token');
        }
      }
      showLogin();
      return;
    }
  }catch(e){}

  // Fallback: no server (standalone HTML mode)
  try{
    const ld=localStorage.getItem('vl_l');const ll=localStorage.getItem('vl_ls');
    if(ld)leads=JSON.parse(ld);
    if(ll){const p=JSON.parse(ll);lists=[{id:'all',name:'Alle leads'},...p.filter(x=>x.id!=='all')];}
    const ic=localStorage.getItem('vl_icp');const pp=localStorage.getItem('vl_pipe');
    const nt=localStorage.getItem('vl_notes');const tg=localStorage.getItem('vl_tags');
    const fu=localStorage.getItem('vl_fu');const nu=localStorage.getItem('vl_n8n');
    const ac=localStorage.getItem('vl_acts');
    if(ic)icpScores=JSON.parse(ic);
    if(pp)pipeline=JSON.parse(pp);
    if(nt)leadNotes=JSON.parse(nt);
    if(tg)leadTags=JSON.parse(tg);
    if(fu)leadFollowup=JSON.parse(fu);
    if(nu)nUrl=nu;
    if(ac)leadActivities=JSON.parse(ac);
  }catch(e){}
  // Show app without login in standalone mode
  document.getElementById('login-overlay').style.display='none';
  document.getElementById('app').style.display='flex';
  rSB();applyF();updateTaskBadge();
  setTimeout(()=>{
    ['q','q-ex','f-ci','f-cx','qs'].forEach(id=>{const el=document.getElementById(id);if(el)el.addEventListener('input',debounce(applyF,350));});
  },80);
})();

function debounce(fn,ms){let t;return(...a)=>{clearTimeout(t);t=setTimeout(()=>fn(...a),ms);};}

async function save(){
  try{
    localStorage.setItem(lsKey('icp'),JSON.stringify(icpScores));
    localStorage.setItem(lsKey('pipe'),JSON.stringify(pipeline));
    localStorage.setItem(lsKey('pipes'),JSON.stringify(pipelines));
    localStorage.setItem(lsKey('notes'),JSON.stringify(leadNotes));
    localStorage.setItem(lsKey('tags'),JSON.stringify(leadTags));
    localStorage.setItem(lsKey('fu'),JSON.stringify(leadFollowup));
    localStorage.setItem(lsKey('acts'),JSON.stringify(leadActivities));
    localStorage.setItem(lsKey('contacts'),JSON.stringify(leadContacts));
    localStorage.setItem(lsKey('deal'),JSON.stringify(leadDeal));
    localStorage.setItem(lsKey('hist'),JSON.stringify(leadHistory));
    localStorage.setItem(lsKey('n8n'),nUrl);
    if(!isServerMode){
      localStorage.setItem('vl_l',JSON.stringify(leads));
      localStorage.setItem('vl_ls',JSON.stringify(lists));
    }
  }catch(e){}
}

// ── FILTERS + LIVE SEARCH ────────────────────────────────────────────────────
async function applyF(fromOffset=0){
  const q=(document.getElementById('q').value||document.getElementById('qs').value||'').trim();
  const branche=document.getElementById('f-b').value,form=document.getElementById('f-form').value;
  const fe1=document.getElementById('fe1').value,fe2=document.getElementById('fe2').value;
  const fy1=document.getElementById('fy1').value,fy2=document.getElementById('fy2').value;
  const fam=document.getElementById('fam').value,faM=document.getElementById('faM').value;
  const ci=document.getElementById('f-ci').value.trim();
  const cx=document.getElementById('f-cx').value.toLowerCase().trim();
  const fzm=document.getElementById('fzm').value,fzM=document.getElementById('fzM').value;
  const needEm=false,needPh=false,needSoc=false,needVid=false;
  const minIcp=parseInt(document.getElementById('f-icp').value)||0;
  const qex=(document.getElementById('q-ex').value||'').trim().toLowerCase();
  const adProtect=['alle','skjul','kun'].find(k=>document.getElementById('rk-'+k)?.classList.contains('on'))||'alle';

  // Server mode: søgning kræver altid mindst 2 tegn (cvrapi.dk)
  const hasAnyFilter = branche||form||ci||fzm||fam||faM||fy1||fy2||qex;
  const canServerSearch = isServerMode && q.length>=2;

  // Tom søgning i server mode — vis intro-tilstand, ikke demo-data
  if(isServerMode && q.length<2 && !hasAnyFilter){
    res=[];apiTotal=0;apiFrom=0;
    clearApiError();
    document.getElementById('tbody').innerHTML=`<tr><td colspan="12" style="text-align:center;padding:70px 20px;color:var(--gray2)">
      <div style="font-size:28px;margin-bottom:12px"></div>
      <div style="font-size:14px;font-weight:600;color:var(--pdarker);margin-bottom:6px">Søg efter virksomheder</div>
      <div style="font-size:12px">Skriv mindst 2 tegn i søgefeltet — navn, CVR eller branche</div>
    </td></tr>`;
    document.getElementById('thead').innerHTML='';
    const lmw=document.getElementById('load-more-wrap');if(lmw)lmw.style.display='none';
    const sb=document.getElementById('stbar');if(sb)sb.innerHTML='';
    return;
  }

  if(canServerSearch){
    setLoading(true);
    const params=new URLSearchParams();
    if(q)params.set('q',q);
    if(branche)params.set('branche',branche);
    if(form)params.set('form',form);
    if(ci)params.set('city',ci);
    if(fzm)params.set('zip',fzm);
    if(fe1)params.set('empMin',fe1);if(fe2)params.set('empMax',fe2);
    if(fy1)params.set('foundedFrom',fy1);if(fy2)params.set('foundedTo',fy2);
    if(needEm)params.set('hasEmail','true');if(needPh)params.set('hasPhone','true');
    if(adProtect!=='alle')params.set('adProtect',adProtect);
    params.set('from',fromOffset);
    params.set('size','500');
    try{
      const r=await fetch(`/api/search?${params}`);
      const data=await r.json();
      if(!r.ok){
        showApiError(data.error||'Søgning fejlede',data.code);
        setLoading(false);
        localFilter(q,qex,form,branche,fe1,fe2,fy1,fy2,ci,cx,fzm,fzM,needEm,needPh,needSoc,needVid,adProtect,minIcp);
        return;
      }
      clearApiError();
      // Opdater aktiv provider fra søgesvaret (håndterer fallback til cvrapi)
      if(data.provider)apiProvider=data.provider+(data.fallback?' fallback':'');
      let co=data.companies||[];
      apiTotal=data.total||co.length;
      apiFrom=fromOffset;

      // Client-side efterfiltrering (uanset provider)
      if(qex)co=co.filter(c=>!c.name.toLowerCase().includes(qex)&&!(c.industry||'').toLowerCase().includes(qex));
      if(cx)co=co.filter(c=>!(c.city||'').toLowerCase().includes(cx));
      if(fzM)co=co.filter(c=>+c.zip<=+fzM);
      if(needSoc)co=co.filter(c=>c.ig||c.fb||c.tt||c.li);
      if(needVid)co=co.filter(c=>c.ig||c.tt);
      if(minIcp>0)co=co.filter(c=>getIcp(c)>=minIcp);
      if(techSel.size>0)co=co.filter(c=>[...techSel].some(t=>(c.tech||[]).includes(t)));
      if(stageSel.size>0)co=co.filter(c=>stageSel.has((pipelines.ae||{})[c.cvr]||(pipelines.sdr||{})[c.cvr]||'Ny'));

      const mapC=c=>({...c,
        ic:c.industryCode||c.ic||'',ind:c.industry||c.ind||'',
        emp:c.employeeCount||c.emp||0,emps:c.employees||c.emps||'',
        ph:c.phone||c.ph||'',em:c.email||c.em||'',
        addr:c.address||c.addr||'',st:c.status||c.st||'active',yr:c.founded||c.yr||'',
        ageM:c.ageM||0,eq:c.equity||c.eq||0,omsaetning:c.revenue||c.omsaetning||0,
        bf:c.grossProfit||c.bf||0,res:c.result||c.res||0,
        ig:c.ig||'',fb:c.fb||'',tt:c.tt||'',li:c.li||'',tech:c.tech||[],
      });
      const mapped=co.map(mapC);
      // Merge lokale leads der matcher søgningen (vises altid uanset API)
      const ql2=(q||'').toLowerCase();
      const localMatches=leads.filter(l=>{
        if(mapped.find(x=>x.cvr===l.cvr))return false; // allerede i API-resultater
        if(q&&!(l.name?.toLowerCase().includes(ql2)||l.cvr?.includes(q)||l.city?.toLowerCase().includes(ql2)))return false;
        if(qex&&l.name?.toLowerCase().includes(qex))return false;
        return true;
      }).map(mapC);
      if(fromOffset>0){res=[...res,...mapped,...localMatches];}else{res=[...mapped,...localMatches];}
    }catch(err){
      showApiError('Netværksfejl: '+err.message);
      setLoading(false);
      localFilter(q,qex,form,branche,fe1,fe2,fy1,fy2,ci,cx,fzm,fzM,needEm,needPh,needSoc,needVid,adProtect,minIcp);
      return;
    }
    setLoading(false);
  } else {
    localFilter(q,qex,form,branche,fe1,fe2,fy1,fy2,ci,cx,fzm,fzM,needEm,needPh,needSoc,needVid,adProtect,minIcp);
    return;
  }
  sortR();render();
}

function localFilter(q,qex,form,branche,fe1,fe2,fy1,fy2,ci,cx,fzm,fzM,needEm,needPh,needSoc,needVid,adProtect,minIcp){
  apiTotal=0;apiFrom=0;
  const ql=(q||'').toLowerCase();
  res=DEMO_DATA.filter(c=>{
    if(q&&!(c.name.toLowerCase().includes(ql)||c.cvr.includes(q)||c.city.toLowerCase().includes(ql)||c.ind.toLowerCase().includes(ql)))return false;
    if(qex&&(c.name.toLowerCase().includes(qex)||c.ind.toLowerCase().includes(qex)))return false;
    if(form&&c.form!==form)return false;
    if(branche&&!c.ic.startsWith(branche))return false;
    if(fe1&&c.emp<+fe1)return false;if(fe2&&c.emp>+fe2)return false;
    if(fy1&&+c.yr<+fy1)return false;if(fy2&&+c.yr>+fy2)return false;
    if(ci&&!c.city.toLowerCase().includes(ci.toLowerCase()))return false;
    if(cx&&c.city.toLowerCase().includes(cx))return false;
    if(needEm&&!c.em)return false;if(needPh&&!c.ph)return false;
    if(needSoc&&!(c.ig||c.fb||c.tt||c.li))return false;
    if(needVid&&!(c.ig||c.tt))return false;
    if(adProtect==='skjul'&&c.adProtected)return false;
    if(adProtect==='kun'&&!c.adProtected)return false;
    if(minIcp>0&&getIcp(c)<minIcp)return false;
    if(techSel.size>0&&![...techSel].some(t=>(c.tech||[]).includes(t)))return false;
    if(stageSel.size>0){const ps=(pipelines.ae||{})[c.cvr]||(pipelines.sdr||{})[c.cvr]||'Ny';if(!stageSel.has(ps))return false;}
    return true;
  });
  sortR();render();
}

async function loadMore(){
  const btn=document.getElementById('load-more-btn');
  btn.disabled=true;btn.textContent='Indlæser…';
  await applyF(apiFrom+res.length);
  btn.disabled=false;btn.textContent='Indlæs flere resultater';
}

function setLoading(on){
  const sb=document.getElementById('stbar');
  if(on){sb.innerHTML='<span style="color:var(--gray2)">Søger…</span>';}
}

function showApiError(msg,code){
  let html=`<span style="color:var(--red);font-weight:600">${e(msg)}</span>`;
  if(code==='QUOTA_EXCEEDED'){
    html+=` — <a href="#" onclick="openInt();return false" style="color:var(--blue);font-size:11px">Konfigurér Datafordeler</a>`;
  }
  let errDiv=document.getElementById('api-error-bar');
  if(!errDiv){
    errDiv=document.createElement('div');
    errDiv.id='api-error-bar';
    errDiv.style.cssText='padding:6px 12px;background:#fee2e2;border-bottom:1px solid #fca5a5;font-size:11.5px;display:flex;align-items:center;gap:8px';
    const stbar=document.getElementById('stbar');
    stbar.parentNode.insertBefore(errDiv,stbar.nextSibling);
  }
  errDiv.innerHTML=html+`<span onclick="clearApiError()" style="margin-left:auto;cursor:pointer;color:var(--gray2);font-size:14px">✕</span>`;
  errDiv.style.display='flex';
}

function clearApiError(){
  const el=document.getElementById('api-error-bar');
  if(el)el.style.display='none';
}

function setRk(v){['alle','skjul','kun'].forEach(k=>document.getElementById('rk-'+k).classList.toggle('on',k===v));applyF();}
function tChipTech(el,name){techSel.has(name)?(techSel.delete(name),el.classList.remove('on')):(techSel.add(name),el.classList.add('on'));applyF();}
function tChipStage(el,name){stageSel.has(name)?(stageSel.delete(name),el.classList.remove('on')):(stageSel.add(name),el.classList.add('on'));applyF();}
function resetF(){
  ['q','q-ex','f-ci','f-cx','qs','fe1','fe2','fy1','fy2','f-eq','f-res','fam','faM','fzm','fzM'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  document.getElementById('f-form').value='';document.getElementById('f-b').value='';
  document.getElementById('f-icp').value='0';
  techSel.clear();stageSel.clear();
  document.querySelectorAll('.chip').forEach(c=>c.classList.remove('on'));
  setRk('alle');applyF();
}

function togAcc(id){
  const b=document.getElementById('acc-'+id),a=document.getElementById('arr-'+id);
  const o=b.classList.toggle('open');a.classList.toggle('open',o);
}

// ── SORT + RENDER ──────────────────────────────────────────────────────────────
function sortR(){
  res.sort((a,b)=>{
    const av=sC==='emp'?a.emp:sC==='eq'?a.eq:sC==='omsaetning'?a.omsaetning:sC==='icp'?getIcp(a):(a[sC]||'');
    const bv=sC==='emp'?b.emp:sC==='eq'?b.eq:sC==='omsaetning'?b.omsaetning:sC==='icp'?getIcp(b):(b[sC]||'');
    return av<bv?-sD:av>bv?sD:0;
  });
}
function setSort(c){sC===c?sD*=-1:(sC=c,sD=1);sortR();render();}
function si(k){return`<span style="opacity:${sC===k?1:.3};font-size:9px;margin-left:2px">${sC===k?(sD>0?'▲':'▼'):'⇅'}</span>`;}
function render(){if(aView==='search')rTbl();else if(aView==='deals')rDeals();else rLeads();}

function sv(v){
  aView=v;
  document.getElementById('nv-dash').classList.toggle('on',v==='dashboard');
  document.getElementById('nv-s').classList.toggle('on',v==='search');
  document.getElementById('nv-l').classList.toggle('on',v==='leads');
  document.getElementById('nv-deals').classList.toggle('on',v==='deals');
  document.getElementById('nv-calls').classList.toggle('on',v==='calls');
  document.getElementById('nv-mail').classList.toggle('on',v==='mail');
  document.getElementById('nv-calendar').classList.toggle('on',v==='calendar');
  document.getElementById('nv-tasks').classList.toggle('on',v==='tasks');

  selCo=null;hdDp();ckd.clear();upSel();
  /* filters now in toolbar popover */
  const sp=document.getElementById('settings-panel');
  const dp2=document.getElementById('deals-panel');
  const tp=document.getElementById('tasks-panel');
  const dash=document.getElementById('dashboard-panel');
  const cp=document.getElementById('calls-panel');
  const mp=document.getElementById('mail-panel');
  const kp=document.getElementById('calendar-panel');
  const bw=document.querySelector('.body-wrap');
  const tb=document.querySelector('.toolbar');
  const sb=document.getElementById('stbar');
  const selb=document.getElementById('selbar');
  const hideAll=()=>{
    sp.style.display='none';dp2.style.display='none';tp.style.display='none';
    dash.style.display='none';cp.style.display='none';mp.style.display='none';
    kp.style.display='none';
    bw.style.display='none';tb.style.display='none';sb.style.display='none';
    if(selb)selb.style.display='none';
    document.getElementById('sb-lists').style.display='none';
    document.getElementById('sb-footer').style.display='none';
    document.getElementById('leads-list-bar').style.display='none';
  };
  if(v==='settings'){
    hideAll();sp.style.display='flex';sp.style.flexDirection='column';
    document.getElementById('n8n-url-s').value=nUrl;updIS();checkTwilioStatus();checkGmailStatus();
  } else if(v==='deals'){
    hideAll();dp2.style.display='flex';dp2.style.flexDirection='column';rDeals();
  } else if(v==='calls'){
    hideAll();cp.style.display='flex';cp.style.flexDirection='column';rCalls();
  } else if(v==='mail'){
    hideAll();mp.style.display='flex';mp.style.flexDirection='column';rMail();
  } else if(v==='calendar'){
    hideAll();kp.style.display='flex';kp.style.flexDirection='column';rCalendar();
  } else if(v==='tasks'){
    hideAll();tp.style.display='flex';tp.style.flexDirection='column';rTasks();
  } else if(v==='dashboard'){
    hideAll();dash.style.display='flex';dash.style.flexDirection='column';rDashboard();
  } else {
    hideAll();
    bw.style.display='';tb.style.display='';sb.style.display='';if(selb)selb.style.display='';
    const isLeads=v==='leads';
    document.getElementById('sb-lists').style.display='none';
    document.getElementById('sb-footer').style.display='none';
    document.getElementById('leads-list-bar').style.display=isLeads?'':'none';
    rSB();render();
  }
}

// ── ACTIVITY / TASK HELPERS ───────────────────────────────────────────────────
const ACT_TYPES={
  call:  {ico:'<span class="act-ico act-call"></span>',lbl:'Opkald'},
  email: {ico:'<span class="act-ico act-email"></span>',lbl:'Email'},
  followup:{ico:'<span class="act-ico act-followup"></span>',lbl:'Opfølgning'},
  meeting:{ico:'<span class="act-ico act-meeting"></span>',lbl:'Møde'},
  note:  {ico:'<span class="act-ico act-note"></span>',lbl:'Note'},
  task:  {ico:'<span class="act-ico act-task"></span>',lbl:'Opgave'},
};

function todayStr(){const d=new Date();return d.toISOString().split('T')[0];}
function tomorrowStr(){const d=new Date();d.setDate(d.getDate()+1);return d.toISOString().split('T')[0];}

function allActivities(){
  return Object.entries(leadActivities).flatMap(([cvr,acts])=>(acts||[]).map(a=>({...a,cvr})));
}

function updateTaskBadge(){
  const today=todayStr();
  const due=allActivities().filter(a=>!a.done&&a.date&&a.date<=today);
  const badge=document.getElementById('task-badge');
  if(badge){badge.textContent=due.length;badge.style.display=due.length?'':'none';}
}

function dayOffset(n){
  const d=new Date();d.setDate(d.getDate()+n);
  return d.toISOString().substring(0,10);
}

function rTasks(){
  const today=todayStr();
  const yesterday=dayOffset(-1);
  const tomorrow=dayOffset(1);

  const all=allActivities().sort((a,b)=>{
    const da=(a.date||'9999')+(a.time||'00:00');
    const db=(b.date||'9999')+(b.time||'00:00');
    return da<db?-1:da>db?1:0;
  });

  // Three-day buckets (include done tasks in yesterday/today/tomorrow)
  const yesterdayActs = all.filter(a=>a.date===yesterday);
  const todayActs     = all.filter(a=>a.date===today);
  const tomorrowActs  = all.filter(a=>a.date===tomorrow);

  // Below-the-fold sections
  const overdue = all.filter(a=>!a.done&&a.date&&a.date<yesterday);
  const future  = all.filter(a=>!a.done&&a.date&&a.date>tomorrow);
  const done    = all.filter(a=>a.done&&(!a.date||a.date<yesterday)).slice(0,20);

  const sum=document.getElementById('tasks-summary');
  if(sum){
    const open=overdue.length+todayActs.filter(a=>!a.done).length+tomorrowActs.filter(a=>!a.done).length+future.length;
    sum.textContent=`${open} åbne · ${all.filter(a=>a.done).length} afsluttede`;
  }

  // Render a single task card (time shown for today col, not for faded cols)
  const renderCard=(a,showTime=false)=>{
    const co=findCo(a.cvr);
    const coName=co?co.name:a.cvr;
    const t=ACT_TYPES[a.type]||{ico:'',lbl:'Opgave'};
    const late=!a.done&&a.date&&a.date<today;
    const timeStr=(showTime&&a.time)?` · ${a.time}`:'';
    const dateStr=showTime?(a.date?fmtDate(a.date)+timeStr:'Ingen dato'):(a.time||'');
    return `<div class="task-item ${a.done?'done-task':''} ${late?'overdue':''}" id="titem-${a.id}">
      <input type="checkbox" class="task-check" ${a.done?'checked':''} onchange="toggleActivity('${a.cvr}','${a.id}',this.checked)">
      <div class="task-ico">${t.ico}</div>
      <div class="task-body">
        <div class="task-title">${e(a.title||t.lbl)}</div>
        <div><span class="task-co" onclick="openLeadFromTask('${a.cvr}')">${e(coName)}</span></div>
        ${dateStr?`<div class="task-meta ${late?'late':''}">${dateStr}</div>`:''}
      </div>
      <span class="task-del" onclick="deleteActivity('${a.cvr}','${a.id}')" title="Slet">×</span>
    </div>`;
  };

  // Render a day column
  const renderDayCol=(acts,colClass,emoji,label,dateLabel,cntStyle,emptyMsg,showTime=false)=>{
    const items=acts.map(a=>renderCard(a,showTime)).join('');
    return `<div class="tasks-day-col ${colClass}">
      <div class="tasks-day-hd">
        <span class="day-label">${emoji} ${label}</span>
        <span class="day-cnt" style="${cntStyle}">${acts.length}</span>
      </div>
      <div style="font-size:10px;color:var(--gray3);margin-bottom:8px;margin-top:-6px">${dateLabel}</div>
      ${items||`<div class="tasks-day-empty">${emptyMsg}</div>`}
    </div>`;
  };

  // Render flat section (overdue / future / done)
  const renderGroup=(acts,title,emptyMsg,extraClass='')=>{
    if(!acts.length&&!emptyMsg)return'';
    const items=acts.map(a=>renderCard(a,true)).join('');
    return `<div class="tasks-section">
      <div class="tasks-section-hd">${title}<span class="tasks-cnt" style="${extraClass}">${acts.length}</span></div>
      ${items||`<div style="font-size:11.5px;color:var(--gray2);padding:10px 0">${emptyMsg}</div>`}
    </div>`;
  };

  const fmt=d=>fmtDate(d);

  document.getElementById('tasks-body').innerHTML=
    // ── Three-day view ──
    `<div class="tasks-3col">` +
      renderDayCol(yesterdayActs,'day-past','<span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#9ca3af"></span>','I går',fmt(yesterday),'background:#f3f4f6;color:#6b7280','-',false) +
      renderDayCol(todayActs,'day-today','<span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#eab308"></span>','I dag',fmt(today),'background:#fef9c3;color:#854d0e','Ingen opgaver i dag',true) +
      renderDayCol(tomorrowActs,'day-future','<span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#3b82f6"></span>','I morgen',fmt(tomorrow),'background:#dbeafe;color:#1d4ed8','-',false) +
    `</div>` +
    // ── Below-fold sections ──
    (overdue.length?renderGroup(overdue,'<span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#ef4444;margin-right:4px"></span> Forsinkede (ældre)','',`background:#fee2e2;color:#991b1b`):'') +
    (future.length?renderGroup(future,'Kommende','',`background:#dbeafe;color:#1d4ed8`):'') +
    (done.length?renderGroup(done,'✔ Afsluttet','',`background:#f3f4f6;color:#6b7280`):'');

  updateTaskBadge();
}

function fmtDate(d){
  if(!d)return'';
  const [y,m,day]=d.split('-');
  return `${day}/${m}/${y}`;
}

function findCo(cvr){
  return leads.find(x=>x.cvr===cvr)||res.find(x=>x.cvr===cvr)||DEMO_DATA.find(x=>x.cvr===cvr);
}

function openLeadFromTask(cvr){
  const c=findCo(cvr);if(!c)return;
  selCo=c;showDp(c);showTab('akt');
}

async function addActivity(cvr){
  const typeEl=document.getElementById('act-type-'+cvr);
  const titleEl=document.getElementById('act-title-'+cvr);
  const dateEl=document.getElementById('act-date-'+cvr);
  const timeEl=document.getElementById('act-time-'+cvr);
  if(!typeEl||!titleEl)return;
  const title=(titleEl.value||'').trim();
  const type=typeEl.value||'task';
  if(!title){titleEl.focus();return;}
  if(!leadActivities[cvr])leadActivities[cvr]=[];
  const act={
    id: Date.now().toString(36)+Math.random().toString(36).slice(2,5),
    type, title,
    date:dateEl?dateEl.value:todayStr(),
    time:timeEl?timeEl.value:'',
    done:false,
    createdAt:new Date().toISOString()
  };
  leadActivities[cvr].push(act);
  titleEl.value='';
  await save();
  const listEl=document.getElementById('acts-'+cvr);
  if(listEl)listEl.innerHTML=renderActList(cvr);
  updateTaskBadge();
}

async function toggleActivity(cvr,id,done){
  const acts=leadActivities[cvr]||[];
  const a=acts.find(x=>x.id===id);
  if(a)a.done=done;
  await save();
  if(aView==='tasks')rTasks();else{
    const listEl=document.getElementById('acts-'+cvr);
    if(listEl)listEl.innerHTML=renderActList(cvr);
    updateTaskBadge();
  }
}

async function deleteActivity(cvr,id){
  if(!leadActivities[cvr])return;
  leadActivities[cvr]=leadActivities[cvr].filter(x=>x.id!==id);
  await save();
  if(aView==='tasks')rTasks();else{
    const listEl=document.getElementById('acts-'+cvr);
    if(listEl)listEl.innerHTML=renderActList(cvr);
    updateTaskBadge();
  }
}

function renderActList(cvr){
  const acts=(leadActivities[cvr]||[]).slice().sort((a,b)=>{
    if(a.done!==b.done)return a.done?1:-1;
    return (a.date+a.time)<(b.date+b.time)?-1:1;
  });
  if(!acts.length)return`<div style="font-size:11.5px;color:var(--gray2);padding:8px 0;text-align:center">Ingen aktiviteter endnu</div>`;
  return acts.map(a=>{
    const t=ACT_TYPES[a.type]||{ico:'',lbl:''};
    const when=[a.date?fmtDate(a.date):'',a.time].filter(Boolean).join(' ');
    return`<div class="act-list-item ${a.done?'done-act':''}">
      <input type="checkbox" class="act-done-cb" ${a.done?'checked':''} onchange="toggleActivity('${cvr}','${a.id}',this.checked)">
      <div style="flex-shrink:0">${t.ico}</div>
      <div class="act-lbl">
        ${e(a.title||t.lbl)}
        ${when?`<span class="act-lbl-meta">${when}</span>`:''}
      </div>
      <span class="act-rm" onclick="deleteActivity('${cvr}','${a.id}')" title="Slet">×</span>
    </div>`;
  }).join('');
}

// ── DASHBOARD ─────────────────────────────────────────────────────────────────
function getWeekStart(){
  const d=new Date();const day=d.getDay();
  d.setDate(d.getDate()-(day===0?6:day-1));
  return d.toISOString().split('T')[0];
}


// ── REVENUE INTELLIGENCE ──────────────────────────────────────────────────────
const RI_STAGE_W={'Forhandling':40,'Tilbud sendt':30,'Demo Booket':20,'Møde booket':15,'Kvalificeret':10,'Kontaktet':5,'Ny':2};
const RI_MAX_SCORE=148; // icp*10(50)+stage(40)+acts*8(40)+contact(5)+value(8)+plan(5)

function computeHotScore(cvr,lead,deal,acts){
  const stage=(pipelines.ae||{})[cvr]||(pipelines.sdr||{})[cvr]||'';
  if(!stage||RISK_SKIP.has(stage))return 0;
  const icp=getIcp(lead);
  const cutoff=new Date(Date.now()-14*24*3600*1000).toISOString().slice(0,10);
  const recentActs=(acts||[]).filter(a=>a.date&&a.date>=cutoff).length;
  const hasContact=!!(lead.contactName||(leadContacts[cvr]||[]).find(c=>c.name));
  const hasDealValue=!!(deal?.mrr||deal?.arr);
  const hasPlan=!!deal?.plan;
  const risk=computeDealRisk(cvr,lead,deal,acts);
  return Math.max(0,
    icp*10 + (RI_STAGE_W[stage]||0) + Math.min(recentActs,5)*8
    + (hasContact?5:0) + (hasDealValue?8:0) + (hasPlan?5:0)
    - (risk.level==='high'?25:risk.level==='medium'?12:0)
  );
}

function buildRevenueIntelData(){
  const aePipe=pipelines.ae||{};
  const ACT_LABELS={call:'Opkald',email:'Email',meeting:'Møde',followup:'Opfølgning',task:'Opgave'};

  // Scored active deals
  const activeLeads=leads.filter(l=>aePipe[l.cvr]&&!RISK_SKIP.has(aePipe[l.cvr]));
  const scoredDeals=activeLeads.map(l=>{
    const score=computeHotScore(l.cvr,l,leadDeal[l.cvr],leadActivities[l.cvr]||[]);
    return{lead:l,score,prob:Math.min(96,Math.round(score/RI_MAX_SCORE*100)),stage:aePipe[l.cvr]};
  }).sort((a,b)=>b.score-a.score).slice(0,5);

  // Won/lost
  const wonLeads=leads.filter(l=>aePipe[l.cvr]==='Vundet');
  const lostLeads=leads.filter(l=>aePipe[l.cvr]==='Tabt');

  // ICP win rates
  const icpMap={};
  [...wonLeads,...lostLeads].forEach(l=>{
    const s=getIcp(l);
    if(!icpMap[s])icpMap[s]={won:0,lost:0};
    aePipe[l.cvr]==='Vundet'?icpMap[s].won++:icpMap[s].lost++;
  });
  const icpRows=[5,4,3,2,1].filter(s=>(icpMap[s]?.won||0)+(icpMap[s]?.lost||0)>0).map(s=>{
    const tot=(icpMap[s]?.won||0)+(icpMap[s]?.lost||0);
    const wr=Math.round((icpMap[s]?.won||0)/tot*100);
    return{stars:s,won:icpMap[s].won,total:tot,wr};
  });
  const bestIcp=icpRows.sort((a,b)=>b.wr-a.wr)[0];

  // Top industries
  const indMap={};
  wonLeads.forEach(l=>{const k=l.ind||'Ukendt';indMap[k]=(indMap[k]||0)+1;});
  const topInds=Object.entries(indMap).sort((a,b)=>b[1]-a[1]).slice(0,3);

  // Activity patterns from progressed/won deals
  const progressed=leads.filter(l=>['Forhandling','Tilbud sendt','Vundet'].includes(aePipe[l.cvr]));
  const actCount={call:0,email:0,meeting:0,followup:0};
  progressed.forEach(l=>(leadActivities[l.cvr]||[]).forEach(a=>{if(actCount[a.type]!==undefined)actCount[a.type]++;}));
  const totalActs=Object.values(actCount).reduce((a,b)=>a+b,0)||1;
  const actRows=Object.entries(actCount).filter(([,c])=>c>0).sort((a,b)=>b[1]-a[1])
    .map(([type,count])=>({type,label:ACT_LABELS[type]||type,ico:(ACT_TYPES[type]||{ico:''}).ico,count,pct:Math.round(count/totalActs*100)}));

  // Avg acts to win
  const avgActsToWin=wonLeads.length>0
    ?Math.round(wonLeads.reduce((s,l)=>s+(leadActivities[l.cvr]||[]).length,0)/wonLeads.length)
    :null;

  return{scoredDeals,wonLeads,lostLeads,activeLeads,icpRows,icpMap,bestIcp,topInds,actRows,avgActsToWin};
}


function toggleRI(){
  _riOpen=!_riOpen;
  const card=document.querySelector('.ri-card');
  if(!card)return;
  const body=card.querySelector('.ri-body');
  const chevron=card.querySelector('.ri-chevron');
  if(body) body.style.display=_riOpen?'':'none';
  if(chevron){ chevron.classList.toggle('open',_riOpen); }
}

async function runRevenueAI(){
  const btn=document.getElementById('ri-ai-btn');
  const resEl=document.getElementById('ri-ai-result');
  if(!btn||!resEl)return;
  btn.disabled=true;btn.textContent='Analyserer…';
  const d=buildRevenueIntelData();
  try{
    const r=await fetch('/api/revenue-intelligence',{method:'POST',headers:ah(),body:JSON.stringify({
      activeDeals:d.activeLeads.length,wonDeals:d.wonLeads.length,lostDeals:d.lostLeads.length,
      hotDeals:d.scoredDeals.slice(0,3).map(x=>({name:x.lead.name,stage:x.stage,prob:x.prob})),
      icpStats:d.bestIcp?{best:d.bestIcp.stars,bestRate:d.bestIcp.wr}:null,
      actStats:d.actRows[0]?{topType:d.actRows[0].label}:null,
      topIndustries:d.topInds.map(([ind])=>ind)
    })});
    const data=await r.json();
    resEl.innerHTML=`<div class="ri-ai-result">
      <div style="font-size:9.5px;font-weight:700;color:var(--p1);text-transform:uppercase;letter-spacing:.8px;margin-bottom:7px">AI Revenue Signal</div>
      <div style="color:var(--pdarker);font-weight:600;margin-bottom:8px">${e(data.signal||'')}</div>
      ${data.actions?.length?`<div style="display:flex;flex-direction:column;gap:5px;margin-bottom:${data.strategy?'8':'0'}px">${data.actions.map((a,i)=>`<div style="display:flex;gap:7px;align-items:flex-start"><span style="background:var(--p1);color:#fff;border-radius:50%;width:16px;height:16px;font-size:9px;font-weight:700;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px">${i+1}</span><span style="color:var(--gray)">${e(a)}</span></div>`).join('')}</div>`:''}
      ${data.strategy?`<div style="padding:7px 10px;background:rgba(130,88,168,.08);border-radius:6px;font-size:11px;color:var(--pdarker)"><strong>Strategi:</strong> ${e(data.strategy)}</div>`:''}
    </div>`;
  }catch(err){
    resEl.innerHTML=`<div class="ri-ai-result" style="color:var(--gray2)">AI ikke tilgængelig.</div>`;
  }
  if(btn){btn.disabled=false;btn.innerHTML='AI Signal';}
}

/* ── Dashboard module drag & hide system ─────────────────────────────── */
let _dashEditMode=false;
let _dmDragSrc=null;
const DASH_MODS=[
  {id:'kpicards',label:'KPI-kort',icon:''},
  {id:'attention',label:'Opmærksomhed & Opgaver',icon:''},
  {id:'wins',label:'Seneste Resultater',icon:''},
  {id:'scorecard',label:'Sales Scorecard',icon:''},
];
function getDashOrder(){
  const validIds=new Set(DASH_MODS.map(m=>m.id));
  const stored=JSON.parse(localStorage.getItem('vl_dash_order')||'null');
  if(!stored)return DASH_MODS.map(m=>m.id);
  const filtered=stored.filter(id=>validIds.has(id));
  const missing=DASH_MODS.map(m=>m.id).filter(id=>!filtered.includes(id));
  return [...filtered,...missing];
}
function getDashHidden(){return new Set(JSON.parse(localStorage.getItem('vl_dash_hidden')||'[]'));}
function saveDashOrder(order){localStorage.setItem('vl_dash_order',JSON.stringify(order));}
function saveDashHidden(hidden){localStorage.setItem('vl_dash_hidden',JSON.stringify([...hidden]));}
function toggleDashEdit(){_dashEditMode=!_dashEditMode;rDashboard();}
function dmHide(id){const h=getDashHidden();h.add(id);saveDashHidden(h);rDashboard();}
function dmRestore(id){const h=getDashHidden();h.delete(id);saveDashHidden(h);rDashboard();}
function dmDragStart(ev,id){
  _dmDragSrc=id;ev.dataTransfer.effectAllowed='move';ev.dataTransfer.setData('text/plain',id);
  setTimeout(()=>{const el=document.getElementById('dm-mod-'+id);if(el)el.classList.add('dm-dragging');},0);
}
function dmDragOver(ev,id){
  if(id===_dmDragSrc)return;ev.preventDefault();ev.dataTransfer.dropEffect='move';
  document.querySelectorAll('.dm-module').forEach(el=>el.classList.remove('dm-drag-over'));
  const el=document.getElementById('dm-mod-'+id);if(el)el.classList.add('dm-drag-over');
}
function dmDragLeave(ev,id){const el=document.getElementById('dm-mod-'+id);if(el)el.classList.remove('dm-drag-over');}
function dmDrop(ev,targetId){
  ev.preventDefault();if(!_dmDragSrc||_dmDragSrc===targetId)return;
  const order=getDashOrder();const from=order.indexOf(_dmDragSrc);const to=order.indexOf(targetId);
  if(from<0||to<0)return;order.splice(from,1);order.splice(to,0,_dmDragSrc);saveDashOrder(order);
  document.querySelectorAll('.dm-module').forEach(el=>el.classList.remove('dm-drag-over','dm-dragging'));
  rDashboard();
}
function dmDragEnd(){
  _dmDragSrc=null;
  document.querySelectorAll('.dm-module').forEach(el=>el.classList.remove('dm-dragging','dm-drag-over'));
}
function dmWrap(id,content){
  const m=DASH_MODS.find(x=>x.id===id)||{label:id,icon:''};
  const editAttrs=_dashEditMode?` draggable="true" ondragstart="dmDragStart(event,'${id}')" ondragover="dmDragOver(event,'${id}')" ondragleave="dmDragLeave(event,'${id}')" ondrop="dmDrop(event,'${id}')" ondragend="dmDragEnd()"`:` ondragover="dmDragOver(event,'${id}')" ondragleave="dmDragLeave(event,'${id}')" ondrop="dmDrop(event,'${id}')"`;
  return `<div class="dm-module${_dashEditMode?' dm-edit-active':''}" id="dm-mod-${id}"${editAttrs}>
    <div class="dm-handle-bar">
      <span style="font-size:16px;color:var(--gray2);cursor:grab;line-height:1">⠿</span>
      <span style="font-size:12px;font-weight:600;color:var(--gray);flex:1">${m.icon} ${m.label}</span>
      <button class="dm-hide-btn" onclick="dmHide('${id}')" title="Skjul modul">✕</button>
    </div>
    ${content}
  </div>`;}

const scoreColor=(val,green,yellow)=>val>=green?'#10b981':val>=yellow?'#f59e0b':'#ef4444';

async function rDashboard(){
  const panel=document.getElementById('dashboard-panel');
  if(!panel)return;
  const today=todayStr();
  const weekStart=getWeekStart();
  const monthStart=today.slice(0,7)+'-01';
  const allActs=allActivities();

  const callsToday=allActs.filter(a=>a.type==='call'&&a.date===today).length;
  const callsWeek=allActs.filter(a=>a.type==='call'&&a.date>=weekStart).length;
  const emailsWeek=allActs.filter(a=>a.type==='email'&&a.date>=weekStart).length;
  const followupsWeek=allActs.filter(a=>a.type==='followup'&&a.date>=weekStart).length;
  const meetingsWeek=allActs.filter(a=>a.type==='meeting'&&a.date>=weekStart).length;
  const tasksOpen=allActs.filter(a=>!a.done&&a.date&&a.date<=today).length;
  const todayTasks=allActs.filter(a=>!a.done&&a.date===today).sort((a,b)=>(a.time||'').localeCompare(b.time||''));
  const leadsWeek=leads.filter(l=>l.addedAt&&l.addedAt.slice(0,10)>=weekStart).length;
  const leadsMonth=leads.filter(l=>l.addedAt&&l.addedAt.slice(0,10)>=monthStart).length;
  const leadsTotal=leads.length;

  const aePipe=pipelines.ae||{};
  const sdrPipe=pipelines.sdr||{};

  // Deal risk counts — compute once per lead
  const riskCache=new Map();
  leads.forEach(l=>riskCache.set(l.cvr,computeDealRisk(l.cvr,l,leadDeal[l.cvr],leadActivities[l.cvr]||[])));
  const atRiskDeals=leads.filter(l=>riskCache.get(l.cvr)?.level==='high');
  const atRiskMed=leads.filter(l=>riskCache.get(l.cvr)?.level==='medium');

  const pipeLeads=leads.filter(l=>aePipe[l.cvr]&&aePipe[l.cvr]!=='Tabt');
  const wonLeads=leads.filter(l=>aePipe[l.cvr]==='Vundet');
  const lostLeads=leads.filter(l=>aePipe[l.cvr]==='Tabt');
  const pipeValue=pipeLeads.reduce((s,l)=>s+(l.omsaetning||0),0);
  const activeDeals=pipeLeads.length-wonLeads.length;
  const winRate=(wonLeads.length+lostLeads.length)>0?Math.round(wonLeads.length/(wonLeads.length+lostLeads.length)*100):0;

  let teamStats=[];
  if(isServerMode&&authToken){try{teamStats=await fetch('/api/stats/team',{headers:ah()}).then(r=>r.ok?r.json():[]);}catch(e){}}

  const hr=new Date().getHours();
  const greeting=hr<12?'God morgen':hr<17?'God eftermiddag':'God aften';
  const dkDate=new Date().toLocaleDateString('da-DK',{weekday:'long',day:'numeric',month:'long'});

  // SVG icon map for KPI cards (only icons actually used)
  const kpiIcons={
    'briefcase':'<div class="kpi-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg></div>',
    'dollar':'<div class="kpi-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>',
    'phone':'<div class="kpi-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>',
    'chart':'<div class="kpi-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M18 20V10M12 20V4M6 20v-6"/></svg></div>'
  };
  // Dark KPI card
  const dmKpi=(ico,val,lbl,sub,badgeClass,type)=>`
    <div class="dm-kpi"${type?' onclick="showDashDrawer(\''+type+'\')"':''}>
      <div class="dm-kpi-ico">${kpiIcons[ico]||ico}</div>
      <div class="dm-kpi-val">${val}</div>
      <div class="dm-kpi-lbl">${lbl}</div>
      ${sub?'<div class="dm-kpi-sub"><span class="dm-badge '+(badgeClass||'dm-badge-neu')+'">'+sub+'</span></div>':''}
    </div>`;

  // New computations
  const upcomingActs = allActs.filter(a=>!a.done&&a.date&&a.date>=today).sort((a,b)=>a.date.localeCompare(b.date)).slice(0,8);
  const recentWins = wonLeads.sort((a,b)=>(b.addedAt||'').localeCompare(a.addedAt||'')).slice(0,5);

  // Needs attention items
  const needsAttention = [];
  atRiskDeals.forEach(l=>{
    needsAttention.push({cvr:l.cvr,name:l.name||l.cvr,reason:'Risiko',badgeClass:'risk'});
  });
  // Overdue tasks
  allActs.filter(a=>!a.done&&a.date&&a.date<today).forEach(a=>{
    const co=leads.find(l=>l.cvr===a.cvr);
    if(co&&!needsAttention.find(x=>x.cvr===co.cvr)){
      needsAttention.push({cvr:co.cvr,name:co.name||co.cvr,reason:'Forfalden opgave',badgeClass:'overdue'});
    }
  });
  const attentionItems = needsAttention.slice(0,8);

  // Scorecard calculations
  const wonValue=wonLeads.reduce((s,l)=>s+(parseFloat(l.deal?.revenue)||0),0);
  const activityRate=callsWeek+emailsWeek;
  const convRate=leadsTotal>0?Math.round(wonLeads.length/leadsTotal*100):0;
  const pipeCoverage=wonValue>0?Math.round(pipeValue/wonValue*10)/10:0;

  // Avg deal cycle (days from addedAt to last activity for won leads)
  let avgCycle=0;
  if(wonLeads.length){
    const cycles=wonLeads.map(l=>{
      const added=new Date(l.addedAt||l.createdAt||today);
      const acts=allActs.filter(a=>a.cvr===l.cvr).sort((a,b)=>b.date.localeCompare(a.date));
      const lastAct=acts[0]?new Date(acts[0].date):new Date();
      return Math.round((lastAct-added)/(1000*60*60*24));
    }).filter(d=>d>0);
    avgCycle=cycles.length?Math.round(cycles.reduce((s,d)=>s+d,0)/cycles.length):0;
  }

  // Module: KPI Cards
  const modKpicards = `<div class="dm-kpi-grid">
    ${dmKpi('briefcase',leadsTotal,'Leads i alt',leadsWeek>0?'+'+leadsWeek+' denne uge':null,leadsWeek>0?'dm-badge-up':'dm-badge-neu','leads_week')}
    ${dmKpi('dollar',activeDeals,'Aktive Deals',activeDeals+' i pipeline','dm-badge-neu','active_deals')}
    ${dmKpi('phone',callsWeek,'Opkald denne uge',callsToday>0?'+'+callsToday+' i dag':null,callsToday>0?'dm-badge-up':'dm-badge-neu','calls')}
    ${dmKpi('chart',fmtKr(pipeValue),'Pipeline-værdi',null,null,'pipeline_value')}
  </div>`;

  // Module: Attention + Upcoming
  const attnHtml = attentionItems.length ? attentionItems.map(it=>`
    <div class="dm-attn-item" onclick="openDealCard('${it.cvr}')">
      <div class="dm-attn-dot" style="background:${it.badgeClass==='risk'?'#ef4444':it.badgeClass==='overdue'?'#f59e0b':'#6366f1'}"></div>
      <div class="dm-attn-info">
        <div class="dm-attn-name">${e(it.name)}</div>
      </div>
      <div class="dm-attn-badge ${it.badgeClass}">${e(it.reason)}</div>
    </div>`).join('') : '<div style="padding:16px;text-align:center;color:var(--gray);font-size:12px">Alt ser godt ud</div>';

  const upcomingHtml = upcomingActs.length ? upcomingActs.map(a=>{
    const co=leads.find(l=>l.cvr===a.cvr);
    const t=ACT_TYPES[a.type]||{ico:'',lbl:'Opgave'};
    const d=new Date(a.date);
    const dateStr=d.toLocaleDateString('da-DK',{day:'numeric',month:'short'});
    return `<div class="dm-timeline-item">
      <div class="dm-timeline-date">${dateStr}</div>
      <div class="dm-timeline-body">
        <div class="dm-timeline-title">${e(co?.name||a.cvr)}</div>
        <div class="dm-timeline-meta">${e(a.title||t.lbl)}</div>
      </div>
    </div>`;
  }).join('') : '<div style="padding:16px;text-align:center;color:var(--gray);font-size:12px">Ingen kommende opgaver</div>';

  const modAttention = `<div class="dm-attention-grid">
    <div class="dm-card">
      <div class="dm-card-hd">KRÆVER OPMÆRKSOMHED — ${attentionItems.length}</div>
      ${attnHtml}
    </div>
    <div class="dm-card">
      <div class="dm-card-hd">KOMMENDE OPGAVER</div>
      ${upcomingHtml}
    </div>
  </div>`;

  // Module: Recent Wins
  const winsHtml = recentWins.length ? recentWins.map(l=>{
    const val=parseFloat(l.deal?.revenue)||0;
    const dateStr=l.addedAt?new Date(l.addedAt).toLocaleDateString('da-DK',{year:'numeric',month:'2-digit',day:'2-digit'}):'';
    return `<div class="dm-win-item" onclick="openDealCard('${l.cvr}')">
      <div class="dm-win-check">✓</div>
      <div class="dm-win-info">
        <div class="dm-win-name">${e(l.name||l.cvr)}</div>
      </div>
      <div class="dm-win-val">${val>0?fmtKr(val):''}</div>
      <div class="dm-win-date">${dateStr}</div>
    </div>`;
  }).join('') : '<div style="padding:16px;text-align:center;color:var(--gray);font-size:12px">Ingen vundne deals endnu</div>';

  const modWins = `<div class="dm-card">
    <div class="dm-card-hd">SENESTE RESULTATER</div>
    ${winsHtml}
  </div>`;

  // Module: Sales Scorecard
  const scoreRows = [
    {lbl:'Win Rate',val:winRate+'%',color:scoreColor(winRate,40,20)},
    {lbl:'Gns. Deal Cyklus',val:avgCycle+' dage',color:scoreColor(avgCycle<=30?40:avgCycle<=60?25:0,40,20)},
    {lbl:'Pipeline Coverage',val:pipeCoverage+'x',color:scoreColor(pipeCoverage,3,1)},
    {lbl:'Aktivitetsrate',val:activityRate+' / uge',color:scoreColor(activityRate,20,10)},
    {lbl:'Konverteringsrate',val:convRate+'%',color:scoreColor(convRate,15,5)},
  ];

  const modScorecard = `<div class="dm-card">
    <div class="dm-card-hd">SALES SCORECARD</div>
    ${scoreRows.map(r=>`<div class="dm-scorecard-row">
      <div class="dm-scorecard-lbl">${r.lbl}</div>
      <div class="dm-scorecard-val" style="color:${r.color}">${r.val}</div>
      <div class="dm-scorecard-dot" style="background:${r.color}"></div>
    </div>`).join('')}
  </div>`;

  const modMap = {kpicards:modKpicards, attention:modAttention, wins:modWins, scorecard:modScorecard};

  const order = getDashOrder();
  const hidden = getDashHidden();
  const editClass = _dashEditMode ? ' dm-edit-active' : '';
  const modulesHtml = order.filter(id=>!hidden.has(id)&&modMap[id]).map(id=>dmWrap(id,modMap[id])).join('');

  // Restore bar for hidden modules
  const hiddenMods = order.filter(id=>hidden.has(id));
  const restoreBar = hiddenMods.length ? `<div class="dm-restore-bar has-hidden">${hiddenMods.map(id=>{
    const m=DASH_MODS.find(x=>x.id===id);
    return m?`<button class="dm-restore-btn" onclick="dmRestore('${id}')">+ ${e(m.label)}</button>`:'';
  }).join('')}</div>` : '<div class="dm-restore-bar"></div>';

  panel.innerHTML = `<div class="dm-page${editClass}">
    <div class="dm-hd">
      <div>
        <div class="dm-greeting">${greeting}, ${e(currentUser?.name?.split(' ')[0]||'bruger')} 👋</div>
        <div class="dm-date">${dkDate}</div>
      </div>
      <div style="display:flex;align-items:center;gap:12px">
        <button class="dm-customize-btn${_dashEditMode?' dm-active':''}" onclick="toggleDashEdit()">${_dashEditMode?'✓ Færdig':'Tilpas dashboard'}</button>
        <div class="dm-live"><div class="dm-live-dot"></div> Live</div>
      </div>
    </div>
    <div class="dm-modules-wrap">
      ${modulesHtml}
    </div>
    ${restoreBar}
  </div>`;
}

function showDashDrawer(type){
  const drawer=document.getElementById('dash-drawer');
  const titleEl=document.getElementById('dash-drawer-title');
  const body=document.getElementById('dash-drawer-body');
  const bd=document.getElementById('dash-drawer-bd');
  const today=todayStr();
  const weekStart=getWeekStart();
  const allActs=allActivities();

  const STAGE_BG={'Ny':'#e0f2fe','Kvalificeret':'#dcfce7','I dialog':'#fef9c3','Tilbud':'#fdf2f8','Vundet':'#dcfce7','Tabt':'#fee2e2'};
  const STAGE_TX={'Ny':'#0369a1','Kvalificeret':'#15803d','I dialog':'#854d0e','Tilbud':'#86198f','Vundet':'#166534','Tabt':'#991b1b'};

  const actList=(acts,empty)=>{
    if(!acts.length)return '<div style="text-align:center;padding:32px 20px;color:var(--gray2);font-size:12px">'+empty+'</div>';
    return acts.map(a=>{
      const co=leads.find(l=>l.cvr===a.cvr);
      const t=ACT_TYPES[a.type]||{ico:'',lbl:'Aktivitet'};
      const done=a.done;
      return '<div class="dash-drawer-item" onclick="closeDashDrawer();openDealCard(\''+a.cvr+'\')">'+
        '<div style="flex-shrink:0">'+t.ico+'</div>'+
        '<div style="flex:1;min-width:0"><div style="font-size:12px;font-weight:600;color:var(--pdarker);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">'+e(a.title||t.lbl)+'</div>'+
        '<div style="font-size:11px;color:var(--gray);margin-top:1px">'+(co?e(co.name):'—')+' · '+(a.date||'')+' '+(a.time||'')+'</div></div>'+
        (done?'<span style="font-size:11px;color:var(--green);background:var(--greenbg);padding:2px 7px;border-radius:5px;font-weight:600;flex-shrink:0">✓ Udført</span>':
              '<span style="font-size:11px;color:var(--amber);background:var(--amberbg);padding:2px 7px;border-radius:5px;font-weight:600;flex-shrink:0">Åben</span>')+
        '</div>';
    }).join('');
  };

  const leadList=(arr,empty)=>{
    if(!arr.length)return '<div style="text-align:center;padding:32px 20px;color:var(--gray2);font-size:12px">'+empty+'</div>';
    return arr.map(c=>{
      const icp=getIcp(c);const stage=(pipelines.ae||{})[c.cvr]||(pipelines.sdr||{})[c.cvr]||'';
      return '<div class="dash-drawer-item" onclick="closeDashDrawer();openDealCard(\''+c.cvr+'\')">'+
        '<div style="flex:1;min-width:0">'+
        '<div style="font-size:12.5px;font-weight:600;color:var(--pdarker);margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">'+e(c.name)+'</div>'+
        '<div style="font-size:11px;color:var(--gray);margin-bottom:3px">'+e(c.ind||c.industry||'')+'</div>'+
        (stage?'<span style="font-size:10px;padding:1px 6px;border-radius:5px;font-weight:600;background:'+(STAGE_BG[stage]||'var(--p6)')+';color:'+(STAGE_TX[stage]||'var(--p1)')+'">'+stage+'</span>':'')+
        '</div>'+
        '<div style="text-align:right;flex-shrink:0;margin-left:10px">'+
        '<div style="font-size:12px;font-weight:700;color:var(--pdarker)">'+fmtKr(c.omsaetning)+'</div>'+
        '<div style="font-size:11px;color:var(--amber);letter-spacing:-1px">'+'★'.repeat(icp)+'☆'.repeat(5-icp)+'</div>'+
        '</div></div>';
    }).join('');
  };

  let heading='',html='';
  if(type==='calls'){heading='Opkald denne uge';html=actList(allActs.filter(a=>a.type==='call'&&a.date>=weekStart).sort((a,b)=>b.date.localeCompare(a.date)),'Ingen opkald denne uge');}
  else if(type==='emails'){heading='Emails denne uge';html=actList(allActs.filter(a=>a.type==='email'&&a.date>=weekStart).sort((a,b)=>b.date.localeCompare(a.date)),'Ingen emails denne uge');}
  else if(type==='followups'){heading='Opfølgninger denne uge';html=actList(allActs.filter(a=>a.type==='followup'&&a.date>=weekStart).sort((a,b)=>b.date.localeCompare(a.date)),'Ingen opfølgninger denne uge');}
  else if(type==='meetings'){heading='Møder denne uge';html=actList(allActs.filter(a=>a.type==='meeting'&&a.date>=weekStart).sort((a,b)=>b.date.localeCompare(a.date)),'Ingen møder denne uge');}
  else if(type==='tasks_open'){heading='⏰ Åbne opgaver';html=actList(allActs.filter(a=>!a.done&&a.date&&a.date<=today).sort((a,b)=>a.date.localeCompare(b.date)),'Ingen åbne opgaver');}
  else if(type==='leads_week'){heading='Leads tilføjet denne uge';html=leadList(leads.filter(l=>l.addedAt&&l.addedAt.slice(0,10)>=weekStart).sort((a,b)=>(b.addedAt||'').localeCompare(a.addedAt||'')),'Ingen leads tilføjet denne uge');}
  else if(type==='active_deals'){const ae=pipelines.ae||{};heading='Aktive deals';html=leadList(leads.filter(l=>ae[l.cvr]&&ae[l.cvr]!=='Vundet'&&ae[l.cvr]!=='Tabt'),'Ingen aktive deals');}
  else if(type==='won'){const ae=pipelines.ae||{};heading='Vundne deals';html=leadList(leads.filter(l=>ae[l.cvr]==='Vundet').sort((a,b)=>(b.omsaetning||0)-(a.omsaetning||0)),'Ingen vundne deals endnu');}
  else if(type==='pipeline_value'){const ae=pipelines.ae||{};heading='Pipeline — alle deals';html=leadList(leads.filter(l=>ae[l.cvr]).sort((a,b)=>(b.omsaetning||0)-(a.omsaetning||0)),'Ingen deals i pipeline');}
  else if(type==='win_rate'){const ae=pipelines.ae||{};heading='Afsluttede deals';html=leadList(leads.filter(l=>ae[l.cvr]==='Vundet'||ae[l.cvr]==='Tabt').sort((a,b)=>(b.omsaetning||0)-(a.omsaetning||0)),'Ingen afsluttede deals');}
  else{heading='Detaljer';html='<div style="padding:20px;color:var(--gray2)">Ingen data</div>';}

  titleEl.textContent=heading;
  body.innerHTML=html;
  drawer.style.display='flex';
  bd.style.display='block';
}

function closeDashDrawer(){
  document.getElementById('dash-drawer').style.display='none';
  document.getElementById('dash-drawer-bd').style.display='none';
}

// ── DEALS KANBAN ──────────────────────────────────────────────────────────────
let dragCvr=null;

function dragStart(e,cvr){
  dragCvr=cvr;
  e.dataTransfer.effectAllowed='move';
  // slight delay so the card renders as "dragging" after pickup
  setTimeout(()=>e.target.classList.add('dragging'),0);
}
function dragEnd(e){
  e.target.classList.remove('dragging');
  document.querySelectorAll('.kb-cards').forEach(c=>c.classList.remove('drag-over'));
}
function dragOver(e){
  e.preventDefault();
  e.dataTransfer.dropEffect='move';
  e.currentTarget.classList.add('drag-over');
}
function dragLeave(e){
  if(!e.currentTarget.contains(e.relatedTarget))
    e.currentTarget.classList.remove('drag-over');
}
async function dropCard(e,stage){
  e.preventDefault();
  e.currentTarget.classList.remove('drag-over');
  if(!dragCvr)return;
  await setPipeline(dragCvr,stage);
  dragCvr=null;
  rDeals();
}

// ══════════════════════════════════════════════════════════════════════════════
// CALLS MODULE
// ══════════════════════════════════════════════════════════════════════════════

function fmtDur(sec){
  if(!sec)return'0:00';
  const m=Math.floor(sec/60),s=sec%60;
  return m+':'+(s<10?'0':'')+s;
}
function fmtDateTime(iso){
  if(!iso)return'—';
  const d=new Date(iso);
  return d.toLocaleDateString('da-DK',{day:'2-digit',month:'short'})+' '+d.toLocaleTimeString('da-DK',{hour:'2-digit',minute:'2-digit'});
}
function outcomeLabel(o){
  return{interested:'Interesseret',callback:'Ring igen',booked:'Møde booket','not-interested':'Ikke interesseret','no-answer':'Ikke svar','voicemail':'Besked','completed':'Gennemført','no-show':'Mødt ikke op'}[o]||o||'—';
}
function outcomeBadgeStyle(o){
  const m={interested:'background:#dcfce7;color:#16a34a',booked:'background:#f3e8ff;color:#7c3aed',callback:'background:#fef9c3;color:#854d0e','not-interested':'background:#fee2e2;color:#dc2626','no-answer':'background:var(--gray3);color:var(--gray)','no-show':'background:#fee2e2;color:#dc2626',voicemail:'background:#dbeafe;color:#1d4ed8',completed:'background:#dcfce7;color:#16a34a'};
  return m[o]||'background:var(--gray3);color:var(--gray)';
}

function rCalls(){
  const panel=document.getElementById('calls-panel');
  if(!panel)return;
  const role=(currentUser?.role||'').toUpperCase();
  // Build queue from leads list
  const qLeads=leads.slice(0,50);
  panel.innerHTML=`
<div class="cl-page">
  <div class="cl-hd">
    <div style="font-size:15px;font-weight:800;color:var(--pdarker)">Opkald</div>
    <div class="cl-tabs">
      <button class="cl-tab${activeCallPane==='calls'?' on':''}" onclick="setCallPane('calls')">Ring op</button>
      <button class="cl-tab${activeCallPane==='demos'?' on':''}" onclick="setCallPane('demos')">Demos</button>
    </div>
    <div style="flex:1"></div>
    ${activeCallPane==='calls'?`
    <div style="display:flex;align-items:center;gap:10px">
      <select id="script-sel" onchange="changeScript(this.value)" style="font-size:11px;padding:4px 8px;border:1px solid var(--border);border-radius:6px;background:#fff;color:var(--pdarker);outline:none">
        ${callScripts.map(s=>`<option value="${s.id}" ${activeScript?.id===s.id?'selected':''}>${e(s.name)}</option>`).join('')}
      </select>
      <button class="btn btn-sm" style="font-size:11px" onclick="openScriptEditor()">Rediger script</button>
    </div>` : `
    <button class="btn btn-primary btn-sm" onclick="openAddDemo()">+ Tilføj demo</button>`}
  </div>

  ${activeCallPane==='calls'?renderCallsTab(qLeads):renderDemosTab()}
</div>`;
  initCallTimerDisplay();
}

function renderCallsTab(qLeads){
  const statsToday=callLog.filter(c=>{
    const d=c.createdAt?.slice(0,10);return d===todayStr();
  });
  const totalDurToday=statsToday.reduce((s,c)=>s+(c.duration||0),0);
  const wonToday=statsToday.filter(c=>c.outcome==='interested'||c.outcome==='booked').length;
  return`
<div style="background:#fff;border-bottom:1px solid var(--border);padding:8px 20px;display:flex;gap:20px;flex-shrink:0">
  <div style="display:flex;align-items:center;gap:6px">
    <span style="font-size:18px;font-weight:800;color:var(--pdarker)">${statsToday.length}</span>
    <span style="font-size:10px;color:var(--gray)">opkald i dag</span>
  </div>
  <div style="display:flex;align-items:center;gap:6px">
    <span style="font-size:18px;font-weight:800;color:var(--pdarker)">${fmtDur(totalDurToday)}</span>
    <span style="font-size:10px;color:var(--gray)">tale-tid</span>
  </div>
  <div style="display:flex;align-items:center;gap:6px">
    <span style="font-size:18px;font-weight:800;color:#16a34a">${wonToday}</span>
    <span style="font-size:10px;color:var(--gray)">positive</span>
  </div>
  <div style="margin-left:auto;display:flex;align-items:center;gap:8px">
    <span style="font-size:11px;color:var(--gray)">Auto-dial:</span>
    <button id="autodial-btn" class="btn btn-sm" onclick="toggleAutoDial()" style="font-size:11px;${autoDial?'background:var(--p1);color:#fff':''}">
      ${autoDial?'Pause':'▶ Start auto-dial'}
    </button>
  </div>
</div>
<div class="cl-body" style="flex:1;overflow:hidden">
  <!-- LEFT: call queue -->
  <div class="cl-queue">
    <div class="cl-queue-hd">Kaldekø (${qLeads.length} leads)
      <select id="queue-list-sel" onchange="rCalls()" style="float:right;font-size:9px;border:none;background:transparent;color:var(--p1);font-weight:700;outline:none;cursor:pointer">
        ${lists.map(l=>`<option value="${l.id}">${l.name}</option>`).join('')}
      </select>
    </div>
    <div class="cl-queue-list">
      ${qLeads.length===0?`<div style="text-align:center;padding:20px;color:var(--gray2);font-size:12px">Ingen leads i køen.<br>Tilføj leads under Mine leads.</div>`:''}
      ${(()=>{const lastCallMap=new Map(callLog.map(c=>[c.cvr,c]));return qLeads.map((l,i)=>{
        const isCalling=activeCall?.cvr===l.cvr;
        const lastCall=lastCallMap.get(l.cvr);
        const lastOutcome=lastCall?.outcome;
        return`<div class="cl-queue-item${isCalling?' calling':''}" onclick="selectQueueLead('${l.cvr}')">
          <div style="width:28px;height:28px;border-radius:50%;background:${isCalling?'var(--p1)':'var(--p7)'};display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:${isCalling?'#fff':'var(--pdarker)'};flex-shrink:0">${(l.name||'?')[0]}</div>
          <div style="flex:1;min-width:0">
            <div class="cl-qi-name">${e(l.name)}</div>
            <div class="cl-qi-ph">${l.ph?l.ph:'Ingen tlf.'}</div>
          </div>
          ${lastOutcome?`<span class="cl-qi-badge" style="${outcomeBadgeStyle(lastOutcome)}">${outcomeLabel(lastOutcome).split(' ')[0]}</span>`:''}
        </div>`;
      }).join('');})()}
    </div>
    <div class="cl-autodial" style="font-size:10px;color:var(--gray)">
      ${autoDial?`<span style="color:var(--p1);font-weight:700">▶ Auto-dial kører</span><span style="margin-left:auto">${autoDialIdx+1}/${autoDialQueue.length}</span>`:'Vælg et lead for at starte opkald'}
    </div>
  </div>

  <!-- CENTER: dialer -->
  <div class="cl-dialer">
    <div id="cl-dialer-inner" style="display:flex;flex-direction:column;height:100%">
      ${renderDialerEmpty()}
    </div>
  </div>
</div>

<!-- HISTORY -->
<div class="cl-hist">
  <div class="cl-hist-hd">Opkaldshistorik — alle opkald (${callLog.length})</div>
  ${callLog.length===0?`<div style="text-align:center;padding:16px;color:var(--gray2);font-size:12px">Ingen opkald endnu.</div>`:''}
  ${callLog.slice(0,30).map(c=>`
    <div class="cl-hist-row">
      <span style="color:var(--gray);font-size:10px">${fmtDateTime(c.createdAt)}</span>
      <span class="n">${e(c.companyName||'—')}</span>
      <span>${fmtDur(c.duration)}</span>
      <span><span class="cl-qi-badge" style="${outcomeBadgeStyle(c.outcome)};font-size:9px;padding:2px 7px;border-radius:4px;font-weight:700">${outcomeLabel(c.outcome)}</span></span>
      <span style="font-size:10px;color:var(--gray);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${e(c.notes||'')}</span>
      <span><button class="cl-hist-row ai-btn" onclick="showCallAI('${c.id}')">AI</button></span>
    </div>`).join('')}
</div>`;
}

function renderDialerEmpty(){
  return`<div class="cl-dialer-empty">
    <div style="font-size:40px">&#9742;</div>
    <div style="font-size:14px;font-weight:600;color:var(--gray)">Vælg et lead fra køen for at starte et opkald</div>
    <div style="font-size:12px;color:var(--gray2)">Klik på et lead til venstre eller brug auto-dial</div>
  </div>`;
}

function renderDialerActive(lead){
  const script=activeScript;
  const ph=lead.ph||lead.phone||'';
  const em=lead.em||lead.email||'';
  const web=lead.web||lead.website||'';
  const rev=lead.omsaetning||0;
  const emp=lead.emps||lead.emp||'';
  const prevCalls=callLog.filter(c=>c.cvr===lead.cvr);
  const lastCall=prevCalls[prevCalls.length-1];
  const sdrStage=(pipelines.sdr||{})[lead.cvr];
  const aeStage=(pipelines.ae||{})[lead.cvr];
  const pipeStage=aeStage||sdrStage||'';
  return`
<div class="cl-call-hd">
  <div style="flex:1;min-width:0">
    <div style="display:flex;align-items:center;gap:10px">
      <div style="font-size:16px;font-weight:800;color:var(--pdarker)">${e(lead.name)}</div>
      ${pipeStage?`<span style="font-size:10px;font-weight:700;background:rgba(130,88,168,.12);color:var(--p1);padding:2px 8px;border-radius:10px">${e(pipeStage)}</span>`:''}
    </div>
    <div style="font-size:11px;color:var(--gray);margin-top:2px">${e(lead.ind||'')}${lead.city?' · '+e(lead.city):''}${lead.cvr?' · CVR '+lead.cvr:''}</div>
    <!-- Quick data chips -->
    <div style="display:flex;flex-wrap:wrap;gap:5px;margin-top:7px">
      ${rev?`<span class="cl-chip">${fmtKr(rev)}</span>`:''}
      ${emp?`<span class="cl-chip">${e(String(emp))} ans.</span>`:''}
      ${ph?`<a href="tel:${ph}" class="cl-chip" style="color:var(--p1);text-decoration:none">${e(ph)}</a>`:''}
      ${em?`<a href="mailto:${em}" class="cl-chip" style="color:var(--p1);text-decoration:none">${e(em)}</a>`:''}
      ${web?`<a href="${e(web.startsWith('http')?web:'https://'+web)}" target="_blank" class="cl-chip" style="color:var(--p1);text-decoration:none">${e(web.replace(/^https?:\/\//,''))}</a>`:''}
      ${prevCalls.length?`<span class="cl-chip" style="background:#fef9c3;color:#92400e">${prevCalls.length} tidl. opkald${lastCall?' · '+outcomeLabel(lastCall.outcome):''}</span>`:''}
    </div>
  </div>
  <div style="display:flex;flex-direction:column;align-items:flex-end;gap:6px;flex-shrink:0">
    <div style="display:flex;align-items:center;gap:10px">
      <div id="cl-timer" class="cl-timer">0:00</div>
      <span id="cl-status" class="cl-call-status idle">Klar</span>
    </div>
    <button onclick="showDp('${lead.cvr}')" style="font-size:11px;font-weight:600;color:var(--p1);background:rgba(130,88,168,.07);border:1px solid rgba(130,88,168,.2);border-radius:6px;padding:4px 10px;cursor:pointer">Se lead →</button>
  </div>
</div>
<div class="cl-call-body">
  <!-- Script -->
  <div class="cl-script-wrap">
    <div class="cl-script-card" style="display:flex;flex-direction:column;height:100%">
      <div style="display:flex;align-items:center;gap:8px;padding:10px 14px 0;flex-shrink:0">
        <span style="font-size:10px;font-weight:700;color:var(--gray2);text-transform:uppercase;letter-spacing:.5px;flex:1">${script?e(script.name):'Intet script valgt'}</span>
        ${callScripts.length>1?`<select style="font-size:11px;border:1px solid var(--border);border-radius:5px;padding:3px 6px;background:#fff;color:var(--pdarker);cursor:pointer;outline:none" onchange="changeScript(this.value)">${callScripts.map(s=>`<option value="${s.id}"${s.id===activeScript?.id?' selected':''}>${e(s.name)}</option>`).join('')}</select>`:''}
        <button style="font-size:11px;font-weight:600;color:var(--p1);background:none;border:none;cursor:pointer;padding:2px 6px;border-radius:5px" onclick="openScriptEditor()">Rediger</button>
      </div>
      <textarea class="cl-script-ta" id="cl-script-ta" placeholder="Skriv dit script her… Brug [felter] til at markere ting du skal udfylde under opkaldet.">${script?e(script.text||''):''}</textarea>
    </div>
    <!-- AI live feedback placeholder -->
    <div id="cl-ai-wrap" style="display:none">
      <div class="cl-ai-card">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px">
          <div><div style="font-size:10px;font-weight:700;color:var(--gray2);text-transform:uppercase;margin-bottom:4px">AI Score</div><div class="cl-ai-score" id="cl-ai-score">—</div></div>
          <div style="flex:1"><div id="cl-ai-summary" style="font-size:12px;color:var(--gray);line-height:1.5"></div></div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
          <div><div style="font-size:10px;font-weight:700;color:#16a34a;margin-bottom:5px">Gik godt</div><ul class="cl-ai-list" id="cl-ai-strengths"></ul></div>
          <div><div style="font-size:10px;font-weight:700;color:#dc2626;margin-bottom:5px">Kan forbedres</div><ul class="cl-ai-list" id="cl-ai-improvements"></ul></div>
        </div>
        <div style="margin-top:8px;padding-top:8px;border-top:1px solid var(--border)">
          <span style="font-size:10px;font-weight:700;color:var(--gray2)">Næste skridt: </span>
          <span id="cl-ai-next" style="font-size:11px;color:var(--pdarker)"></span>
        </div>
      </div>
    </div>
  </div>
  <!-- Notes col -->
  <div class="cl-notes-col">
    <div class="cl-notes-card">
      <div class="cl-notes-lbl">Udfald</div>
      <select class="cl-outcome-sel" id="cl-outcome" onchange="updateOutcomeActions(this.value)">
        <option value="">Vælg udfald…</option>
        <option value="interested">Interesseret</option>
        <option value="booked">Møde booket</option>
        <option value="callback">Ring igen</option>
        <option value="not-interested">Ikke interesseret</option>
        <option value="no-answer">Ikke svar</option>
        <option value="voicemail">Besked efterladt</option>
      </select>
      <div id="cl-actions"></div>
    </div>
    <div class="cl-notes-card" id="cl-nxt-card">
      <div class="cl-notes-lbl">Næste handling</div>
      <div class="cl-nxt-types">
        <button class="cl-nxt-type active" onclick="setClNxtType(this,'call')">Opkald</button>
        <button class="cl-nxt-type" onclick="setClNxtType(this,'email')">Email</button>
        <button class="cl-nxt-type" onclick="setClNxtType(this,'meeting')">Møde</button>
        <button class="cl-nxt-type" onclick="setClNxtType(this,'followup')">Opfølgning</button>
      </div>
      <input type="hidden" id="cl-nxt-type" value="call">
      <input class="cl-nxt-inp" id="cl-nxt-title" placeholder="Hvad skal der ske?">
      <input type="date" class="cl-nxt-inp" id="cl-nxt-date" style="width:100%;box-sizing:border-box" value="${tomorrowStr()}">
      <input type="time" class="cl-nxt-inp" id="cl-nxt-time" style="width:100%;box-sizing:border-box">
      <div id="cl-nxt-feedback"></div>
    </div>
    <div class="cl-notes-card" style="flex:1">
      <div class="cl-notes-lbl">Notater</div>
      <textarea class="cl-notes-ta" id="cl-notes" rows="7" placeholder="Skriv noter under opkaldet…"></textarea>
    </div>
    <div class="cl-notes-card">
      <div class="cl-notes-lbl">Kontakt</div>
      <div style="font-size:12px;color:var(--pdarker);font-weight:600">${e(lead.name)}</div>
      ${ph?`<a href="tel:${ph}" style="font-size:11px;color:var(--p1);text-decoration:none;display:flex;align-items:center;gap:4px;margin-top:4px">${e(ph)}</a>`:'<div style="font-size:11px;color:var(--gray2);margin-top:4px">Ingen tlf.</div>'}
      ${em?`<a href="mailto:${em}" style="font-size:11px;color:var(--p1);text-decoration:none;display:flex;align-items:center;gap:4px;margin-top:3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${e(em)}</a>`:''}
    </div>
  </div>
</div>
<div class="cl-ctrl">
  ${ph?
    (twilioReady
      ? `<button class="cl-btn-call start" id="cl-call-start-btn" onclick="if(!twilioCall('${ph}')){}">Ring via Twilio: ${e(ph)}</button>`
      : `<a href="tel:${ph}" class="cl-btn-call start" id="cl-call-start-btn" onclick="startCallTimer()">Ring: ${e(ph)}</a>`)
    : `<button class="cl-btn-call start" id="cl-call-start-btn" onclick="startCallTimer()">Start opkald (log manuelt)</button>`}
  <button class="cl-btn-call end" id="cl-call-end-btn" onclick="${twilioReady?'twilioHangup();':''}endCallTimer()" style="display:none">Afslut</button>
  <button class="cl-btn-save" onclick="saveCall()">Gem opkald</button>
  ${autoDial?`<button class="cl-btn-save" onclick="nextAutoDial()" style="margin-left:auto">Næste →</button>`:''}
  <button class="cl-btn-save" onclick="analyseCall()" style="margin-left:auto;background:rgba(130,88,168,.08);border-color:var(--p3);color:var(--p1)">AI analyse</button>
</div>`;
}

function renderDemosTab(){
  const upcoming=demoLog.filter(d=>d.status==='scheduled').sort((a,b)=>(a.scheduledAt||'').localeCompare(b.scheduledAt||''));
  const past=demoLog.filter(d=>d.status!=='scheduled').sort((a,b)=>(b.scheduledAt||'').localeCompare(a.scheduledAt||''));
  const demos=[...upcoming,...past];
  return`
<div class="cl-demo-body">
  <!-- Demo list -->
  <div class="cl-demo-list">
    <div class="cl-queue-hd">Demos (${demoLog.length})</div>
    ${demos.length===0?`<div style="text-align:center;padding:20px;color:var(--gray2);font-size:12px">Ingen demos endnu.<br>Klik "+ Tilføj demo" øverst.</div>`:''}
    ${demos.map(d=>`
      <div class="cl-demo-item${selectedDemo?.id===d.id?' on':''}" onclick="selectDemo('${d.id}')">
        <div class="cl-demo-date">${d.scheduledAt?new Date(d.scheduledAt).toLocaleDateString('da-DK',{weekday:'short',day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'}):'Dato ikke sat'}</div>
        <div class="cl-demo-co">${e(d.companyName||'Ukendt')}</div>
        <div class="cl-demo-ct">${e(d.contactName||'')}</div>
        <span class="cl-demo-status cl-demo-s-${d.status||'scheduled'}">${{scheduled:'Planlagt',completed:'Gennemført',cancelled:'Annulleret'}[d.status]||d.status}</span>
      </div>`).join('')}
    <!-- Calendar sync notice -->
    <div style="padding:12px 14px;border-top:1px solid var(--border);margin-top:auto">
      <div style="font-size:10px;font-weight:700;color:var(--gray2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px">Google Kalender</div>
      <div style="font-size:11px;color:var(--gray);line-height:1.5;margin-bottom:8px">Synk dine demo-aftaler fra Google Kalender.</div>
      <button class="btn btn-sm" style="width:100%;font-size:11px" onclick="syncGoogleCalendar()">Synk kalender</button>
    </div>
  </div>
  <!-- Demo detail -->
  <div class="cl-demo-detail" id="cl-demo-detail">
    ${selectedDemo?renderDemoDetail(selectedDemo):renderDemoEmpty()}
  </div>
</div>`;
}

function renderDemoEmpty(){
  return`<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;color:var(--gray2);gap:10px">
    <div style="font-size:14px;color:var(--gray2)"></div>
    <div style="font-size:14px;font-weight:600;color:var(--gray)">Vælg en demo fra listen</div>
    <div style="font-size:12px">eller klik "+ Tilføj demo" for at oprette en ny</div>
  </div>`;
}

function renderDemoDetail(d){
  const pains=d.pains||[];
  const solutions=d.solutions||[];
  return`
<div class="cl-demo-section">
  <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:10px">
    <div>
      <div style="font-size:16px;font-weight:800;color:var(--pdarker)">${e(d.companyName||'Ukendt virksomhed')}</div>
      <div style="font-size:12px;color:var(--gray);margin-top:3px">${e(d.contactName||'')} ${d.contactTitle?'· '+e(d.contactTitle):''}</div>
      <div style="font-size:11px;color:var(--p1);margin-top:4px">${d.scheduledAt?new Date(d.scheduledAt).toLocaleString('da-DK',{weekday:'long',day:'2-digit',month:'long',hour:'2-digit',minute:'2-digit'}):'Dato ikke sat'}</div>
    </div>
    <div style="display:flex;flex-direction:column;gap:6px;align-items:flex-end">
      <span class="cl-demo-status cl-demo-s-${d.status||'scheduled'}" style="font-size:11px;padding:4px 10px">${{scheduled:'Planlagt',completed:'Gennemført',cancelled:'Annulleret'}[d.status]||d.status}</span>
      ${d.meetingUrl?`<a href="${d.meetingUrl}" target="_blank" class="cl-join-btn">▶ Join demo</a>`:'<span style="font-size:11px;color:var(--gray2)">Ingen møde-link</span>'}
    </div>
  </div>
</div>

<div class="cl-demo-section">
  <div class="cl-demo-sec-hd">Kundens smerter / udfordringer</div>
  <div id="demo-pains-wrap" style="margin-bottom:8px;display:flex;flex-wrap:wrap;gap:4px">
    ${pains.map((p,i)=>`<span class="cl-pain-tag">${e(p)}<button onclick="removeDemoPain(${i})" style="background:none;border:none;cursor:pointer;color:var(--gray);font-size:10px;padding:0 2px;margin-left:2px">✕</button></span>`).join('')}
  </div>
  <div style="display:flex;gap:6px">
    <input id="pain-input" class="modal-inp" placeholder="Tilføj smerte/udfordring…" style="flex:1" onkeydown="if(event.key==='Enter')addDemoPain()">
    <button class="btn btn-sm" onclick="addDemoPain()">+ Tilføj</button>
  </div>
</div>

<div class="cl-demo-section">
  <div class="cl-demo-sec-hd">Løsninger / value props</div>
  <div id="demo-solutions-wrap" style="margin-bottom:8px;display:flex;flex-wrap:wrap;gap:4px">
    ${solutions.map((s,i)=>`<span class="cl-pain-tag" style="background:#f0fdf4;border-color:#bbf7d0">${e(s)}<button onclick="removeDemoSolution(${i})" style="background:none;border:none;cursor:pointer;color:var(--gray);font-size:10px;padding:0 2px;margin-left:2px">✕</button></span>`).join('')}
  </div>
  <div style="display:flex;gap:6px">
    <input id="solution-input" class="modal-inp" placeholder="Tilføj løsning/value prop…" style="flex:1" onkeydown="if(event.key==='Enter')addDemoSolution()">
    <button class="btn btn-sm" onclick="addDemoSolution()">+ Tilføj</button>
  </div>
</div>

<div class="cl-demo-section">
  <div class="cl-demo-sec-hd">Notater</div>
  <textarea id="demo-notes" class="cl-notes-ta" rows="4" placeholder="Skriv mødenotater her…" style="width:100%;box-sizing:border-box">${e(d.notes||'')}</textarea>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:8px">
    <div>
      <div style="font-size:10px;font-weight:700;color:var(--gray2);margin-bottom:4px">Næste skridt</div>
      <input id="demo-nextstep" class="modal-inp" placeholder="Aftal opfølgning…" value="${e(d.nextStep||'')}">
    </div>
    <div>
      <div style="font-size:10px;font-weight:700;color:var(--gray2);margin-bottom:4px">Udfald</div>
      <select id="demo-outcome" class="cl-outcome-sel">
        <option value="">Vælg udfald…</option>
        <option value="won" ${d.outcome==='won'?'selected':''}>Vundet</option>
        <option value="followup" ${d.outcome==='followup'?'selected':''}>Opfølgning</option>
        <option value="no-show" ${d.outcome==='no-show'?'selected':''}>Mødte ikke op</option>
        <option value="lost" ${d.outcome==='lost'?'selected':''}>Tabt</option>
      </select>
    </div>
  </div>
</div>

<div style="display:flex;gap:10px;flex-wrap:wrap">
  <button class="btn btn-primary btn-sm" onclick="saveDemo()">Gem demo</button>
  <button class="btn btn-sm" onclick="analyseDemo()" style="background:rgba(130,88,168,.08);border-color:var(--p3);color:var(--p1)">AI analyse</button>
  <button class="btn btn-sm" onclick="updateDemoStatus('completed')" style="background:#dcfce7;border-color:#86efac;color:#16a34a">Marker gennemført</button>
  <button class="btn btn-sm" onclick="updateDemoStatus('cancelled')" style="color:#dc2626;border-color:#fca5a5;background:#fff1f2">Annuller</button>
</div>

<div id="demo-ai-wrap" style="display:none;margin-top:12px">
  <div class="cl-ai-card">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px">
      <div><div style="font-size:10px;font-weight:700;color:var(--gray2);text-transform:uppercase;margin-bottom:4px">AI Score</div><div class="cl-ai-score" id="demo-ai-score">—</div></div>
      <div style="flex:1"><div id="demo-ai-summary" style="font-size:12px;color:var(--gray);line-height:1.5"></div></div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
      <div><div style="font-size:10px;font-weight:700;color:#16a34a;margin-bottom:5px">Styrker</div><ul class="cl-ai-list" id="demo-ai-strengths"></ul></div>
      <div><div style="font-size:10px;font-weight:700;color:#dc2626;margin-bottom:5px">Forbedringer</div><ul class="cl-ai-list" id="demo-ai-improvements"></ul></div>
    </div>
    <div style="margin-top:8px;padding-top:8px;border-top:1px solid var(--border)">
      <span style="font-size:10px;font-weight:700;color:var(--gray2)">Næste skridt: </span>
      <span id="demo-ai-next" style="font-size:11px;color:var(--pdarker)"></span>
    </div>
  </div>
</div>`;
}

// ── Calls control functions ───────────────────────────────────────────────────
function setCallPane(pane){
  activeCallPane=pane;
  rCalls();
}

function selectQueueLead(cvr){
  const lead=leads.find(l=>l.cvr===cvr);
  if(!lead)return;
  // If already calling this lead, just show it
  if(!activeCall||activeCall.cvr!==cvr){
    if(callTimerInt){clearInterval(callTimerInt);callTimerInt=null;}
    callElapsed=0;
    activeCall={cvr,companyName:lead.name,phone:lead.ph,startTime:null,lead};
    activeScriptStep=0;
    _lastOutcome=null;
  }
  // Re-render dialer
  const inner=document.getElementById('cl-dialer-inner');
  if(inner) inner.innerHTML=renderDialerActive(lead);
}

function startCallTimer(){
  if(callTimerInt)return;
  activeCall.startTime=new Date().toISOString();
  const statusEl=document.getElementById('cl-status');
  if(statusEl){statusEl.className='cl-call-status live';statusEl.textContent='Live';}
  const startBtn=document.getElementById('cl-call-start-btn');
  const endBtn=document.getElementById('cl-call-end-btn');
  if(startBtn)startBtn.style.display='none';
  if(endBtn)endBtn.style.display='flex';
  callTimerInt=setInterval(()=>{
    callElapsed++;
    const t=document.getElementById('cl-timer');
    if(t)t.textContent=fmtDur(callElapsed);
  },1000);
}

function endCallTimer(){
  if(callTimerInt){clearInterval(callTimerInt);callTimerInt=null;}
  const statusEl=document.getElementById('cl-status');
  if(statusEl){statusEl.className='cl-call-status ended';statusEl.textContent='Afsluttet';}
  const startBtn=document.getElementById('cl-call-start-btn');
  const endBtn=document.getElementById('cl-call-end-btn');
  if(startBtn)startBtn.style.display='flex';
  if(endBtn)endBtn.style.display='none';
}

function initCallTimerDisplay(){
  if(activeCall&&callTimerInt){
    const t=document.getElementById('cl-timer');
    if(t)t.textContent=fmtDur(callElapsed);
    const statusEl=document.getElementById('cl-status');
    if(statusEl){statusEl.className='cl-call-status live';statusEl.textContent='Live';}
  }
}

function goStep(i){/* deprecated */}

function changeScript(id){
  activeScript=callScripts.find(s=>s.id===id)||callScripts[0];
  const ta=document.getElementById('cl-script-ta');
  if(ta&&activeScript){
    ta.value=activeScript.text||'';
    const lbl=ta.closest('.cl-script-card')?.querySelector('span');
    if(lbl)lbl.textContent=activeScript.name;
  }
}

// ── Outcome → contextual action buttons ──────────────────────────────────────
let _lastOutcome=null;
function setClNxtType(btn,type){
  document.querySelectorAll('.cl-nxt-type').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  const h=document.getElementById('cl-nxt-type');
  if(h)h.value=type;
}

function updateOutcomeActions(outcome){
  if(outcome===_lastOutcome)return;
  _lastOutcome=outcome;
  const wrap=document.getElementById('cl-actions');
  if(!wrap)return;
  const lead=activeCall?.lead;
  const cvr=activeCall?.cvr;
  const actions={
    interested:[
      {label:'Pipeline → Kvalificeret',color:'#2563eb',bg:'#eff6ff',fn:`callActionPipeline('Kvalificeret',event)`},
      {label:'Opret opgave',color:'#16a34a',bg:'#f0fdf4',fn:`callActionTask()`},
    ],
    booked:[
      {label:'Opret demo',color:'#7c3aed',bg:'#f5f3ff',fn:`callActionDemo()`},
      {label:'SDR → Møde booket',color:'#2563eb',bg:'#eff6ff',fn:`callActionPipeline('Møde booket',event)`},
    ],
    callback:[
      {label:'Ring igen om 2 dage',color:'#d97706',bg:'#fffbeb',fn:`callActionReminder(2,event)`},
      {label:'Ring igen om 5 dage',color:'#d97706',bg:'#fffbeb',fn:`callActionReminder(5,event)`},
    ],
    'not-interested':[
      {label:'Pipeline → Ikke interesseret',color:'#dc2626',bg:'#fef2f2',fn:`callActionPipeline('Ikke interesseret',event)`},
    ],
    'no-answer':[
      {label:'Ring igen i morgen',color:'#d97706',bg:'#fffbeb',fn:`callActionReminder(1,event)`},
    ],
    voicemail:[
      {label:'Ring igen om 2 dage',color:'#d97706',bg:'#fffbeb',fn:`callActionReminder(2,event)`},
      {label:'Send email opfølgning',color:'#0ea5e9',bg:'#f0f9ff',fn:`callActionEmail()`},
    ],
  };
  const list=actions[outcome]||[];
  if(!list.length){wrap.innerHTML='';return;}
  wrap.innerHTML=`<div style="margin-top:8px;padding-top:8px;border-top:1px solid var(--border)"><div style="font-size:10px;font-weight:700;color:var(--gray2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px">Hurtig handling</div>${list.map(a=>`<button class="cl-action-btn" style="background:${a.bg};color:${a.color}" onclick="${a.fn}">${a.label}</button>`).join('')}</div>`;
}

function callActionPipeline(stage,ev){
  if(!activeCall?.cvr)return;
  const cvr=activeCall.cvr;
  const role=(currentUser?.role||'').toLowerCase();
  const pane=role==='ae'?'ae':'sdr';
  setPipeline(cvr,stage,pane);
  showToast(`Pipeline → ${stage}`);
  const btn=ev?.target;
  if(btn){btn.style.opacity='.5';btn.disabled=true;btn.textContent='Opdateret';}
}

function callActionTask(){
  if(!activeCall?.lead)return;
  // Pre-fill add-task modal / show toast as placeholder
  showToast('Åbn opgave-modulet for at tilføje opgave for '+e(activeCall.companyName));
}

function callActionDemo(){
  if(!activeCall?.lead)return;
  // Pre-fill demo with company data from active call
  const lead=activeCall.lead;
  document.querySelector('[onclick="setCallPane(\'demos\')"]')?.click();
  setTimeout(()=>{
    const btn=document.querySelector('[onclick="openAddDemo()"]');
    if(btn)btn.click();
    // Pre-fill company name
    setTimeout(()=>{
      const inp=document.getElementById('new-demo-company');
      if(inp&&lead.name)inp.value=lead.name;
    },100);
  },150);
}

function callActionReminder(days,ev){
  const d=new Date();
  d.setDate(d.getDate()+days);
  const ds=d.toLocaleDateString('da-DK',{weekday:'short',day:'numeric',month:'short'});
  showToast(`Påmindelse sat til ${ds}`);
  const btn=ev?.target;
  if(btn){btn.style.opacity='.5';btn.disabled=true;btn.textContent=`Sat til ${ds}`;}
}

function callActionEmail(){
  if(!activeCall?.lead)return;
  const email=activeCall.lead.email;
  if(email){
    window.open(`mailto:${email}?subject=Opfølgning på vores samtale&body=Hej,\n\nTak for at jeg måtte lægge en besked. Jeg vil gerne følge op på vores tidligere kontakt.\n\nMed venlig hilsen`, '_blank');
  } else {
    showToast('Ingen email registreret på dette lead');
  }
}
// ─────────────────────────────────────────────────────────────────────────────

async function saveCall(){
  if(!activeCall)return;
  const outcome=document.getElementById('cl-outcome')?.value||'';
  const notes=document.getElementById('cl-notes')?.value||'';
  const call={
    cvr:activeCall.cvr,
    companyName:activeCall.companyName,
    phone:activeCall.phone,
    startTime:activeCall.startTime||new Date().toISOString(),
    duration:callElapsed,
    outcome,notes,
    scriptId:activeScript?.id
  };
  // Push to AE pipeline if meeting booked
  if(outcome==='booked'){
    await setPipeline(activeCall.cvr,'Møde booket','sdr');
  }
  try{
    const saved=await fetch('/api/calls',{method:'POST',headers:ah(),body:JSON.stringify(call)}).then(r=>r.json());
    callLog.unshift(saved);
  }catch(err){callLog.unshift({id:'call_'+Date.now(),...call,createdAt:new Date().toISOString()});}
  // Save next action if filled
  const nxtTitle=(document.getElementById('cl-nxt-title')?.value||'').trim();
  const nxtType=document.getElementById('cl-nxt-type')?.value||'call';
  const nxtDate=document.getElementById('cl-nxt-date')?.value||tomorrowStr();
  const nxtTime=document.getElementById('cl-nxt-time')?.value||'';
  if(nxtTitle&&activeCall?.cvr){
    const cvr=activeCall.cvr;
    if(!leadActivities[cvr])leadActivities[cvr]=[];
    leadActivities[cvr].push({
      id:Date.now().toString(36)+Math.random().toString(36).slice(2,5),
      type:nxtType, title:nxtTitle,
      date:nxtDate, time:nxtTime,
      done:false, createdAt:new Date().toISOString()
    });
    await save();
    updateTaskBadge();
    const fb=document.getElementById('cl-nxt-feedback');
    if(fb){fb.innerHTML='<div class="cl-nxt-saved">Handling oprettet</div>';}
  }
  // Reset
  if(callTimerInt){clearInterval(callTimerInt);callTimerInt=null;}
  callElapsed=0;
  activeCall=null;
  rCalls();
  if(autoDial) setTimeout(()=>nextAutoDial(),1500);
}

async function analyseCall(){
  if(!activeCall)return;
  const notes=document.getElementById('cl-notes')?.value||'';
  const outcome=document.getElementById('cl-outcome')?.value||'';
  const btn=document.querySelector('.cl-btn-save[onclick="analyseCall()"]');
  if(btn){btn.textContent='Analyserer…';btn.disabled=true;}
  try{
    const r=await fetch('/api/analyze',{method:'POST',headers:ah(),
      body:JSON.stringify({type:'call',notes,duration:callElapsed,outcome,companyName:activeCall.companyName})}).then(r=>r.json());
    showCallAIInline(r);
  }catch(err){}
  if(btn){btn.textContent='AI analyse';btn.disabled=false;}
}

function showCallAIInline(r){
  const wrap=document.getElementById('cl-ai-wrap');
  if(!wrap)return;
  wrap.style.display='block';
  const scoreEl=document.getElementById('cl-ai-score');
  if(scoreEl)scoreEl.textContent=r.score+'/10';
  const sumEl=document.getElementById('cl-ai-summary');
  if(sumEl)sumEl.textContent=r.summary||'';
  const strEl=document.getElementById('cl-ai-strengths');
  if(strEl)strEl.innerHTML=(r.strengths||[]).map(s=>`<li>✓ ${e(s)}</li>`).join('');
  const impEl=document.getElementById('cl-ai-improvements');
  if(impEl)impEl.innerHTML=(r.improvements||[]).map(s=>`<li>→ ${e(s)}</li>`).join('');
  const nextEl=document.getElementById('cl-ai-next');
  if(nextEl)nextEl.textContent=r.nextStep||'';
}

async function showCallAI(callId){
  const call=callLog.find(c=>c.id===callId);
  if(!call)return;
  if(call.aiAnalysis){alert('AI Analyse:\n\nScore: '+call.aiAnalysis.score+'/10\n\n'+call.aiAnalysis.summary+'\n\nNæste skridt: '+call.aiAnalysis.nextStep);return;}
  try{
    const r=await fetch('/api/analyze',{method:'POST',headers:ah(),
      body:JSON.stringify({type:'call',notes:call.notes||'',duration:call.duration,outcome:call.outcome,companyName:call.companyName})}).then(r=>r.json());
    call.aiAnalysis=r;
    await fetch('/api/calls/'+callId,{method:'PATCH',headers:ah(),body:JSON.stringify({aiAnalysis:r})}).catch(()=>{});
    alert('AI Analyse:\n\nScore: '+r.score+'/10\n\n'+r.summary+'\n\nGik godt:\n'+(r.strengths||[]).join('\n')+'\n\nKan forbedres:\n'+(r.improvements||[]).join('\n')+'\n\nNæste skridt: '+r.nextStep);
  }catch(e){}
}

// Auto-dial
function toggleAutoDial(){
  autoDial=!autoDial;
  if(autoDial){
    autoDialQueue=leads.filter(l=>l.ph);
    autoDialIdx=0;
    if(autoDialQueue.length>0) selectQueueLead(autoDialQueue[0].cvr);
  }
  rCalls();
}

function nextAutoDial(){
  autoDialIdx++;
  if(autoDialIdx>=autoDialQueue.length){
    autoDial=false;rCalls();return;
  }
  selectQueueLead(autoDialQueue[autoDialIdx].cvr);
  rCalls();
}

// ── Demos control functions ───────────────────────────────────────────────────
function selectDemo(id){
  selectedDemo=demoLog.find(d=>d.id===id)||null;
  const detail=document.getElementById('cl-demo-detail');
  if(detail)detail.innerHTML=selectedDemo?renderDemoDetail(selectedDemo):renderDemoEmpty();
  // Update active class
  document.querySelectorAll('.cl-demo-item').forEach(el=>el.classList.toggle('on',el.getAttribute('onclick')===`selectDemo('${id}')`));
}

async function saveDemo(){
  if(!selectedDemo)return;
  const notes=document.getElementById('demo-notes')?.value||'';
  const nextStep=document.getElementById('demo-nextstep')?.value||'';
  const outcome=document.getElementById('demo-outcome')?.value||'';
  const updates={notes,nextStep,outcome};
  selectedDemo={...selectedDemo,...updates};
  try{
    await fetch('/api/demos/'+selectedDemo.id,{method:'PATCH',headers:ah(),body:JSON.stringify(updates)});
    const idx=demoLog.findIndex(d=>d.id===selectedDemo.id);
    if(idx>=0)demoLog[idx]={...demoLog[idx],...updates};
  }catch(e){}
  // If outcome is won → push to AE pipeline
  if(outcome==='won'&&selectedDemo.cvr){
    await setPipeline(selectedDemo.cvr,'Vundet','ae');
  }
  showToast('Demo gemt');
}

async function analyseDemo(){
  if(!selectedDemo)return;
  const notes=document.getElementById('demo-notes')?.value||'';
  const pains=selectedDemo.pains||[];
  const solutions=selectedDemo.solutions||[];
  const btn=document.querySelector('[onclick="analyseDemo()"]');
  if(btn){btn.textContent='Analyserer…';btn.disabled=true;}
  try{
    const r=await fetch('/api/analyze',{method:'POST',headers:ah(),
      body:JSON.stringify({type:'demo',notes,pains,solutions,companyName:selectedDemo.companyName,contactName:selectedDemo.contactName})}).then(r=>r.json());
    const wrap=document.getElementById('demo-ai-wrap');
    if(wrap){
      wrap.style.display='block';
      document.getElementById('demo-ai-score').textContent=r.score+'/10';
      document.getElementById('demo-ai-summary').textContent=r.summary||'';
      document.getElementById('demo-ai-strengths').innerHTML=(r.strengths||[]).map(s=>`<li>✓ ${e(s)}</li>`).join('');
      document.getElementById('demo-ai-improvements').innerHTML=(r.improvements||[]).map(s=>`<li>→ ${e(s)}</li>`).join('');
      document.getElementById('demo-ai-next').textContent=r.nextStep||'';
    }
    // Save analysis
    selectedDemo.aiAnalysis=r;
    await fetch('/api/demos/'+selectedDemo.id,{method:'PATCH',headers:ah(),body:JSON.stringify({aiAnalysis:r})}).catch(()=>{});
  }catch(e){}
  if(btn){btn.textContent='AI analyse';btn.disabled=false;}
}

async function updateDemoStatus(status){
  if(!selectedDemo)return;
  selectedDemo.status=status;
  const idx=demoLog.findIndex(d=>d.id===selectedDemo.id);
  if(idx>=0)demoLog[idx].status=status;
  try{await fetch('/api/demos/'+selectedDemo.id,{method:'PATCH',headers:ah(),body:JSON.stringify({status})});}catch(e){}
  rCalls();
}

function addDemoPain(){
  const inp=document.getElementById('pain-input');
  if(!inp||!inp.value.trim())return;
  if(!selectedDemo)return;
  selectedDemo.pains=selectedDemo.pains||[];
  selectedDemo.pains.push(inp.value.trim());
  inp.value='';
  const wrap=document.getElementById('demo-pains-wrap');
  if(wrap)wrap.innerHTML=selectedDemo.pains.map((p,i)=>`<span class="cl-pain-tag">${e(p)}<button onclick="removeDemoPain(${i})" style="background:none;border:none;cursor:pointer;color:var(--gray);font-size:10px;padding:0 2px;margin-left:2px">✕</button></span>`).join('');
}
function removeDemoPain(i){
  if(!selectedDemo)return;
  selectedDemo.pains.splice(i,1);
  const wrap=document.getElementById('demo-pains-wrap');
  if(wrap)wrap.innerHTML=selectedDemo.pains.map((p,j)=>`<span class="cl-pain-tag">${e(p)}<button onclick="removeDemoPain(${j})" style="background:none;border:none;cursor:pointer;color:var(--gray);font-size:10px;padding:0 2px;margin-left:2px">✕</button></span>`).join('');
}
function addDemoSolution(){
  const inp=document.getElementById('solution-input');
  if(!inp||!inp.value.trim())return;
  if(!selectedDemo)return;
  selectedDemo.solutions=selectedDemo.solutions||[];
  selectedDemo.solutions.push(inp.value.trim());
  inp.value='';
  const wrap=document.getElementById('demo-solutions-wrap');
  if(wrap)wrap.innerHTML=selectedDemo.solutions.map((s,i)=>`<span class="cl-pain-tag" style="background:#f0fdf4;border-color:#bbf7d0">${e(s)}<button onclick="removeDemoSolution(${i})" style="background:none;border:none;cursor:pointer;color:var(--gray);font-size:10px;padding:0 2px;margin-left:2px">✕</button></span>`).join('');
}
function removeDemoSolution(i){
  if(!selectedDemo)return;
  selectedDemo.solutions.splice(i,1);
  const wrap=document.getElementById('demo-solutions-wrap');
  if(wrap)wrap.innerHTML=selectedDemo.solutions.map((s,j)=>`<span class="cl-pain-tag" style="background:#f0fdf4;border-color:#bbf7d0">${e(s)}<button onclick="removeDemoSolution(${j})" style="background:none;border:none;cursor:pointer;color:var(--gray);font-size:10px;padding:0 2px;margin-left:2px">✕</button></span>`).join('');
}

function openAddDemo(){
  const modal=document.createElement('div');
  modal.style.cssText='position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:1000;display:flex;align-items:center;justify-content:center';
  modal.innerHTML=`
  <div style="background:#fff;border-radius:12px;padding:24px;width:420px;max-width:95vw;box-shadow:0 20px 60px rgba(0,0,0,.3)">
    <div style="font-size:16px;font-weight:800;color:var(--pdarker);margin-bottom:16px">Tilføj demo</div>
    <div style="display:flex;flex-direction:column;gap:8px">
      <input id="add-demo-co" class="modal-inp" placeholder="Virksomhedsnavn *">
      <input id="add-demo-ct" class="modal-inp" placeholder="Kontaktperson">
      <input id="add-demo-cvr" class="modal-inp" placeholder="CVR-nummer">
      <input id="add-demo-url" class="modal-inp" placeholder="Møde-link (Google Meet / Zoom)">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        <div>
          <div style="font-size:10px;font-weight:700;color:var(--gray2);margin-bottom:4px">Dato & tid</div>
          <input id="add-demo-dt" type="datetime-local" class="modal-inp">
        </div>
        <div>
          <div style="font-size:10px;font-weight:700;color:var(--gray2);margin-bottom:4px">Varighed (min)</div>
          <input id="add-demo-dur" class="modal-inp" placeholder="30" type="number" value="30">
        </div>
      </div>
    </div>
    <div style="display:flex;gap:8px;margin-top:16px">
      <button class="btn btn-primary" style="flex:1" onclick="confirmAddDemo()">Opret demo</button>
      <button class="btn" onclick="this.closest('[style*=fixed]').remove()">Annuller</button>
    </div>
  </div>`;
  document.body.appendChild(modal);
}

async function confirmAddDemo(){
  const co=document.getElementById('add-demo-co')?.value.trim();
  if(!co){alert('Angiv venligst virksomhedsnavn');return;}
  const demo={
    companyName:co,
    contactName:document.getElementById('add-demo-ct')?.value.trim()||'',
    cvr:document.getElementById('add-demo-cvr')?.value.trim()||'',
    meetingUrl:document.getElementById('add-demo-url')?.value.trim()||'',
    scheduledAt:document.getElementById('add-demo-dt')?.value||null,
    duration:parseInt(document.getElementById('add-demo-dur')?.value)||30,
    status:'scheduled',pains:[],solutions:[]
  };
  try{
    const saved=await fetch('/api/demos',{method:'POST',headers:ah(),body:JSON.stringify(demo)}).then(r=>r.json());
    demoLog.unshift(saved);
    selectedDemo=saved;
  }catch(e){const id='demo_'+Date.now();demoLog.unshift({id,...demo,createdAt:new Date().toISOString()});selectedDemo=demoLog[0];}
  document.querySelector('[style*=fixed][style*=rgba]')?.remove();
  setCallPane('demos');
}

function openScriptEditor(){
  // Allow editing any script, not only activeScript
  const scripts=callScripts.length?callScripts:[{id:'__new__',name:'Nyt script',text:'',steps:[]}];
  const editSc=activeScript||scripts[0];
  const modal=document.createElement('div');
  modal.id='script-editor-modal';
  modal.style.cssText='position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:1000;display:flex;align-items:center;justify-content:center';
  const scriptTabs=scripts.map(s=>`<button onclick="scriptEditorSelect('${s.id}',this)" style="font-size:11px;font-weight:600;padding:4px 10px;border-radius:5px;border:1px solid var(--border);cursor:pointer;white-space:nowrap;${s.id===editSc.id?'background:var(--p1);color:#fff;border-color:var(--p1)':'background:#fff;color:var(--gray)'}">${e(s.name)}</button>`).join('');
  const bodyText=editSc.text||editSc.steps?.map(s=>s.text).join('\n\n---\n\n')||'';
  modal.innerHTML=`
  <div style="background:#fff;border-radius:12px;padding:24px;width:560px;max-width:95vw;max-height:90vh;display:flex;flex-direction:column;gap:14px;box-shadow:0 20px 60px rgba(0,0,0,.3)">
    <div style="font-size:16px;font-weight:800;color:var(--pdarker)">Rediger script</div>
    <div style="display:flex;gap:6px;flex-wrap:wrap">${scriptTabs}
      <button onclick="scriptEditorNew()" style="font-size:11px;font-weight:600;padding:4px 10px;border-radius:5px;border:1px dashed var(--p3);cursor:pointer;background:rgba(130,88,168,.06);color:var(--p1)">+ Nyt</button>
    </div>
    <div style="display:flex;gap:8px;align-items:center">
      <input id="script-name-edit" class="modal-inp" value="${e(editSc.name)}" placeholder="Script-navn" style="font-weight:600;flex:1">
      <input type="hidden" id="script-id-edit" value="${editSc.id}">
    </div>
    <textarea id="script-body-edit" style="width:100%;box-sizing:border-box;font-size:13px;font-family:inherit;line-height:1.7;border:1px solid var(--border);border-radius:8px;padding:12px;outline:none;resize:none;flex:1;min-height:220px;color:var(--pdarker)" placeholder="Skriv dit script her… Brug [felter] til at markere hvad du skal udfylde under opkaldet.&#10;&#10;Eksempel:&#10;Hej [navn], jeg ringer fra Vedio. Vi hjælper virksomheder som [firmanavn] med at…">${e(bodyText)}</textarea>
    <div style="display:flex;gap:8px">
      <button class="btn btn-primary" style="flex:1" onclick="saveScriptEdit()">Gem script</button>
      <button class="btn" onclick="document.getElementById('script-editor-modal').remove()">Annuller</button>
    </div>
  </div>`;
  document.body.appendChild(modal);
}

function scriptEditorSelect(id, btn){
  const sc=callScripts.find(s=>s.id===id);
  if(!sc)return;
  document.getElementById('script-name-edit').value=sc.name;
  document.getElementById('script-id-edit').value=sc.id;
  document.getElementById('script-body-edit').value=sc.text||sc.steps?.map(s=>s.text).join('\n\n---\n\n')||'';
  btn.closest('[style*=flex-wrap]').querySelectorAll('button').forEach(b=>{ b.style.background=b===btn?'var(--p1)':'#fff'; b.style.color=b===btn?'#fff':'var(--gray)'; b.style.borderColor=b===btn?'var(--p1)':'var(--border)'; });
}

function scriptEditorNew(){
  const name='Script '+(callScripts.length+1);
  document.getElementById('script-name-edit').value=name;
  document.getElementById('script-id-edit').value='__new__';
  document.getElementById('script-body-edit').value='';
}

function addScriptStep(){/* deprecated */}
function removeScriptStep(i){/* deprecated */}

async function saveScriptEdit(){
  const name=document.getElementById('script-name-edit')?.value.trim()||'Script';
  const id=document.getElementById('script-id-edit')?.value||'__new__';
  const text=document.getElementById('script-body-edit')?.value||'';
  const steps=[{title:'Script',text}]; // keep steps compat
  if(id==='__new__'){
    // create new
    try{
      const res=await fetch('/api/scripts',{method:'POST',headers:ah(),body:JSON.stringify({name,text,steps})});
      const sc=await res.json();
      callScripts.push(sc);
      activeScript=sc;
    }catch(err){}
  } else {
    const idx=callScripts.findIndex(s=>s.id===id);
    const updated={...(callScripts[idx]||{}),name,text,steps};
    if(idx>=0)callScripts[idx]=updated;
    if(activeScript?.id===id)activeScript=updated;
    try{await fetch('/api/scripts/'+id,{method:'PATCH',headers:ah(),body:JSON.stringify({name,text,steps})});}catch(err){}
  }
  document.getElementById('script-editor-modal')?.remove();
  rCalls();
}

async function syncGoogleCalendar(){
  alert('Google Kalender-integration kræver OAuth-opsætning.\n\nKonfigurer GOOGLE_CLIENT_ID og GOOGLE_CLIENT_SECRET i din .env-fil for at aktivere automatisk synkronisering.\n\nIndtil da kan du tilføje demos manuelt via "+ Tilføj demo".');
}

function showToast(msg,dur=2500){
  let t=document.getElementById('toast-msg');
  if(!t){t=document.createElement('div');t.id='toast-msg';t.style.cssText='position:fixed;bottom:24px;right:24px;background:var(--pdarker);color:#fff;padding:10px 18px;border-radius:8px;font-size:13px;font-weight:600;z-index:9999;transition:opacity .3s';document.body.appendChild(t);}
  t.textContent=msg;t.style.opacity='1';
  clearTimeout(t._t);t._t=setTimeout(()=>{t.style.opacity='0';},dur);
}

// ══════════════════════════════════════════════════════════════════════════════

// ── DEAL RISK DETECTION ───────────────────────────────────────────────────────
const RISK_STALE_DAYS={
  'Ny':5,'Kontaktet':7,'Kvalificeret':10,'Møde booket':3,
  'Demo Booket':3,'Tilbud sendt':5,'Forhandling':7,'Vundet':999,'Tabt':999,'Ikke interesseret':999
};
const RISK_SKIP=new Set(['Vundet','Tabt','Ikke interesseret']);

function computeDealRisk(cvr,lead,deal,acts,contacts){
  const today=todayStr();
  const sdrStage=(pipelines.sdr||{})[cvr]||'';
  const aeStage=(pipelines.ae||{})[cvr]||'';
  const stage=aeStage||sdrStage;
  if(!stage||RISK_SKIP.has(stage))return{level:'none',flags:[],stage,staleDays:0,hasNextStep:true};

  // 1. Next step: any non-done upcoming activity
  const upcoming=(acts||[]).filter(a=>!a.done&&a.date&&a.date>=today);
  const hasNextStep=upcoming.length>0;

  // 2. Stale: days since last completed activity (or since addedAt)
  const doneActs=(acts||[]).filter(a=>a.done&&a.date).sort((a,b)=>b.date.localeCompare(a.date));
  const lastDate=doneActs[0]?.date||lead?.addedAt?.slice(0,10)||today;
  const staleDays=Math.max(0,Math.floor((new Date(today)-new Date(lastDate))/86400000));
  const threshold=RISK_STALE_DAYS[stage]||7;
  const isStale=staleDays>threshold;

  // 3. Missing CRM data
  const ctacts=contacts||leadContacts[cvr]||[];
  const hasContact=!!(lead?.contactName||(leadContacts[cvr]||[]).find(c=>c.name));
  const hasPhone=!!(lead?.ph||(leadContacts[cvr]||[]).find(c=>c.phone));
  const hasDealValue=!!(deal?.mrr||deal?.arr);
  const hasPlan=!!deal?.plan;

  const flags=[];
  if(!hasNextStep)flags.push({type:'no_next_step',label:'Mangler næste skridt',detail:'Ingen planlagt opfølgning eller aktivitet',severity:'high',icon:''});
  if(isStale)flags.push({type:'stale',label:`Inaktiv i ${staleDays} dage`,detail:`Sidst aktivitet: ${lastDate} · Grænse for "${stage}": ${threshold} dage`,severity:'high',icon:'⏳'});
  if(!hasContact)flags.push({type:'missing_contact',label:'Ingen kontaktperson',detail:'Tilføj kontakt under Kontakter-fanen',severity:'medium',icon:''});
  if(!hasPhone)flags.push({type:'missing_phone',label:'Mangler telefonnummer',detail:'Nødvendigt for direkte outreach',severity:'medium',icon:''});
  if(!hasDealValue)flags.push({type:'missing_value',label:'Ingen deal-størrelse (MRR/ARR)',detail:'Angiv under Deal-fanen for pipeline-tracking',severity:'medium',icon:''});
  if(!hasPlan)flags.push({type:'missing_plan',label:'Ingen plan valgt',detail:'Vælg Vedio Core, Pro eller Enterprise',severity:'medium',icon:''});

  const level=flags.some(f=>f.severity==='high')?'high':flags.length>0?'medium':'low';
  return{level,flags,stage,staleDays,hasNextStep,lastDate,hasDealValue,hasPlan,hasContact,threshold};
}

async function analyzeDealRiskAI(cvr){
  const el=document.getElementById('risk-ai-'+cvr);
  if(!el)return;
  el.innerHTML=`<div style="display:flex;align-items:center;gap:8px;padding:10px;color:var(--gray);font-size:11.5px"><div class="spinner" style="width:13px;height:13px;border-width:2px;flex-shrink:0"></div>AI analyserer deal…</div>`;
  const lead=leads.find(l=>l.cvr===cvr)||res.find(l=>l.cvr===cvr)||{};
  const deal=leadDeal[cvr]||{};
  const acts=leadActivities[cvr]||[];
  const risk=computeDealRisk(cvr,lead,deal,acts);
  const contacts=leadContacts[cvr]||[];
  const contactName=contacts[0]?.name||lead.contactName||'';
  const missingData=risk.flags.filter(f=>f.type.startsWith('missing_')).map(f=>f.label);
  try{
    const r=await fetch('/api/deals/risk',{method:'POST',headers:ah(),body:JSON.stringify({
      cvr,companyName:lead.name,stage:risk.stage,staleDays:risk.staleDays,
      hasNextStep:risk.hasNextStep,missingData,contactName,mrr:deal.mrr,arr:deal.arr,plan:deal.plan
    })});
    const d=await r.json();
    el.innerHTML=`<div class="risk-ai-box">
      <div style="font-size:9.5px;font-weight:700;color:var(--p1);text-transform:uppercase;letter-spacing:.8px;margin-bottom:7px">AI-analyse</div>
      <div style="color:var(--pdarker);margin-bottom:${d.suggestions?.length?'9':'0'}px">${e(d.summary||'')}</div>
      ${d.suggestions?.length?`<div style="display:flex;flex-direction:column;gap:5px">${d.suggestions.map((s,i)=>`<div style="display:flex;gap:7px;align-items:flex-start"><span style="background:var(--p1);color:#fff;border-radius:50%;width:16px;height:16px;font-size:9px;font-weight:700;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px">${i+1}</span><span style="color:var(--gray)">${e(s)}</span></div>`).join('')}</div>`:''}
      ${d.nextStep?`<div style="margin-top:9px;padding:7px 10px;background:rgba(130,88,168,.09);border-radius:6px;font-size:11px;color:var(--pdarker)"><strong>Næste skridt:</strong> ${e(d.nextStep)}</div>`:''}
    </div>`;
  }catch(err){
    el.innerHTML=`<div style="color:var(--gray2);font-size:11.5px;padding:8px">AI-analyse ikke tilgængelig.</div>`;
  }
}

function renderRiskTab(cvr){
  const lead=leads.find(l=>l.cvr===cvr)||res.find(l=>l.cvr===cvr)||{};
  const deal=leadDeal[cvr]||{};
  const acts=leadActivities[cvr]||[];
  const risk=computeDealRisk(cvr,lead,deal,acts);
  const highFlags=risk.flags.filter(f=>f.severity==='high');
  const medFlags=risk.flags.filter(f=>f.severity==='medium');
  const bannerClass=risk.level==='high'?'risk-level-high':risk.level==='medium'?'risk-level-med':risk.level==='low'?'risk-level-low':'risk-level-none';
  const bannerTxt=risk.level==='high'?'<span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#ef4444;margin-right:4px"></span> Høj risiko — kræver øjeblikkelig handling':risk.level==='medium'?'<span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#eab308;margin-right:4px"></span> Advarsel — mangler data eller handling':risk.level==='low'?'<span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#22c55e;margin-right:4px"></span> Sund deal — god fremdrift':'Ikke i aktiv pipeline';
  const flagHtml=f=>`<div class="risk-flag risk-flag-${f.severity}">
    <span class="risk-flag-icon">${f.icon}</span>
    <div class="risk-flag-body"><div class="risk-flag-label">${f.label}</div><div class="risk-flag-detail">${f.detail}</div></div>
  </div>`;
  return `
    <div class="risk-level-banner ${bannerClass}">${bannerTxt}</div>
    ${risk.level==='none'?`<div style="text-align:center;padding:20px;color:var(--gray2);font-size:12px">Virksomheden er i ${risk.stage||'ingen'} pipeline-fase og overvåges ikke for risiko.</div>`:`
      ${highFlags.length?`<div style="font-size:10px;font-weight:700;color:var(--gray2);text-transform:uppercase;letter-spacing:.7px;margin-bottom:5px">Kritiske problemer</div>${highFlags.map(flagHtml).join('')}`:''}
      ${medFlags.length?`<div style="font-size:10px;font-weight:700;color:var(--gray2);text-transform:uppercase;letter-spacing:.7px;margin:${highFlags.length?'10px':0} 0 5px">Manglende data</div>${medFlags.map(flagHtml).join('')}`:''}
      ${!risk.flags.length?`<div class="risk-flag risk-flag-low"><span class="risk-flag-icon"></span><div class="risk-flag-body"><div class="risk-flag-label">Ingen problemer fundet</div><div class="risk-flag-detail">Deal har næste skridt, er aktiv og CRM-data er udfyldt</div></div></div>`:''}
      <div style="margin-top:12px">
        <button class="btn btn-primary btn-sm" style="width:100%;justify-content:center;gap:6px" onclick="analyzeDealRiskAI('${cvr}')">Analysér med AI</button>
      </div>
      <div id="risk-ai-${cvr}"></div>
    `}`;
}

function rDeals(){
  const def=PIPELINE_DEFS[activePane]||PIPELINE_DEFS.ae;
  const STAGES=def.stages;
  const SC=def.colors;
  const pipeMap=pipelines[activePane]||{};
  const role=(currentUser?.role||'').toLowerCase();
  const isAdmin=role==='admin';
  const totalVal=leads.reduce((a,c)=>a+(c.omsaetning||0),0);
  const ds=document.getElementById('deals-summary');
  if(ds)ds.textContent=`${leads.length} leads · ${fmtKr(totalVal)} samlet omsætning`;
  // Pipeline switcher: show to Admin or if they've been assigned a different pane
  const switcherHtml=(isAdmin||role==='')?`
    <div style="display:flex;gap:6px;padding:10px 14px 0">
      <button onclick="switchPane('sdr')" style="padding:4px 14px;border-radius:6px;border:1px solid var(--border);font-size:11px;font-weight:600;cursor:pointer;background:${activePane==='sdr'?'var(--p1)':'transparent'};color:${activePane==='sdr'?'#fff':'var(--gray)'};transition:.15s">SDR Pipeline</button>
      <button onclick="switchPane('ae')"  style="padding:4px 14px;border-radius:6px;border:1px solid var(--border);font-size:11px;font-weight:600;cursor:pointer;background:${activePane==='ae'?'var(--p1)':'transparent'};color:${activePane==='ae'?'#fff':'var(--gray)'};transition:.15s">AE Pipeline</button>
    </div>`:'';
  const boardHtml=STAGES.map(st=>{
    const col=SC[st]||{bg:'#f3f4f6',tc:'#374151'};
    const cards=leads.filter(c=>pipeMap[c.cvr]===st);
    const colVal=cards.reduce((a,c)=>a+(c.omsaetning||0),0);
    return `<div class="kb-col">
      <div class="kb-col-hd">
        <div class="kb-col-name"><span class="kb-col-dot" style="background:${col.tc}"></span>${st.toUpperCase()}</div>
        <span class="kb-cnt">${cards.length}</span>
      </div>
      <div class="kb-cards" ondragover="dragOver(event)" ondragleave="dragLeave(event)" ondrop="dropCard(event,'${st}')">
        ${cards.length?cards.map(c=>{
          const icp=getIcp(c);
          const primaryContact=(leadContacts[c.cvr]||[])[0];
          const contactName=primaryContact?.name||c.contactName||null;
          const risk=computeDealRisk(c.cvr,c,leadDeal[c.cvr],leadActivities[c.cvr]||[]);
          const riskDot=risk.level==='high'?'#ef4444':risk.level==='medium'?'#f59e0b':'#10b981';
          const riskFlags=risk.flags||[];
          const deal=leadDeal[c.cvr]||{};
          const plan=deal.plan||'';
          const acts=leadActivities[c.cvr]||[];
          const daysSince=c.addedAt?Math.round((new Date()-new Date(c.addedAt))/(1000*60*60*24)):0;
          return `<div class="kb-card${risk.level==='high'?' kb-card-risk-high':risk.level==='medium'?' kb-card-risk-med':''}" draggable="true"
              ondragstart="dragStart(event,'${c.cvr}')"
              ondragend="dragEnd(event)"
              onclick="openDealCard('${c.cvr}')">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:4px">
              <div class="kb-card-name" title="${e(c.name)}">${e(c.name)}</div>
              <span class="kb-col-dot" style="background:${riskDot};margin-top:4px"></span>
            </div>
            <div class="kb-card-sub">${e(c.ind||'')}</div>
            ${contactName?`<div style="font-size:12px;font-weight:600;color:var(--pdarker);margin:5px 0 3px">${e(contactName)}</div>`:''}
            ${c.ph||c.em?`<div style="display:flex;flex-direction:column;gap:3px;margin-bottom:4px">
              ${c.ph?`<a href="tel:${c.ph}" onclick="event.stopPropagation()" style="font-size:11px;color:var(--p1);text-decoration:none;display:flex;align-items:center;gap:5px;font-weight:500;transition:color .1s"><svg style="width:11px;height:11px;stroke:var(--p3);stroke-width:2;fill:none;flex-shrink:0" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>${c.ph}</a>`:''}
              ${c.em?`<a href="mailto:${c.em}" onclick="event.stopPropagation()" style="font-size:11px;color:var(--p1);text-decoration:none;display:flex;align-items:center;gap:5px;font-weight:500;overflow:hidden;white-space:nowrap;text-overflow:ellipsis"><svg style="width:11px;height:11px;stroke:var(--p3);stroke-width:2;fill:none;flex-shrink:0" viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>${trunc(c.em,24)}</a>`:''}
            </div>`:''}
            ${riskFlags.filter(f=>f.severity==='high').length?`<div class="kb-card-flags">${riskFlags.filter(f=>f.severity==='high').map(f=>`<div class="kb-card-flag">${e(f.label)}</div>`).join('')}</div>`:''}
            <div class="kb-card-badges">
              ${plan?`<span class="kb-card-plan">${e(plan)}</span>`:''}
              ${icp>=4?`<svg style="width:12px;height:12px;stroke:#f59e0b;stroke-width:2;fill:none;vertical-align:middle" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`:''}
            </div>
            <div class="kb-card-meta">
              <span style="display:inline-flex;align-items:center;gap:2px"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>${daysSince}d</span>
              <span style="display:inline-flex;align-items:center;gap:2px"><svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>${acts.length}</span>
            </div>
          </div>`;
        }).join(''):`<div class="kb-empty">Ingen deals i denne fase</div>`}
      </div>
    </div>`;
  }).join('');
  const board=document.getElementById('deals-board');
  if(board)board.innerHTML=switcherHtml+`<div class="kb-cols">${boardHtml}</div>`;
}

// ── TABLE ─────────────────────────────────────────────────────────────────────
function rTbl(){
  document.getElementById('thead').innerHTML=`<tr>
    <th style="width:28px"><input type="checkbox" class="cb" onchange="togAll(this)"></th>
    <th class="sort${sC==='name'?' sorted':''}" style="width:20%" onclick="setSort('name')">Virksomhed ${si('name')}</th>
    <th style="width:72px">CVR</th>
    <th class="sort${sC==='ind'?' sorted':''}" style="width:14%" onclick="setSort('ind')">Branche ${si('ind')}</th>
    <th class="sort${sC==='city'?' sorted':''}" style="width:9%" onclick="setSort('city')">By ${si('city')}</th>
    <th class="sort${sC==='emp'?' sorted':''}" style="width:42px" onclick="setSort('emp')">Ans. ${si('emp')}</th>
    <th class="sort${sC==='omsaetning'?' sorted':''}" style="width:78px" onclick="setSort('omsaetning')">Omsætning ${si('omsaetning')}</th>
    <th class="sort${sC==='eq'?' sorted':''}" style="width:78px" onclick="setSort('eq')">EK ${si('eq')}</th>
    <th class="sort${sC==='icp'?' sorted':''}" style="width:65px" onclick="setSort('icp')">ICP ${si('icp')}</th>
    <th style="width:80px">Pipeline</th>
    <th style="width:65px">Social</th>
    <th style="width:50px"></th>
  </tr>`;

  document.getElementById('tbody').innerHTML=res.map(c=>{
    const icp=getIcp(c);
    const ps=(pipelines.ae||{})[c.cvr]||(pipelines.sdr||{})[c.cvr]||'—';
    const hasSoc=!!(c.ig||c.fb||c.tt||c.li);
    const usesVideo=!!(c.ig||c.tt);
    const socBadge=hasSoc?`<span style="font-size:11px" title="${[c.ig?'IG':'',c.fb?'FB':'',c.tt?'TT':'',c.li?'LI':'',usesVideo?'Video':''].filter(Boolean).join(' ')}">${[c.ig?'IG':'',c.fb?'FB':'',c.tt?'TT':'',c.li?'LI':'',usesVideo?'V':''].filter(Boolean).join('')}</span>`:'<span style="color:#d1d5db;font-size:11px">—</span>';
    return`<tr data-cvr="${c.cvr}" class="${selCo?.cvr===c.cvr?'sel':''} ${ckd.has(c.cvr)?'chk':''}">
      <td onclick="event.stopPropagation()"><input type="checkbox" class="cb" ${ckd.has(c.cvr)?'checked':''} onchange="togCk('${c.cvr}',this.checked)"></td>
      <td><span class="co-name" title="${e(c.name)}">${trunc(e(c.name),22)}</span></td>
      <td style="font-family:monospace;font-size:11px;color:var(--gray2)">${c.cvr}</td>
      <td style="color:var(--gray);font-size:11.5px" title="${e(c.ind)}">${trunc(c.ind,18)}</td>
      <td style="color:var(--gray)">${c.city}</td>
      <td style="color:var(--gray)">${c.emps}</td>
      <td style="font-weight:600;font-size:11.5px;color:${c.omsaetning>0?'var(--pdarker)':'var(--gray2)'}">${fmtKr(c.omsaetning)}</td>
      <td style="font-weight:600;font-size:11.5px;color:${c.eq>500000?'#16a34a':c.eq<0?'#dc2626':'var(--gray)'}">${fmtKr(c.eq)}</td>
      <td style="font-size:12px;color:#d97706">${'★'.repeat(icp)+'☆'.repeat(5-icp)}</td>
      <td>${ps!=='—'?`<span class="stage-pill ${stageClass(ps)}">${ps}</span>`:'<span style="color:var(--gray2);font-size:11px">—</span>'}</td>
      <td>${socBadge}</td>
      <td onclick="event.stopPropagation()">
        <div style="display:flex;gap:3px;align-items:center">
          ${isL(c.cvr)?'<button class="ib added" title="I leads">✓</button>':`<button class="ib" onclick="qAdd('${c.cvr}')" title="Tilføj lead">+</button>`}
          <button class="ib" onclick="selC('${c.cvr}')" title="Detaljer">→</button>
        </div>
      </td>
    </tr>`;
  }).join('');

  document.getElementById('tbody').onclick=ev=>{
    const tr=ev.target.closest('tr[data-cvr]');
    if(tr&&!ev.target.closest('td:last-child')&&ev.target.tagName!=='INPUT')selC(tr.dataset.cvr);
  };
  rStb();upSel();
}

function rLeads(){
  const vis=aList==='all'?leads:leads.filter(l=>l.listId===aList);
  if(!vis.length){
    document.getElementById('thead').innerHTML='';
    document.getElementById('tbody').innerHTML=`<tr><td colspan="11" style="text-align:center;padding:60px;color:var(--gray2)">Ingen leads endnu — gå til Søg og tilføj virksomheder</td></tr>`;
    rStb();return;
  }
  document.getElementById('thead').innerHTML=`<tr>
    <th style="width:28px"><input type="checkbox" class="cb" onchange="togAll(this)"></th>
    <th style="width:22%">Virksomhed</th><th style="width:72px">CVR</th>
    <th style="width:15%">Branche</th><th style="width:8%">By</th>
    <th style="width:90px">Telefon</th><th style="width:80px">Pipeline</th>
    <th style="width:60px">ICP</th><th style="width:78px">Omsætning</th>
    <th style="width:75px">Tilføjet</th><th style="width:36px"></th>
  </tr>`;
  document.getElementById('tbody').innerHTML=vis.map(c=>{
    const icp=getIcp(c);
    const ps=(pipelines.ae||{})[c.cvr]||(pipelines.sdr||{})[c.cvr]||'—';
    return`<tr data-cvr="${c.cvr}" class="${selCo?.cvr===c.cvr?'sel':''} ${ckd.has(c.cvr)?'chk':''}">
      <td onclick="event.stopPropagation()"><input type="checkbox" class="cb" ${ckd.has(c.cvr)?'checked':''} onchange="togCk('${c.cvr}',this.checked)"></td>
      <td><span class="co-name">${trunc(e(c.name),22)}</span></td>
      <td style="font-family:monospace;font-size:11px;color:var(--gray2)">${c.cvr}</td>
      <td style="color:var(--gray);font-size:11.5px">${trunc(c.ind,18)||'—'}</td>
      <td style="color:var(--gray)">${c.city}</td>
      <td>${c.ph?`<a href="tel:${c.ph}" style="color:var(--blue);text-decoration:none;font-size:12px" onclick="event.stopPropagation()">${fp(c.ph)}</a>`:'<span style="color:var(--gray2)">—</span>'}</td>
      <td>${ps!=='—'?`<span class="stage-pill ${stageClass(ps)}">${ps}</span>`:'<span style="color:var(--gray2);font-size:11px">—</span>'}</td>
      <td style="font-size:11px;color:#d97706">${'★'.repeat(icp)+'☆'.repeat(5-icp)}</td>
      <td style="font-weight:600;font-size:11.5px">${fmtKr(c.omsaetning)}</td>
      <td style="color:var(--gray2);font-size:11px">${c.addedAt?new Date(c.addedAt).toLocaleDateString('da-DK'):'—'}</td>
      <td onclick="event.stopPropagation()"><button class="ib rm" onclick="remL('${c.cvr}')" title="Fjern">✕</button></td>
    </tr>`;
  }).join('');
  document.getElementById('tbody').onclick=ev=>{
    const tr=ev.target.closest('tr[data-cvr]');
    if(tr&&!ev.target.closest('td:last-child')&&ev.target.tagName!=='INPUT')selLD(tr.dataset.cvr);
  };
  rStb();upSel();
}

function stageClass(s){return{
  // Legacy stages
  'Ny':'s-new','Kvalificeret':'s-qual','I dialog':'s-dialog','Tilbud':'s-prop','Forhandling':'s-prop','Vundet':'s-won','Tabt':'s-lost',
  // SDR stages
  'Kontaktet':'s-dialog','Møde booket':'s-prop','Ikke interesseret':'s-lost',
  // AE stages
  'Demo Booket':'s-new','Tilbud sendt':'s-dialog'
}[s]||'s-new';}

function rStb(){
  const sb=document.getElementById('stbar');
  if(aView==='leads'){const vis=aList==='all'?leads:leads.filter(l=>l.listId===aList);sb.innerHTML=`<span class="hi">${vis.length}</span> leads`;return;}
  const hp=res.filter(r=>r.ph||r.phone).length,soc=res.filter(r=>r.ig||r.fb||r.tt||r.li).length,inL=res.filter(r=>isL(r.cvr)).length;
  const totalLabel=apiTotal>0&&apiTotal>res.length
    ?`<span class="hi">${res.length}</span> af <span class="hi">${apiTotal.toLocaleString('da-DK')}</span>`
    :`<span class="hi">${res.length}</span>`;
  const isFallback=apiProvider.includes('fallback');
  const providerLabel=isServerMode?`&nbsp;·&nbsp; <span style="font-size:10px;color:${isFallback?'#d97706':'var(--gray2)'};" title="${isFallback?'Datafordeler afventer godkendelse — søger via cvrapi.dk':''}">${apiProvider}</span>`:(isFallback?'':'');
  sb.innerHTML=`${totalLabel} virksomheder${providerLabel} &nbsp;·&nbsp; ${hp} har tlf. &nbsp;·&nbsp; <span style="color:var(--p1)">${soc} sociale profiler</span> &nbsp;·&nbsp; ${inL} i leads`;

  // Vis "Indlæs flere" knap hvis API har flere resultater
  const lmw=document.getElementById('load-more-wrap');
  const lmi=document.getElementById('load-more-info');
  if(lmw&&isServerMode&&apiTotal>res.length){
    lmw.style.display='block';
    if(lmi)lmi.textContent=`(${res.length} af ${apiTotal.toLocaleString('da-DK')} indlæst)`;
  }else if(lmw){lmw.style.display='none';}
}

// ── DETAIL PANEL ───────────────────────────────────────────────────────────────
function selC(cvr){const c=res.find(x=>x.cvr===cvr);if(!c)return;selCo=c;rTbl();showDp(c);}
function selLD(cvr){const c=leads.find(x=>x.cvr===cvr);if(!c)return;selCo=c;rLeads();showDp(c);}
function openDealCard(cvr){
  const c=leads.find(x=>x.cvr===cvr)||res.find(x=>x.cvr===cvr);
  if(!c)return;
  selCo=c;
  document.getElementById('dp-bd').style.display='block';
  showDp(c);
}
function hdDp(){
  document.getElementById('dp').classList.add('h');
  document.getElementById('dp-bd').style.display='none';
  selCo=null;
}

function showDp(c){
  const dp=document.getElementById('dp');dp.classList.remove('h');
  const inL=isL(c.cvr);
  const icp=getIcp(c);
  const ps=(pipelines.ae||{})[c.cvr]||(pipelines.sdr||{})[c.cvr]||'—';
  const notes=leadNotes[c.cvr]||'';
  const tags=(leadTags[c.cvr]||[]);
  const followup=leadFollowup[c.cvr]||'';
  const _pool=res.length>0?res:leads.length>0?leads:DEMO_DATA;
  const mxO=Math.max(..._pool.map(d=>d.omsaetning||0),1);
  const mxB=Math.max(..._pool.map(d=>Math.max(d.bf||0,0)),1);
  const mxE=Math.max(..._pool.map(d=>Math.max(d.eq||0,0)),1);

  // Enrichment status
  const enrichFields=[
    {label:'Telefon',has:!!c.ph},{label:'Email',has:!!c.em},{label:'Website',has:!!c.web},
    {label:'Instagram',has:!!c.ig},{label:'Facebook',has:!!c.fb},{label:'TikTok',has:!!c.tt},{label:'LinkedIn',has:!!c.li},
    {label:'Omsætning',has:c.omsaetning>0},{label:'Egenkapital',has:!!c.eq},
  ];
  const enrichPct=Math.round(enrichFields.filter(f=>f.has).length/enrichFields.length*100);

  dp.innerHTML=`
    <div class="dp-head">
      <div>
        <div class="dp-name">${e(c.name)}</div>
        <div class="dp-cvr">CVR ${c.cvr} · ${c.form}</div>
      </div>
      <span class="dp-close" onclick="hdDp()">×</span>
    </div>
    <div class="dp-tabs">
      <div class="dp-tab on" onclick="showTab('info')">Info</div>
      <div class="dp-tab" onclick="showTab('contacts')">Kontakter</div>
      <div class="dp-tab" onclick="showTab('deal')">Deal</div>
      <div class="dp-tab" onclick="showTab('sdr')">SDR/AE</div>
      <div class="dp-tab" onclick="showTab('akt')">Aktiviteter</div>
      <div class="dp-tab" onclick="showTab('hist')">Historik</div>
      <div class="dp-tab" onclick="showTab('social')">Social</div>
      <div class="dp-tab" onclick="showTab('enrich')">Enrich</div>
      <div class="dp-tab" onclick="showTab('finans')">Finans</div>
      <div class="dp-tab" id="risk-tab-btn-${c.cvr}" onclick="showTab('risk')" style="${(()=>{const r=computeDealRisk(c.cvr,c,leadDeal[c.cvr],leadActivities[c.cvr]||[]);return r.level==='high'?'color:#991b1b;font-weight:700':r.level==='medium'?'color:#854d0e;font-weight:600':''})()}">Risiko</div>
    </div>

    <!-- INFO TAB -->
    <div class="dp-body on" id="tab-info">
      <div class="dp-stat-grid">
        <div class="dp-stat"><div class="dp-stat-l">Stiftet</div><div class="dp-stat-v">${c.yr}</div></div>
        <div class="dp-stat"><div class="dp-stat-l">Ansatte</div><div class="dp-stat-v">${c.emps}</div></div>
        <div class="dp-stat"><div class="dp-stat-l">Alder</div><div class="dp-stat-v">${Math.floor(c.ageM/12)} år</div></div>
        <div class="dp-stat"><div class="dp-stat-l">Status</div><div class="dp-stat-v"><span class="pill ${c.st==='active'?'pill-active':'pill-inactive'}">${c.st==='active'?'Aktiv':'Inaktiv'}</span></div></div>
      </div>
      ${(c.contactName||c.contactTitle)?`<div style="background:var(--p7);border:1px solid var(--border);border-radius:8px;padding:9px 12px;margin-bottom:6px;display:flex;align-items:center;gap:10px">
        <div style="width:30px;height:30px;border-radius:50%;background:var(--p3);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;flex-shrink:0">${(c.contactName||'?')[0].toUpperCase()}</div>
        <div>
          <div style="font-size:12.5px;font-weight:700;color:var(--pdarker)">${e(c.contactName||'—')}</div>
          ${c.contactTitle?`<div style="font-size:10.5px;color:var(--gray)">${e(c.contactTitle)}</div>`:''}
        </div>
      </div>`:''}
      <div class="dp-row"><span class="dp-k">Adresse</span><span class="dp-v">${[c.addr,c.zip,c.city].filter(Boolean).join(', ')||'—'}</span></div>
      <div class="dp-row"><span class="dp-k">Branche</span><span class="dp-v">${c.ind||'—'}</span></div>
      <div class="dp-row"><span class="dp-k">Telefon</span><span class="dp-v">${c.ph?`<a href="tel:${c.ph}">${fp(c.ph)}</a>`:'<span style="color:var(--gray2);font-size:11px">Ikke udfyldt</span>'}</span></div>
      <div class="dp-row"><span class="dp-k">Email</span><span class="dp-v">${c.em?`<a href="mailto:${c.em}">${c.em}</a>`:'<span style="color:var(--gray2);font-size:11px">Ikke udfyldt</span>'}</span></div>
      <div class="dp-row"><span class="dp-k">Website</span><span class="dp-v">${c.web?`<a href="https://${c.web}" target="_blank">${c.web}</a>`:'<span style="color:var(--gray2);font-size:11px">Ikke udfyldt</span>'}</span></div>
      ${c.tech&&c.tech.length?`<div class="dp-row"><span class="dp-k">Teknologi</span><span class="dp-v" style="font-size:10.5px">${c.tech.join(', ')}</span></div>`:''}
      <div style="margin-top:10px;display:flex;flex-direction:column;gap:5px">
        ${inL?`
          <button class="btn btn-sm" style="width:100%;justify-content:center;gap:6px" onclick="openEditLead('${c.cvr}')">Rediger oplysninger</button>
          <button class="btn" style="width:100%;justify-content:center;color:var(--green);border-color:rgba(22,163,74,.3)" disabled>✓ Allerede i leads</button>
          <button class="btn btn-danger btn-sm" style="width:100%;justify-content:center" onclick="remL('${c.cvr}')">Fjern fra leads</button>`
          :`<button class="btn btn-primary" style="width:100%;justify-content:center" onclick="qAdd('${c.cvr}')">+ Tilføj til leads</button>`}
      </div>
      <a style="display:block;text-align:center;font-size:10.5px;color:var(--gray2);padding:7px;cursor:pointer" onclick="alert('Åbner Virk.dk i server-versionen')">Åbn på Virk.dk →</a>
    </div>

    <!-- FINANS TAB -->
    <div class="dp-body" id="tab-finans">
      <div style="margin-bottom:10px">
        <div class="fin-bar-row"><div class="fin-bar-lbl">Omsætning</div><div class="fin-bar-track"><div class="fin-bar-fill" style="width:${Math.round(c.omsaetning/mxO*100)}%;background:var(--blue)"></div></div><div class="fin-bar-val">${fmtKr(c.omsaetning)}</div></div>
        <div class="fin-bar-row"><div class="fin-bar-lbl">Bruttofort.</div><div class="fin-bar-track"><div class="fin-bar-fill" style="width:${c.bf>0?Math.round(c.bf/mxB*100):0}%;background:var(--p1)"></div></div><div class="fin-bar-val" style="color:${c.bf>=0?'var(--green)':'var(--red)'}">${fmtKr(c.bf)}</div></div>
        <div class="fin-bar-row"><div class="fin-bar-lbl">Egenkapital</div><div class="fin-bar-track"><div class="fin-bar-fill" style="width:${c.eq>0?Math.round(c.eq/mxE*100):0}%;background:var(--amber)"></div></div><div class="fin-bar-val" style="color:${c.eq>=0?'var(--amber)':'var(--red)'}">${fmtKr(c.eq)}</div></div>
      </div>
      <table class="fin-tbl">
        <tr><td>Omsætning</td><td>${fmtKr(c.omsaetning)}</td></tr>
        <tr><td>Bruttofortjeneste</td><td style="color:${c.bf>=0?'var(--green)':'var(--red)'}">${fmtKr(c.bf)}</td></tr>
        <tr><td>Resultat</td><td style="color:${c.res>=0?'var(--green)':'var(--red)'}">${fmtKr(c.res)}</td></tr>
        <tr><td>Egenkapital</td><td style="color:${c.eq>=0?'var(--amber)':'var(--red)'}">${fmtKr(c.eq)}</td></tr>
        <tr><td>Bruttomargin</td><td>${c.omsaetning>0?Math.round(c.bf/c.omsaetning*100)+'%':'—'}</td></tr>
      </table>
      <div style="font-size:10px;color:var(--gray2);margin-top:8px">Demo-data. Live finans kræver Erhvervsstyrelsens årsrapport-API.</div>
    </div>

    <!-- SDR/AE TAB -->
    <div class="dp-body" id="tab-sdr">
      <div class="dp-section">ICP-score</div>
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px">
        <div class="icp-bar" id="icp-bar-${c.cvr}">
          ${[1,2,3,4,5].map(n=>`<div class="icp-dot ${n<=icp?'filled':'empty'}" onclick="setIcp('${c.cvr}',${n})" title="${n} stjerner"></div>`).join('')}
        </div>
        <span style="font-size:12px;color:var(--amber);font-weight:600">${icp}/5 ★</span>
        ${icpScores[c.cvr]===undefined?'<span style="font-size:10px;color:var(--gray2);margin-left:4px">auto</span>':''}
      </div>

      ${(()=>{
        const sdrStage=pipelines.sdr[c.cvr]||'';
        const aeStage=pipelines.ae[c.cvr]||'';
        const _role=(currentUser?.role||'').toLowerCase();
        const showSdr=_role!=='ae';
        const showAe=_role!=='sdr';
        return `${showSdr?`<div class="dp-section" style="display:flex;align-items:center;gap:6px">SDR Pipeline</div>
        <select class="pipeline-select" onchange="setPipeline('${c.cvr}',this.value,'sdr')" style="margin-bottom:10px">
          <option value="">— Ikke i SDR pipeline —</option>
          ${PIPELINE_DEFS.sdr.stages.map(s=>`<option value="${s}" ${sdrStage===s?'selected':''}>${s}</option>`).join('')}
        </select>`:''}
        ${showAe?`<div class="dp-section" style="display:flex;align-items:center;gap:6px">AE Pipeline</div>
        <select class="pipeline-select" onchange="setPipeline('${c.cvr}',this.value,'ae')" style="margin-bottom:10px">
          <option value="">— Ikke i AE pipeline —</option>
          ${PIPELINE_DEFS.ae.stages.map(s=>`<option value="${s}" ${aeStage===s?'selected':''}>${s}</option>`).join('')}
        </select>`:''}`;
      })()}

      <div class="dp-section">Follow-up dato</div>
      <input type="date" value="${followup}" onchange="setFollowup('${c.cvr}',this.value)" style="width:100%;padding:5px 8px;border:1px solid var(--border2);border-radius:6px;font-size:12px;font-family:inherit;color:var(--pdarker);background:var(--p7);outline:none;margin-bottom:10px">

      <div class="dp-section">Tags</div>
      <div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:8px" id="tags-${c.cvr}">
        ${tags.map(t=>`<span class="tag" onclick="removeTag('${c.cvr}','${t}')">${t} ×</span>`).join('')}
        <input class="tag-input" placeholder="+ Tag" onkeydown="addTag(event,'${c.cvr}')">
      </div>

      <div class="dp-section">SDR-noter</div>
      <textarea class="notes-area" placeholder="Skriv noter om virksomheden, kontakter, samtaler…" onchange="setNote('${c.cvr}',this.value)">${notes}</textarea>

      <div class="dp-section" style="margin-top:10px">Email-skabeloner</div>
      <div class="template-btn" onclick="togTemplate('cold')">
        <span></span><span class="lbl">Cold outreach</span><span>▾</span>
      </div>
      <div class="template-preview" id="tpl-cold">
Emne: Spørgsmål til ${e(c.name)}

Hej [kontaktnavn],

Jeg fandt ${e(c.name)} og kan se I arbejder med ${c.ind.toLowerCase()}. Hos Vedio hjælper vi virksomheder med at skalere deres videoindhold uden ekstra ansatte.

Har I 20 min til en kort snak om hvad vi kan gøre for jer?

Mvh [dit navn]</div>
      <div class="template-btn" onclick="togTemplate('followup')">
        <span></span><span class="lbl">Follow-up</span><span>▾</span>
      </div>
      <div class="template-preview" id="tpl-followup">
Emne: Re: Vedio × ${e(c.name)}

Hej igen,

Jeg ville høre om I fik kigget nærmere på vores løsning. Er der spørgsmål jeg kan hjælpe med?

Mvh [dit navn]</div>

      <div style="margin-top:10px">
        <button class="btn btn-amber btn-sm" style="width:100%;justify-content:center" onclick="pushOne('${c.cvr}')">Push til n8n/Twenty</button>
      </div>
    </div>

    <!-- AKTIVITETER TAB -->
    <div class="dp-body" id="tab-akt">

      <!-- Permanent note -->
      <div class="dp-section" style="margin-top:0">Noter</div>
      <textarea class="notes-area" style="margin-bottom:14px" placeholder="Skriv løbende noter om virksomheden, kontakter og samtaler — opdateres automatisk…" onchange="setNote('${c.cvr}',this.value)">${notes}</textarea>

      <!-- Activity form -->
      <div class="act-form">
        <div class="dp-section" style="margin-top:0;margin-bottom:8px">Ny aktivitet</div>
        <div class="act-form-row">
          <select class="act-type-sel" id="act-type-${c.cvr}">
            <option value="call">Opkald</option>
            <option value="email">Email</option>
            <option value="followup">Opfølgning</option>
            <option value="meeting">Møde</option>
            <option value="task">Opgave</option>
          </select>
        </div>
        <div class="act-form-row">
          <input class="act-inp" type="text" id="act-title-${c.cvr}" placeholder="Beskriv aktiviteten…" onkeydown="if(event.key==='Enter')addActivity('${c.cvr}')">
        </div>
        <div class="act-form-row">
          <input class="act-inp act-dt" type="date" id="act-date-${c.cvr}" value="${todayStr()}">
          <input class="act-inp act-tm" type="time" id="act-time-${c.cvr}" value="09:00">
        </div>
        <button class="btn btn-primary btn-sm" onclick="addActivity('${c.cvr}')">+ Tilføj aktivitet</button>
      </div>

      <div class="dp-section">Aktiviteter (${(leadActivities[c.cvr]||[]).length})</div>
      <div id="acts-${c.cvr}" style="border:1px solid var(--border);border-radius:7px;overflow:hidden;background:var(--white)">
        ${renderActList(c.cvr)}
      </div>
    </div>

    <!-- SOCIAL TAB -->
    <div class="dp-body" id="tab-social">
      <div class="dp-section">Sociale profiler</div>
      <div class="social-links" style="margin-bottom:12px">
        ${c.ig?`<a class="soc-ico soc-ig" href="https://instagram.com/${c.ig}" target="_blank" title="Instagram: @${c.ig}"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.17.054 1.97.24 2.43.403a4.088 4.088 0 0 1 1.523.99 4.088 4.088 0 0 1 .99 1.524c.163.46.349 1.26.403 2.43.058 1.265.07 1.645.07 4.849s-.012 3.584-.07 4.85c-.054 1.17-.24 1.97-.403 2.43a4.088 4.088 0 0 1-.99 1.523 4.088 4.088 0 0 1-1.524.99c-.46.163-1.26.349-2.43.403-1.265.058-1.645.07-4.849.07s-3.584-.012-4.85-.07c-1.17-.054-1.97-.24-2.43-.403a4.088 4.088 0 0 1-1.523-.99 4.088 4.088 0 0 1-.99-1.524c-.163-.46-.349-1.26-.403-2.43C2.175 15.584 2.163 15.204 2.163 12s.012-3.584.07-4.85c.054-1.17.24-1.97.403-2.43a4.088 4.088 0 0 1 .99-1.523A4.088 4.088 0 0 1 5.15 2.636c.46-.163 1.26-.349 2.43-.403C8.845 2.175 9.225 2.163 12 2.163M12 0C8.741 0 8.333.014 7.053.072 5.775.131 4.902.333 4.14.63a5.882 5.882 0 0 0-2.126 1.384A5.882 5.882 0 0 0 .63 4.14C.333 4.902.131 5.775.072 7.053.014 8.333 0 8.741 0 12s.014 3.667.072 4.947c.059 1.278.261 2.15.558 2.913a5.882 5.882 0 0 0 1.384 2.126A5.882 5.882 0 0 0 4.14 23.37c.763.297 1.636.499 2.913.558C8.333 23.986 8.741 24 12 24s3.667-.014 4.947-.072c1.278-.059 2.15-.261 2.913-.558a5.882 5.882 0 0 0 2.126-1.384 5.882 5.882 0 0 0 1.384-2.126c.297-.763.499-1.636.558-2.913.058-1.28.072-1.688.072-4.947s-.014-3.667-.072-4.947c-.059-1.278-.261-2.15-.558-2.913a5.882 5.882 0 0 0-1.384-2.126A5.882 5.882 0 0 0 19.86.63c-.763-.297-1.636-.499-2.913-.558C15.667.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg></a>`:''}
        ${c.fb?`<a class="soc-ico soc-fb" href="https://facebook.com/${c.fb}" target="_blank" title="Facebook: ${c.fb}"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg></a>`:''}
        ${c.tt?`<a class="soc-ico soc-tt" href="https://tiktok.com/@${c.tt}" target="_blank" title="TikTok: @${c.tt}"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.88-2.88 2.89 2.89 0 0 1 2.88-2.88c.28 0 .56.04.82.11v-3.5a6.37 6.37 0 0 0-.82-.05A6.34 6.34 0 0 0 3.15 15.2a6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.34-6.34V8.75a8.18 8.18 0 0 0 4.76 1.52V6.81a4.83 4.83 0 0 1-1-.12z"/></svg></a>`:''}
        ${c.li?`<a class="soc-ico soc-li" href="https://linkedin.com/company/${c.li}" target="_blank" title="LinkedIn: ${c.li}"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></a>`:''}
        ${c.web?`<a class="soc-ico soc-web" href="https://${c.web}" target="_blank" title="${c.web}"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></a>`:''}
        <div class="soc-ico soc-add" onclick="alert('Tilføj sociale profiler i server-versionen via settings')">+</div>
      </div>
      ${c.ig?`<div class="dp-row"><span class="dp-k">Instagram</span><span class="dp-v"><a href="https://instagram.com/${c.ig}" target="_blank">@${c.ig}</a></span></div>`:'<div class="dp-row"><span class="dp-k">Instagram</span><span class="dp-v" style="color:var(--gray2)">Ikke fundet</span></div>'}
      ${c.fb?`<div class="dp-row"><span class="dp-k">Facebook</span><span class="dp-v"><a href="https://facebook.com/${c.fb}" target="_blank">${c.fb}</a></span></div>`:'<div class="dp-row"><span class="dp-k">Facebook</span><span class="dp-v" style="color:var(--gray2)">Ikke fundet</span></div>'}
      ${c.tt?`<div class="dp-row"><span class="dp-k">TikTok</span><span class="dp-v"><a href="https://tiktok.com/@${c.tt}" target="_blank">@${c.tt}</a></span></div>`:'<div class="dp-row"><span class="dp-k">TikTok</span><span class="dp-v" style="color:var(--gray2)">Ikke fundet</span></div>'}
      ${c.li?`<div class="dp-row"><span class="dp-k">LinkedIn</span><span class="dp-v"><a href="https://linkedin.com/company/${c.li}" target="_blank">${c.li}</a></span></div>`:'<div class="dp-row"><span class="dp-k">LinkedIn</span><span class="dp-v" style="color:var(--gray2)">Ikke fundet</span></div>'}
      <div style="margin-top:12px;padding:10px;background:var(--p7);border-radius:8px;border:1px solid var(--border);font-size:11px;color:var(--gray);line-height:1.5">
        <strong>Tip til SDR:</strong> Tjek virksomhedens sociale profiler for nylige opslag om vækst, rekruttering eller events — gode samtalestartere.${(c.ig||c.tt)?` <strong style="color:var(--p1)">Bruger sandsynligvis video</strong> (Instagram/TikTok-tilstedeværelse).`:' TikTok/Instagram-tilstedeværelse indikerer fokus på videoindhold.'}
      </div>
    </div>

    <!-- CONTACTS TAB -->
    <div class="dp-body" id="tab-contacts">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
        <div class="dp-section" style="margin:0">Decision makers & kontakter</div>
        <button class="btn btn-primary btn-sm" onclick="toggleContactForm('${c.cvr}')">＋ Tilføj</button>
      </div>
      <div id="contact-form-${c.cvr}" class="contact-form" style="display:none">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px">
          <input class="contact-inp" id="cf-name" placeholder="Navn *">
          <input class="contact-inp" id="cf-title" placeholder="Stilling / titel">
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px">
          <input class="contact-inp" id="cf-phone" placeholder="Telefon">
          <input class="contact-inp" id="cf-email" type="email" placeholder="Email">
        </div>
        <input class="contact-inp" id="cf-linkedin" placeholder="LinkedIn URL">
        <div style="display:flex;gap:6px;justify-content:flex-end">
          <button class="btn btn-sm" onclick="toggleContactForm('${c.cvr}')">Annuller</button>
          <button class="btn btn-primary btn-sm" onclick="saveContact('${c.cvr}')">Gem kontakt</button>
        </div>
      </div>
      <div id="contacts-list-${c.cvr}">
        ${(leadContacts[c.cvr]||[]).length===0
          ? `<div style="text-align:center;padding:24px 10px;color:var(--gray2);font-size:12px">Ingen kontakter endnu.<br>Tilføj beslutningstagere og nøglepersoner.</div>`
          : (leadContacts[c.cvr]||[]).map(ct=>`
            <div class="contact-card" id="cc-${ct.id}">
              <div class="contact-av" style="background:${ct.color||'var(--p3)'}">${(ct.name||'?').split(' ').map(n=>n[0]).join('').slice(0,2).toUpperCase()}</div>
              <div style="flex:1;min-width:0">
                <div style="font-size:12.5px;font-weight:700;color:var(--pdarker)">${e(ct.name||'')}</div>
                ${ct.title?`<div style="font-size:11px;color:var(--gray)">${e(ct.title)}</div>`:''}
                <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:4px">
                  ${ct.phone?`<a href="tel:${ct.phone}" style="font-size:11px;color:var(--p1);text-decoration:none">${e(ct.phone)}</a>`:''}
                  ${ct.email?`<a href="mailto:${ct.email}" style="font-size:11px;color:var(--p1);text-decoration:none">${e(ct.email)}</a>`:''}
                  ${ct.linkedin?`<a href="${ct.linkedin}" target="_blank" style="font-size:11px;color:var(--p1);text-decoration:none">in LinkedIn</a>`:''}
                </div>
              </div>
              <span class="contact-del" onclick="removeContact('${c.cvr}','${ct.id}')" title="Fjern">×</span>
            </div>`).join('')}
      </div>
    </div>

    <!-- DEAL TAB -->
    <div class="dp-body" id="tab-deal">
      <div class="dp-section">Deal-værdi</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        <div class="deal-field">
          <label>MRR (kr./md.)</label>
          <input type="number" class="deal-inp" id="deal-mrr-${c.cvr}" placeholder="0" value="${leadDeal[c.cvr]?.mrr||''}" onchange="saveDealField('${c.cvr}','mrr',+this.value||0)">
        </div>
        <div class="deal-field">
          <label>ARR (kr./år)</label>
          <input type="number" class="deal-inp" id="deal-arr-${c.cvr}" placeholder="Auto (MRR×12)" value="${leadDeal[c.cvr]?.arr||''}" onchange="saveDealField('${c.cvr}','arr',+this.value||0)">
        </div>
      </div>
      <div style="font-size:10px;color:var(--gray2);margin-bottom:14px">Stripe-integration planlagt — vil synkronisere MRR/ARR automatisk</div>

      <div class="dp-section">Plan</div>
      <div class="plan-row">
        ${['Vedio Core','Vedio Pro','Vedio Enterprise'].map(p=>`<button class="plan-btn${leadDeal[c.cvr]?.plan===p?' sel':''}" onclick="saveDealField('${c.cvr}','plan','${p}');document.querySelectorAll('.plan-btn').forEach(b=>b.classList.remove('sel'));this.classList.add('sel')">${p.replace('Vedio ','')}</button>`).join('')}
      </div>

      ${(pipelines.ae||{})[c.cvr]==='Vundet'?`
      <div class="dp-section">Abonnement</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        <div class="deal-field">
          <label>Startdato</label>
          <input type="date" class="deal-inp" value="${leadDeal[c.cvr]?.startDate||''}" onchange="saveDealField('${c.cvr}','startDate',this.value)">
        </div>
        <div class="deal-field">
          <label>Fornyelsesdato</label>
          <input type="date" class="deal-inp" value="${leadDeal[c.cvr]?.renewalDate||''}" onchange="saveDealField('${c.cvr}','renewalDate',this.value)">
        </div>
      </div>`:`
      <div style="background:var(--p7);border:1px solid var(--border);border-radius:8px;padding:12px 14px;color:var(--gray2);font-size:11.5px;text-align:center;margin-top:4px">
        Startdato og fornyelsesdato aktiveres når deal er markeret som <strong style="color:var(--green)">Vundet</strong>
      </div>`}
    </div>

    <!-- HISTORY TAB -->
    <div class="dp-body" id="tab-hist">
      <div style="display:flex;gap:6px;margin-bottom:14px">
        <input class="contact-inp" id="hist-inp-${c.cvr}" placeholder="Tilføj historiknotat…" style="flex:1;background:var(--p7)" onkeydown="if(event.key==='Enter')addManualHistory('${c.cvr}')">
        <button class="btn btn-primary btn-sm" onclick="addManualHistory('${c.cvr}')">Tilføj</button>
      </div>
      <div class="hist-list" id="hist-list-${c.cvr}">
        ${(leadHistory[c.cvr]||[]).length===0
          ? `<div style="text-align:center;padding:24px 10px;color:var(--gray2);font-size:12px">Ingen historik endnu.<br>Pipeline-ændringer logges automatisk.</div>`
          : [...(leadHistory[c.cvr]||[])].reverse().map(h=>`
            <div class="hist-item">
              <div class="hist-dot" style="background:${histDotColor(h.type)}"></div>
              <div class="hist-body">
                <div class="hist-text">${histIcon(h.type)} ${e(h.text)}</div>
                <div class="hist-meta">${h.createdAt?new Date(h.createdAt).toLocaleDateString('da-DK',{day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}):''} · ${e(h.user||'System')}</div>
              </div>
            </div>`).join('')}
      </div>
    </div>

    <!-- ENRICHMENT TAB -->
    <div class="dp-body" id="tab-enrich">
      <div class="dp-section">Enrichment status — ${enrichPct}% komplet</div>
      <div style="background:var(--gray3);height:6px;border-radius:3px;overflow:hidden;margin-bottom:10px">
        <div style="background:var(--p1);height:100%;width:${enrichPct}%;border-radius:3px;transition:width .4s"></div>
      </div>
      ${enrichFields.map(f=>`<div class="enrich-row">
        <span style="color:var(--pdarker)">${f.label}</span>
        <div style="display:flex;align-items:center;gap:5px">
          <div class="enrich-dot ${f.has?'e-ok':'e-no'}"></div>
          <span style="font-size:11px;color:${f.has?'var(--green)':'var(--gray2)'}">${f.has?'Fundet':'Mangler'}</span>
        </div>
      </div>`).join('')}
      <div style="margin-top:12px;display:flex;flex-direction:column;gap:5px">
        <button class="btn btn-primary btn-sm" style="justify-content:center" onclick="alert('Enrichment via Clearbit/Apollo API konfigureres under Social Media → Enrichment API')">Berig automatisk</button>
        <div style="font-size:10px;color:var(--gray2);text-align:center">Kræver Clearbit, Apollo eller Phantombuster API-nøgle</div>
      </div>
    </div>

    <!-- RISK TAB -->
    <div class="dp-body" id="tab-risk">
      ${renderRiskTab(c.cvr)}
    </div>`;
}

function showTab(id){
  document.querySelectorAll('.dp-tab').forEach((t,i)=>t.classList.toggle('on',['info','contacts','deal','sdr','akt','hist','social','enrich','finans','risk'][i]===id));
  document.querySelectorAll('.dp-body').forEach(b=>b.classList.remove('on'));
  document.getElementById('tab-'+id).classList.add('on');
}

function togTemplate(id){
  const el=document.getElementById('tpl-'+id);
  el.classList.toggle('open');
}

// ── SDR ACTIONS ───────────────────────────────────────────────────────────────
// ── AUTO ICP SCORING ──────────────────────────────────────────────────────────
// Rules (max 5 pts):
//  Niche    0-2 pt  → ejendom / marketing / reklame
//  Video    0-1 pt  → IG or TT present (+1), other social only (+0.5)
//  Size     0-1 pt  → 10-49 emp (+0.5), 50+ emp (+1)
//  Revenue  0-1 pt  → 5M+ DKK (+0.5), 20M+ DKK (+1)
function autoIcp(c){
  let s=0;
  const ind=(c.ind||'').toLowerCase();
  const ic=(c.ic||c.industryCode||'').toString();
  // Niche
  const isRealEstate=ic.startsWith('68')||ind.includes('ejendom')||ind.includes('mægler')||ind.includes('udlejning');
  const isMarketing=ic.startsWith('731')||ic.startsWith('732')||ic.startsWith('741')||ic.startsWith('742')||ic.startsWith('702')||
    ind.includes('reklame')||ind.includes('marketing')||ind.includes('kommunikation')||ind.includes('medie')||
    ind.includes('annonce')||ind.includes('pr ')||ind.includes('design')||ind.includes('branding')||ind.includes('kreativ');
  if(isRealEstate||isMarketing)s+=2;
  else if(ic.startsWith('70')||ind.includes('konsulent')||ind.includes('rådgivning')||ind.includes('management'))s+=1;
  // Video / Social
  if(c.ig||c.tt)s+=1; else if(c.fb||c.li)s+=0.5;
  // Size
  const emp=c.emp||0;
  if(emp>=50)s+=1; else if(emp>=10)s+=0.5;
  // Revenue
  const rev=c.omsaetning||0;
  if(rev>=20000000)s+=1; else if(rev>=5000000)s+=0.5;
  return Math.min(5,Math.round(s));
}
function getIcp(c){return icpScores[c.cvr]!==undefined?icpScores[c.cvr]:autoIcp(c);}

async function setIcp(cvr,score){
  icpScores[cvr]=score;await save();
  const bar=document.getElementById('icp-bar-'+cvr);
  if(bar)bar.querySelectorAll('.icp-dot').forEach((d,i)=>{d.classList.toggle('filled',i<score);d.classList.toggle('empty',i>=score);});
  if(aView==='search')rTbl();else rLeads();
}
async function setPipeline(cvr,stage,pane){
  if(!pane)pane=activePane;
  if(!pipelines[pane])pipelines[pane]={};
  const old=pipelines[pane][cvr]||'—';
  pipelines[pane][cvr]=stage;
  // Keep legacy pipeline in sync with AE
  if(pane==='ae')pipeline[cvr]=stage;
  // Auto-push: SDR "Møde booket" → AE "Demo Booket" (cross-user via server)
  if(pane==='sdr'&&stage==='Møde booket'){
    pipelines.ae[cvr]='Demo Booket';
    pipeline[cvr]='Demo Booket';
    addHistoryEntry(cvr,'stage','[AE] Auto-overført fra SDR: Demo Booket');
    if(isServerMode&&authToken){
      const company=leads.find(l=>l.cvr===cvr)||res.find(r=>r.cvr===cvr)||null;
      fetch('/api/pipeline-push',{method:'POST',headers:ah(),
        body:JSON.stringify({cvr,company,aeStage:'Demo Booket'})}).catch(()=>{});
    }
  }
  addHistoryEntry(cvr,'stage','['+pane.toUpperCase()+'] '+old+' → '+stage);
  await save();
  if(isServerMode&&authToken){
    try{await fetch('/api/meta/'+cvr,{method:'PATCH',headers:ah(),
      body:JSON.stringify({pipelines:{sdr:pipelines.sdr,ae:pipelines.ae}})});}catch(e){}
  }
  if(aView==='search')rTbl();else rLeads();
  if(aView==='deals')rDeals();
  if(selCo&&selCo.cvr===cvr)showDp(selCo);
}
async function setNote(cvr,note){leadNotes[cvr]=note;await save();}
async function setFollowup(cvr,date){leadFollowup[cvr]=date;await save();}
async function addTag(ev,cvr){
  if(ev.key==='Enter'){
    const v=ev.target.value.trim();if(!v)return;
    leadTags[cvr]=[...(leadTags[cvr]||[]).filter(t=>t!==v),v];
    await save();ev.target.value='';showDp(selCo);
  }
}
async function removeTag(cvr,tag){leadTags[cvr]=(leadTags[cvr]||[]).filter(t=>t!==tag);await save();showDp(selCo);}

// ── LEADS ─────────────────────────────────────────────────────────────────────
function isL(cvr){return leads.some(l=>l.cvr===cvr);}
async function qAdd(cvr){
  const c=[...res,...leads].find(x=>x.cvr===cvr);if(!c||isL(cvr))return;
  const lead={...c,listId:aList==='all'?'ungrouped':aList,addedAt:new Date().toISOString()};
  if(isServerMode){
    try{await fetch('/api/leads',{method:'POST',headers:ah(),body:JSON.stringify({company:lead,listId:lead.listId})});}catch(e){}
  }
  leads.push(lead);
  addHistoryEntry(cvr,'added','Lead tilføjet til pipeline');
  await save();rSB();render();if(selCo?.cvr===cvr)showDp(leads.find(l=>l.cvr===cvr)||c);
}
async function remL(cvr){
  if(isServerMode){try{await fetch(`/api/leads/${cvr}`,{method:'DELETE',headers:ah()});}catch(e){}}
  leads=leads.filter(l=>l.cvr!==cvr);await save();rSB();if(selCo?.cvr===cvr)hdDp();render();
}

function rSB(){
  // Pre-compute counts once
  const counts=new Map();
  counts.set('all',leads.length);
  lists.forEach(l=>{if(l.id!=='all')counts.set(l.id,leads.filter(x=>x.listId===l.id).length);});
  const isOn=id=>aList===id&&aView==='leads';

  document.getElementById('lc').innerHTML=lists.map(l=>`
    <div class="sb-li${isOn(l.id)?' on':''}" onclick="swList('${l.id}')">
      <span class="sb-li-nm">${e(l.name)}</span>
      <span class="sb-li-c">${counts.get(l.id)}</span>
      ${l.id!=='all'?`<span class="sb-li-del" onclick="event.stopPropagation();delList('${l.id}')">×</span>`:''}
    </div>`).join('');
  const llb=document.getElementById('llb-lists');
  if(llb)llb.innerHTML=lists.map(l=>`
    <div class="llb-list${isOn(l.id)?' on':''}" onclick="swList('${l.id}')">
      ${e(l.name)}
      <span class="llb-count">${counts.get(l.id)}</span>
      ${l.id!=='all'?`<span class="llb-del" onclick="event.stopPropagation();delList('${l.id}')">×</span>`:''}
    </div>`).join('');
}

function swList(id){aList=id;rSB();if(aView!=='leads')sv('leads');else render();}
function togNL(id='nli',disp='block'){
  const n=document.getElementById(id);n.style.display=n.style.display==='none'?disp:'none';
  if(n.style.display!=='none'){n.focus();n.onkeydown=ev=>{
    if(ev.key==='Enter'){const v=ev.target.value.trim();if(v){lists.push({id:'l'+Date.now(),name:v});save();rSB();}n.value='';n.style.display='none';}
    if(ev.key==='Escape'){n.value='';n.style.display='none';}
  };}
}
async function delList(id){
  if(!confirm('Slet listen?'))return;
  lists=lists.filter(l=>l.id!==id);leads=leads.map(l=>l.listId===id?{...l,listId:'ungrouped'}:l);
  if(aList===id)aList='all';await save();rSB();if(aView==='leads')render();
}

// ── BULK ──────────────────────────────────────────────────────────────────────
function togCk(cvr,on){if(on)ckd.add(cvr);else ckd.delete(cvr);upSel();}
function togAll(cb){
  const pool=aView==='leads'?(aList==='all'?leads:leads.filter(l=>l.listId===aList)):res;
  if(cb.checked)pool.forEach(c=>ckd.add(c.cvr));else ckd.clear();render();upSel();
}
function upSel(){
  const sb=document.getElementById('selbar');if(!ckd.size){sb.classList.add('h');return;}
  sb.classList.remove('h');
  sb.innerHTML=`<strong>${ckd.size}</strong> valgt &nbsp;
    <button class="btn btn-primary btn-sm" onclick="bulkAdd()">+ Tilføj som leads</button>
    ${aView==='leads'?'<button class="btn btn-danger btn-sm" onclick="bulkRem()">Fjern valgte</button>':''}
    <button class="btn btn-amber btn-sm" onclick="pushSel()">Push til integration</button>
    <button class="btn btn-sm" onclick="expSel()">⬇ CSV</button>
    <button class="btn btn-sm" style="margin-left:auto" onclick="ckd.clear();render();upSel()">× Fravælg</button>`;
}
function bulkAdd(){[...ckd].filter(c=>!isL(c)).forEach(c=>qAdd(c));ckd.clear();upSel();}
async function bulkRem(){for(const c of[...ckd])await remL(c);ckd.clear();upSel();}
function expSel(){const pool=aView==='leads'?leads:res;doCSV(pool.filter(c=>ckd.has(c.cvr)),'vedio_leads_valgte');}
async function addAll(){if(confirm(`Tilføj alle ${res.length}?`))for(const c of res)await qAdd(c.cvr);}

// ── INTEGRATIONS ───────────────────────────────────────────────────────────────
function openInt(){document.getElementById('int-modal').classList.remove('h');document.getElementById('n8n-url').value=nUrl;updIS();}
function closeInt(){document.getElementById('int-modal').classList.add('h');}
function setStatusBadge(id,text,ok){
  const el=document.getElementById(id);
  if(el){el.textContent=text;el.className='int-status '+(ok?'int-ok':'int-no');}
}
function updIS(){
  const ok=!!nUrl,txt=ok?'Konfigureret':'Ikke konfigureret';
  setStatusBadge('n8n-status',txt,ok);
  setStatusBadge('n8n-status-s',txt,ok);
}
async function saveN8n(){nUrl=document.getElementById('n8n-url').value.trim();await save();updIS();alert('n8n webhook gemt!');}
async function saveN8nS(){nUrl=document.getElementById('n8n-url-s').value.trim();await save();updIS();alert('n8n webhook gemt!');}
async function saveEnrichKeysS(){alert('Enrichment API-nøgler gemt — brug server-versionen til live enrichment.');}

// ── Twilio ────────────────────────────────────────────────────────────────────
let twilioDevice=null, twilioToken=null, twilioReady=false;
let _twilioStatusCache=null, _twilioStatusTs=0;

function applyTwilioStatus(d){
  const badge=document.getElementById('twilio-status-badge');
  const cap=document.getElementById('twilio-cap-label');
  if(!d.configured){
    setStatusBadge('twilio-status-badge','Ikke konfigureret',false);
    if(cap)cap.textContent='Tilføj TWILIO_* variabler til .env og genstart serveren.';
  }else if(!d.ready){
    setStatusBadge('twilio-status-badge','Delvist konfigureret',false);
    if(cap)cap.textContent='Mangler TWILIO_TWIML_APP_SID — opret en TwiML App i Twilio Console.';
  }else{
    setStatusBadge('twilio-status-badge','Aktiv ✓',true);
    if(cap)cap.textContent=`Klar til opkald via ${d.from||'Twilio'}`;
    if(!twilioReady) initTwilioDevice();
  }
}

async function checkTwilioStatus(){
  const now=Date.now();
  if(_twilioStatusCache&&now-_twilioStatusTs<5*60*1000){applyTwilioStatus(_twilioStatusCache);return;}
  try{
    const r=await fetch('/api/twilio/status',{headers:ah()});
    const d=await r.json();
    _twilioStatusCache=d; _twilioStatusTs=Date.now();
    applyTwilioStatus(d);
  }catch(err){
    setStatusBadge('twilio-status-badge','Fejl',false);
    const cap=document.getElementById('twilio-cap-label');
    if(cap)cap.textContent='Kunne ikke nå serveren.';
  }
}

async function initTwilioDevice(){
  if(twilioReady)return;
  try{
    const r=await fetch('/api/twilio/token',{headers:ah()});
    if(!r.ok)return;
    const d=await r.json();
    twilioToken=d.token;
    // Dynamically load Twilio Voice JS SDK if not already present
    if(!window.Twilio){
      await new Promise((res,rej)=>{
        const s=document.createElement('script');
        s.src='https://sdk.twilio.com/js/client/releases/1.14.0/twilio.min.js';
        s.onload=res; s.onerror=rej;
        document.head.appendChild(s);
      });
    }
    twilioDevice=new window.Twilio.Device(twilioToken,{codecPreferences:['opus','pcmu']});
    twilioDevice.on('ready',()=>{twilioReady=true;showToast('Twilio klar — ring direkte fra browseren');});
    twilioDevice.on('error',(e)=>{showToast('Twilio fejl: '+e.message);});
    twilioDevice.on('disconnect',()=>{endCallTimer();});
  }catch(err){
    console.warn('Twilio SDK ikke tilgængeligt:',err);
  }
}

// Called from the call button when Twilio is active
function twilioCall(number){
  if(!twilioReady||!twilioDevice){
    showToast('Twilio ikke klar — brug telefonlink eller konfigurér integration');
    return false;
  }
  const conn=twilioDevice.connect({To:number});
  conn.on('accept',()=>{ startCallTimer(); });
  showToast('Ringer via Twilio…');
  return true;
}

function twilioHangup(){
  if(twilioDevice)twilioDevice.disconnectAll();
}
// ─────────────────────────────────────────────────────────────────────────────

function buildPayload(arr){
  return{timestamp:new Date().toISOString(),source:'Vedio Leads',leads:arr.map(c=>({
    cvr:c.cvr,name:c.name,phone:c.ph,email:c.em,website:c.web,city:c.city,zip:c.zip,
    industry:c.ind,employees:c.emps,revenue:c.omsaetning,equity:c.eq,result:c.res,
    founded:c.yr,form:c.form,status:c.st,
    social:{instagram:c.ig,facebook:c.fb,tiktok:c.tt,linkedin:c.li},
    tech:c.tech||[],icpScore:getIcp(c),
    pipeline:(pipelines.ae||{})[c.cvr]||(pipelines.sdr||{})[c.cvr]||'—',
    sdrStage:(pipelines.sdr||{})[c.cvr]||null,aeStage:(pipelines.ae||{})[c.cvr]||null,
    notes:leadNotes[c.cvr]||'',tags:leadTags[c.cvr]||[],
    followup:leadFollowup[c.cvr]||null,addedAt:c.addedAt
  }))};
}
async function pushLeads(arr){
  if(!nUrl){alert('Ingen n8n webhook konfigureret — klik Integrationer');return;}
  const payload=buildPayload(arr);
  try{
    await fetch(nUrl,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
    alert(`${arr.length} leads sendt til n8n!`);
  }catch(err){
    alert('n8n (CORS blokerer fra browser-widget — brug server-versionen for live push): '+err.message);
  }
}
function pushSel(){const pool=aView==='leads'?leads:res;pushLeads(pool.filter(c=>ckd.has(c.cvr)));}
function pushOne(cvr){const c=[...res,...DEMO_DATA,...leads].find(x=>x.cvr===cvr);if(c)pushLeads([c]);}
function pushToN8n(){pushLeads(leads);}

// ── SOCIAL GUIDE ───────────────────────────────────────────────────────────────
function openSocialGuide(){document.getElementById('social-modal').classList.remove('h');}
function closeSocialGuide(){document.getElementById('social-modal').classList.add('h');}
async function saveEnrichKeys(){alert('Enrichment API-nøgler gemt — brug server-versionen til live enrichment.');}

// ── EXPORT ─────────────────────────────────────────────────────────────────────
function togSB(){sbOpen=!sbOpen;document.getElementById('sb').style.width=sbOpen?'280px':'0';}
function togFilterPop(){const p=document.getElementById('filter-popover'),o=document.getElementById('fp-overlay');const isOpen=p.classList.toggle('open');o.classList.toggle('open',isOpen);}
function doExport(){const vis=aList==='all'?leads:leads.filter(l=>l.listId===aList);if(!vis.length){alert('Ingen leads endnu');return;}doCSV(vis,'vedio_leads');}
function doCSV(data,fn){
  const f=[
    ['cvr','CVR'],['name','Navn'],['addr','Adresse'],['zip','Postnr'],['city','By'],
    ['ph','Telefon'],['em','Email'],['web','Website'],['ind','Branche'],['form','Form'],
    ['emps','Ansatte'],['st','Status'],['yr','Stiftet'],
    ['omsaetning','Omsætning'],['eq','Egenkapital'],['res','Resultat'],
    ['ig','Instagram'],['fb','Facebook'],['tt','TikTok'],['li','LinkedIn'],
    ['addedAt','Tilføjet']
  ];
  const getExtra=(c)=>[
    ['ICP-score',getIcp(c)],['SDR Pipeline',(pipelines.sdr||{})[c.cvr]||''],['AE Pipeline',(pipelines.ae||{})[c.cvr]||''],
    ['Note',leadNotes[c.cvr]||''],['Tags',(leadTags[c.cvr]||[]).join(', ')],
    ['Followup',leadFollowup[c.cvr]||'']
  ];
  const header=[...f.map(x=>x[1]),'ICP-score','Pipeline','Note','Tags','Followup'].map(x=>`"${x}"`).join(';');
  const rows=data.map(c=>[
    ...f.map(x=>`"${(c[x[0]]||'').toString().replace(/"/g,'""')}"`),
    ...getExtra(c).map(x=>`"${x[1].toString().replace(/"/g,'""')}"`)
  ].join(';'));
  const csv='\uFEFF'+[header,...rows].join('\n');
  const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv;charset=utf-8;'}));
  a.download=fn+'_'+new Date().toISOString().slice(0,10)+'.csv';a.click();
}

// ── UTILS ──────────────────────────────────────────────────────────────────────
function fmtKr(n){if(!n||n===0)return'—';const abs=Math.abs(n);const s=abs>=1000000?(Math.round(abs/100000)/10).toFixed(1)+'m':abs>=1000?Math.round(abs/1000)+'k':abs.toString();return(n<0?'-':'')+s;}
function fp(p){const d=(p||'').replace(/\D/g,'');return d.length===8?d.replace(/(\d{2})(\d{2})(\d{2})(\d{2})/,'$1 $2 $3 $4'):p||'';}
function e(s){return(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function trunc(s,n){return s&&s.length>n?s.slice(0,n)+'…':s||'';}
// ── CONTACTS ──────────────────────────────────────────────────────────────────
const CONTACT_COLORS=['#8258a8','#2563eb','#16a34a','#d97706','#0891b2','#7c3aed','#db2777','#dc2626'];
function toggleContactForm(cvr){
  const f=document.getElementById('contact-form-'+cvr);
  if(!f)return;
  const open=f.style.display!=='none';
  f.style.display=open?'none':'flex';
  if(!open){setTimeout(()=>{const n=document.getElementById('cf-name');if(n)n.focus();},50);}
}
async function saveContact(cvr){
  const name=(document.getElementById('cf-name')?.value||'').trim();
  if(!name){document.getElementById('cf-name')?.focus();return;}
  const ct={
    id:'c'+Date.now(),
    name,
    title:(document.getElementById('cf-title')?.value||'').trim(),
    phone:(document.getElementById('cf-phone')?.value||'').trim(),
    email:(document.getElementById('cf-email')?.value||'').trim(),
    linkedin:(document.getElementById('cf-linkedin')?.value||'').trim(),
    color:CONTACT_COLORS[Math.floor(Math.random()*CONTACT_COLORS.length)],
    createdAt:new Date().toISOString(),
  };
  leadContacts[cvr]=[...(leadContacts[cvr]||[]),ct];
  addHistoryEntry(cvr,'contact','Kontakt tilføjet: '+ct.name+(ct.title?' ('+ct.title+')':''));
  if(isServerMode){try{await fetch('/api/meta/'+cvr,{method:'PATCH',headers:ah(),body:JSON.stringify({contacts:leadContacts[cvr]})});}catch(e){}}
  await save();
  if(selCo&&selCo.cvr===cvr)showDp(selCo);
  showTab('contacts');
}
async function removeContact(cvr,id){
  const ct=(leadContacts[cvr]||[]).find(c=>c.id===id);
  leadContacts[cvr]=(leadContacts[cvr]||[]).filter(c=>c.id!==id);
  if(ct)addHistoryEntry(cvr,'contact','Kontakt fjernet: '+ct.name);
  if(isServerMode){try{await fetch('/api/meta/'+cvr,{method:'PATCH',headers:ah(),body:JSON.stringify({contacts:leadContacts[cvr]})});}catch(e){}}
  await save();
  if(selCo&&selCo.cvr===cvr)showDp(selCo);
  showTab('contacts');
}

// ── DEAL ──────────────────────────────────────────────────────────────────────
async function saveDealField(cvr,field,value){
  if(!leadDeal[cvr])leadDeal[cvr]={};
  const old=leadDeal[cvr][field];
  leadDeal[cvr][field]=value;
  // Auto-calc ARR from MRR if ARR not manually set
  if(field==='mrr'&&!leadDeal[cvr]._arrManual){
    leadDeal[cvr].arr=(value||0)*12;
    const arrEl=document.getElementById('deal-arr-'+cvr);
    if(arrEl)arrEl.value=leadDeal[cvr].arr||'';
  }
  if(field==='arr')leadDeal[cvr]._arrManual=true;
  // History entries for notable changes
  if(field==='plan'&&old!==value)addHistoryEntry(cvr,'deal','Plan: '+(old||'ingen')+' → '+value);
  if(field==='mrr'&&old!==value&&value>0)addHistoryEntry(cvr,'deal','MRR opdateret: '+fmtKr(value)+'/md.');
  if(field==='startDate'&&value)addHistoryEntry(cvr,'deal','Startdato sat: '+value);
  if(isServerMode){try{await fetch('/api/meta/'+cvr,{method:'PATCH',headers:ah(),body:JSON.stringify({deal:leadDeal[cvr]})});}catch(e){}}
  await save();
}

// ── HISTORY ───────────────────────────────────────────────────────────────────
function histDotColor(type){
  const m={stage:'var(--p1)',added:'var(--green)',note:'var(--amber)',deal:'var(--blue)',contact:'#7c3aed',manual:'var(--gray2)'};
  return m[type]||'var(--gray3)';
}
function histIcon(type){
  const m={stage:'~',added:'+',note:'N',deal:'$',contact:'C',manual:'M'};
  return m[type]||'•';
}
function addHistoryEntry(cvr,type,text){
  if(!leadHistory[cvr])leadHistory[cvr]=[];
  leadHistory[cvr].push({id:'h'+Date.now(),type,text,user:currentUser?currentUser.name:'System',createdAt:new Date().toISOString()});
  // fire-and-forget server sync
  if(isServerMode){fetch('/api/meta/'+cvr,{method:'PATCH',headers:ah(),body:JSON.stringify({history:leadHistory[cvr]})}).catch(()=>{});}
  save();
}
async function addManualHistory(cvr){
  const inp=document.getElementById('hist-inp-'+cvr);
  if(!inp)return;
  const text=inp.value.trim();
  if(!text)return;
  addHistoryEntry(cvr,'manual',text);
  inp.value='';
  if(selCo&&selCo.cvr===cvr)showDp(selCo);
  showTab('hist');
}

// ── PROFILE MODAL ─────────────────────────────────────────────────────────────
const PROFILE_COLORS=['#8258a8','#2563eb','#16a34a','#d97706','#dc2626','#0891b2','#7c3aed','#db2777','#059669','#ea580c'];
let profileAvatarData=null; // pending base64 or null-to-clear

function openProfileModal(){
  if(!currentUser)return;
  profileAvatarData=undefined; // undefined = no change pending
  // Populate fields
  document.getElementById('pf-name').value=currentUser.name||'';
  document.getElementById('pf-email').value=currentUser.email||'';
  document.getElementById('pf-pw-current').value='';
  document.getElementById('pf-pw-new').value='';
  document.getElementById('pf-pw-confirm').value='';
  document.getElementById('profile-pw-section').style.display='none';
  document.getElementById('pw-toggle-arrow').textContent='▶';
  // Hide message
  const msg=document.getElementById('profile-msg');
  msg.className='profile-msg';msg.textContent='';
  // Avatar preview
  const bigAv=document.getElementById('profile-avatar-big');
  applyAvatarToEl(bigAv,currentUser);
  bigAv.style.width='80px';bigAv.style.height='80px';bigAv.style.fontSize='28px';
  document.getElementById('profile-avatar-remove').style.display=currentUser.avatar?'block':'none';
  // Color swatches
  const cr=document.getElementById('profile-color-row');
  cr.innerHTML=PROFILE_COLORS.map(c=>`<div class="profile-color-swatch${(currentUser.color||'#8258a8')===c?' sel':''}" style="background:${c}" onclick="selectProfileColor('${c}')" title="${c}"></div>`).join('');
  // Show modal
  document.getElementById('profile-modal').style.display='flex';
  setTimeout(()=>document.getElementById('pf-name').focus(),60);
}

function closeProfileModal(){
  document.getElementById('profile-modal').style.display='none';
  profileAvatarData=undefined;
}

function togglePwSection(){
  const sec=document.getElementById('profile-pw-section');
  const arr=document.getElementById('pw-toggle-arrow');
  const open=sec.style.display!=='none';
  sec.style.display=open?'none':'flex';
  arr.textContent=open?'▶':'▼';
}

function selectProfileColor(c){
  document.querySelectorAll('.profile-color-swatch').forEach(s=>s.classList.remove('sel'));
  event.target.classList.add('sel');
}

function handleAvatarUpload(input){
  const file=input.files[0];
  if(!file)return;
  if(file.size>2*1024*1024){showProfileMsg('Billede må max være 2 MB','err');input.value='';return;}
  const reader=new FileReader();
  reader.onload=ev=>{
    profileAvatarData=ev.target.result; // base64
    const bigAv=document.getElementById('profile-avatar-big');
    bigAv.innerHTML='<img src="'+profileAvatarData+'" style="width:100%;height:100%;object-fit:cover;border-radius:50%;display:block">';
    bigAv.style.background='transparent';bigAv.style.fontSize='0';
    document.getElementById('profile-avatar-remove').style.display='block';
  };
  reader.readAsDataURL(file);
  input.value='';
}

function removeAvatar(){
  profileAvatarData=null; // null = explicitly remove
  const bigAv=document.getElementById('profile-avatar-big');
  const initials=(currentUser.name||'?').split(' ').map(n=>n[0]).join('').slice(0,2).toUpperCase();
  bigAv.innerHTML='';bigAv.textContent=initials;
  bigAv.style.background=currentUser.color||'var(--p1)';bigAv.style.fontSize='28px';
  document.getElementById('profile-avatar-remove').style.display='none';
}

function showProfileMsg(txt,type){
  const msg=document.getElementById('profile-msg');
  msg.textContent=txt;msg.className='profile-msg '+type;
  if(type==='ok')setTimeout(()=>{msg.className='profile-msg';msg.textContent='';},3000);
}

async function saveProfile(){
  if(!currentUser)return;
  const name=document.getElementById('pf-name').value.trim();
  const email=document.getElementById('pf-email').value.trim();
  const selSwatch=document.querySelector('.profile-color-swatch.sel');
  const color=selSwatch?selSwatch.style.background:currentUser.color;
  if(!name){showProfileMsg('Navn må ikke være tomt','err');return;}
  if(!email||!email.includes('@')){showProfileMsg('Ugyldig email','err');return;}
  const body={name,email,color};
  if(profileAvatarData!==undefined)body.avatar=profileAvatarData; // null clears, base64 sets
  try{
    const r=await fetch('/api/auth/profile',{method:'PATCH',headers:ah(),body:JSON.stringify(body)});
    const d=await r.json();
    if(!r.ok){showProfileMsg(d.error||'Kunne ikke gemme','err');return;}
    currentUser=Object.assign(currentUser,d);
    // Refresh sidebar
    applyAvatarToEl(document.getElementById('user-avatar'),currentUser);
    document.getElementById('user-name').textContent=currentUser.name;
    const rb=document.getElementById('user-role-badge');
    if(rb){rb.textContent=currentUser.role;rb.className='role-badge '+({SDR:'role-sdr',AE:'role-ae',Admin:'role-admin'}[currentUser.role]||'role-ae');}
    showProfileMsg('Profil gemt ✓','ok');
    setTimeout(closeProfileModal,1200);
  }catch(ex){showProfileMsg('Serverfejl','err');}
}

async function changePassword(){
  const cur=document.getElementById('pf-pw-current').value;
  const nw=document.getElementById('pf-pw-new').value;
  const cf=document.getElementById('pf-pw-confirm').value;
  if(!cur||!nw||!cf){showProfileMsg('Udfyld alle adgangskode-felter','err');return;}
  if(nw!==cf){showProfileMsg('De to nye adgangskoder matcher ikke','err');return;}
  if(nw.length<3){showProfileMsg('Ny adgangskode skal være mindst 3 tegn','err');return;}
  try{
    const r=await fetch('/api/auth/change-password',{method:'POST',headers:ah(),body:JSON.stringify({currentPassword:cur,newPassword:nw})});
    const d=await r.json();
    if(!r.ok){showProfileMsg(d.error||'Fejl ved skift af adgangskode','err');return;}
    document.getElementById('pf-pw-current').value='';
    document.getElementById('pf-pw-new').value='';
    document.getElementById('pf-pw-confirm').value='';
    showProfileMsg('Adgangskode ændret ✓','ok');
  }catch(ex){showProfileMsg('Serverfejl','err');}
}

// ── EDIT LEAD ─────────────────────────────────────────────────────────────────
let editLeadCvr=null;
function openEditLead(cvr){
  const c=leads.find(l=>l.cvr===cvr);if(!c)return;
  editLeadCvr=cvr;
  document.getElementById('edit-lead-title').textContent='Rediger: '+c.name;
  document.getElementById('ef-contactName').value=c.contactName||'';
  document.getElementById('ef-contactTitle').value=c.contactTitle||'';
  document.getElementById('ef-ph').value=c.ph||'';
  document.getElementById('ef-em').value=c.em||'';
  document.getElementById('ef-web').value=c.web||'';
  document.getElementById('ef-name').value=c.name||'';
  document.getElementById('ef-ind').value=c.ind||'';
  document.getElementById('ef-addr').value=c.addr||'';
  document.getElementById('ef-zip').value=c.zip||'';
  document.getElementById('ef-city').value=c.city||'';
  document.getElementById('ef-omsaetning').value=c.omsaetning||'';
  document.getElementById('ef-emps').value=c.emps||'';
  const modal=document.getElementById('edit-lead-modal');
  modal.style.display='flex';
  setTimeout(()=>document.getElementById('ef-contactName').focus(),50);
}
function closeEditLead(){
  document.getElementById('edit-lead-modal').style.display='none';
  editLeadCvr=null;
}
async function saveEditLead(){
  if(!editLeadCvr)return;
  const updates={
    name:(document.getElementById('ef-name').value.trim()||undefined),
    contactName:document.getElementById('ef-contactName').value.trim(),
    contactTitle:document.getElementById('ef-contactTitle').value.trim(),
    ph:document.getElementById('ef-ph').value.trim(),
    em:document.getElementById('ef-em').value.trim(),
    web:document.getElementById('ef-web').value.trim(),
    ind:document.getElementById('ef-ind').value.trim(),
    addr:document.getElementById('ef-addr').value.trim(),
    zip:document.getElementById('ef-zip').value.trim(),
    city:document.getElementById('ef-city').value.trim(),
    omsaetning:parseInt(document.getElementById('ef-omsaetning').value)||0,
    emps:parseInt(document.getElementById('ef-emps').value)||0,
  };
  if(!updates.name)delete updates.name;
  const lead=leads.find(l=>l.cvr===editLeadCvr);
  if(lead)Object.assign(lead,updates);
  if(isServerMode){
    try{await fetch('/api/leads/'+editLeadCvr,{method:'PATCH',headers:ah(),body:JSON.stringify(updates)});}catch(ex){}
  }
  await save();
  const btn=document.querySelector('#edit-lead-modal .btn-primary');
  if(btn){btn.textContent='✓ Gemt!';setTimeout(()=>{btn.textContent='Gem ændringer';},1200);}
  closeEditLead();
  const updated=leads.find(l=>l.cvr===editLeadCvr||l.cvr===(lead&&lead.cvr));
  const target=leads.find(l=>l.cvr===(lead?lead.cvr:editLeadCvr));
  if(selCo&&target&&selCo.cvr===target.cvr){selCo=target;showDp(target);}
  rLeads();render();
}

document.addEventListener('keydown',ev=>{if(ev.key==='Escape'){hdDp();closeInt();closeSocialGuide();closeDashDrawer();closeEditLead();closeProfileModal();ckd.clear();upSel();}});
document.querySelectorAll('[data-tip]').forEach(el=>{let t=null;el.addEventListener('mouseenter',()=>{t=document.createElement('div');t.className='data-tip-popup';t.textContent=el.dataset.tip;document.body.appendChild(t);const r=el.getBoundingClientRect();t.style.left=r.left+r.width/2-t.offsetWidth/2+'px';t.style.top=r.top-t.offsetHeight-6+'px';});el.addEventListener('mouseleave',()=>{if(t){t.remove();t=null;}});});
document.getElementById('int-modal').addEventListener('click',ev=>{if(ev.target.id==='int-modal')closeInt();});
document.getElementById('social-modal').addEventListener('click',ev=>{if(ev.target.id==='social-modal')closeSocialGuide();});
document.getElementById('edit-lead-modal').addEventListener('click',ev=>{if(ev.target.id==='edit-lead-modal')closeEditLead();});
document.getElementById('profile-modal').addEventListener('click',ev=>{if(ev.target.id==='profile-modal')closeProfileModal();});

// ── MAIL / GMAIL ──────────────────────────────────────────────────────────────
let mailStatus=null, activeMailFolder='in:inbox', activeMailId=null, mailNextPageToken=null;
let _gmailStatusCache=null, _gmailStatusTs=0;

async function checkGmailStatus(){
  const now=Date.now();
  if(_gmailStatusCache&&now-_gmailStatusTs<5*60*1000){applyGmailStatus(_gmailStatusCache);return;}
  try{
    // Load both config state and connection state in parallel
    const [cfgR, statusR] = await Promise.all([
      fetch('/api/mail/config',{headers:ah()}),
      fetch('/api/mail/status',{headers:ah()})
    ]);
    const cfg=await cfgR.json();
    const status=await statusR.json();
    const combined={...status, oauthConfigured: cfg.configured, redirectUri: cfg.redirectUri};
    _gmailStatusCache=combined; _gmailStatusTs=Date.now();
    applyGmailStatus(combined);
  }catch(err){
    setStatusBadge('gmail-status-badge','Fejl',false);
  }
}

function applyGmailStatus(d){
  mailStatus=d;
  const setupSection=document.getElementById('gmail-setup-section');
  const connectSection=document.getElementById('gmail-connect-section');
  const cap=document.getElementById('gmail-cap-label');
  const connectBtn=document.getElementById('gmail-connect-btn');
  const disconnectBtn=document.getElementById('gmail-disconnect-btn');
  const redirectDisplay=document.getElementById('gmail-redirect-uri-display');
  if(redirectDisplay&&d.redirectUri)redirectDisplay.textContent=d.redirectUri;

  if(!d.oauthConfigured){
    // Show credential input form
    setStatusBadge('gmail-status-badge','Opsætning krævet',false);
    if(setupSection)setupSection.style.display='';
    if(connectSection)connectSection.style.display='none';
  }else if(!d.connected){
    // Credentials saved, but user hasn't linked their Google account yet
    setStatusBadge('gmail-status-badge','Ikke forbundet',false);
    if(setupSection)setupSection.style.display='none';
    if(connectSection)connectSection.style.display='';
    if(cap)cap.textContent='';
    if(connectBtn)connectBtn.style.display='';
    if(disconnectBtn)disconnectBtn.style.display='none';
  }else{
    // Fully connected
    setStatusBadge('gmail-status-badge','Forbundet ✓',true);
    if(setupSection)setupSection.style.display='none';
    if(connectSection)connectSection.style.display='';
    if(cap)cap.textContent=d.email||'';
    if(connectBtn)connectBtn.style.display='none';
    if(disconnectBtn)disconnectBtn.style.display='';
  }
}

async function saveGmailConfig(){
  const clientId=document.getElementById('gmail-client-id-input')?.value.trim();
  const clientSecret=document.getElementById('gmail-client-secret-input')?.value.trim();
  if(!clientId||!clientSecret){showToast('Udfyld både Client ID og Client Secret');return;}
  const btn=document.querySelector('#gmail-setup-section .btn-primary');
  if(btn){btn.textContent='Gemmer…';btn.disabled=true;}
  try{
    const r=await fetch('/api/mail/config',{method:'POST',headers:{...ah(),'Content-Type':'application/json'},body:JSON.stringify({clientId,clientSecret})});
    const d=await r.json();
    if(d.error)throw new Error(d.error);
    _gmailStatusCache=null;
    showToast('Nøgler gemt! Klik nu "Forbind med Google"');
    checkGmailStatus();
  }catch(err){
    showToast('Fejl: '+err.message);
  }finally{
    if(btn){btn.textContent='Gem og fortsæt →';btn.disabled=false;}
  }
}

function resetGmailConfig(){
  if(!confirm('Fjern gemte OAuth-nøgler og start forfra?'))return;
  fetch('/api/mail/config',{method:'DELETE',headers:ah()}).then(()=>{
    _gmailStatusCache=null;
    checkGmailStatus();
  });
}

async function connectGmail(){
  const r=await fetch('/api/mail/auth-url',{headers:ah()});
  const d=await r.json();
  if(d.url)window.location.href=d.url;
  else showToast('Kan ikke hente OAuth URL — tjek at nøglerne er gemt korrekt.');
}

async function disconnectGmail(){
  if(!confirm('Afbryd Gmail-forbindelsen? Dine OAuth-nøgler forbliver gemt.'))return;
  await fetch('/api/mail/disconnect',{method:'DELETE',headers:ah()});
  _gmailStatusCache=null;
  checkGmailStatus();
  showToast('Gmail-konto afbrudt');
}

// ── Main mail render ──
async function rMail(){
  const panel=document.getElementById('mail-panel');
  if(!panel)return;
  // Check if just redirected after OAuth
  const urlParams=new URLSearchParams(window.location.search);
  if(urlParams.get('gmailConnected')){
    history.replaceState({},'',window.location.pathname);
    _gmailStatusCache=null;
  }
  try{
    const r=await fetch('/api/mail/status',{headers:ah()});
    mailStatus=await r.json();
  }catch(e){ mailStatus={configured:false,connected:false}; }

  if(!mailStatus.configured||!mailStatus.connected){
    panel.innerHTML=`
    <div style="flex:1;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:16px;padding:40px">
      <div style="font-size:14px;color:var(--gray2)"></div>
      <div style="font-size:18px;font-weight:800;color:var(--pdarker)">Gmail ikke forbundet</div>
      <div style="font-size:13px;color:var(--gray);text-align:center;max-width:360px;line-height:1.6">
        ${!mailStatus.configured
          ?'Tilføj <code style="background:var(--p7);padding:1px 5px;border-radius:3px">GOOGLE_CLIENT_ID</code>, <code style="background:var(--p7);padding:1px 5px;border-radius:3px">GOOGLE_CLIENT_SECRET</code> og <code style="background:var(--p7);padding:1px 5px;border-radius:3px">GOOGLE_REDIRECT_URI</code> til din <code>.env</code> fil og genstart serveren.'
          :'Klik nedenfor for at forbinde din Gmail-konto.'}
      </div>
      ${mailStatus.configured?`<button class="btn btn-primary" onclick="connectGmail()" style="padding:10px 24px;font-size:13px">Forbind Gmail</button>`:''}
      <button class="btn btn-sm" onclick="sv('settings')" style="font-size:12px;color:var(--gray)">Gå til Indstillinger →</button>
    </div>`;
    return;
  }
  renderMailLayout();
  loadMailMessages(activeMailFolder);
}

function renderMailLayout(){
  const panel=document.getElementById('mail-panel');
  panel.innerHTML=`
  <div class="mail-wrap">
    <!-- Folders sidebar -->
    <div class="mail-folders">
      <button class="mail-compose-btn" onclick="showCompose({})">Skriv ny</button>
      ${[
        {q:'in:inbox',label:'Indbakke',ico:''},
        {q:'in:sent',label:'Sendt',ico:''},
        {q:'in:drafts',label:'Kladder',ico:''},
        {q:'is:starred',label:'Stjernemarkeret',ico:''},
        {q:'in:trash',label:'Papirkurv',ico:''},
      ].map(f=>`<button class="mail-folder-btn${activeMailFolder===f.q?' active':''}" onclick="switchMailFolder('${f.q}')">${f.ico} ${f.label}</button>`).join('')}
      <div style="margin-top:8px;padding-top:8px;border-top:1px solid var(--border)">
        <input id="mail-search-input" placeholder="Søg…" style="width:100%;box-sizing:border-box;padding:6px 8px;border:1px solid var(--border);border-radius:7px;font-size:11px;outline:none;background:#fff" onkeydown="if(event.key==='Enter')switchMailFolder('q:'+this.value.trim())">
      </div>
    </div>
    <!-- Message list -->
    <div class="mail-list" id="mail-list-col">
      <div class="mail-list-hd">
        <span id="mail-folder-label">Indbakke</span>
        <span id="mail-list-loading" style="margin-left:auto;font-size:10px;color:var(--gray)"></span>
      </div>
      <div id="mail-list-body" style="flex:1;overflow-y:auto"></div>
      <div class="mail-load-more" id="mail-load-more" style="display:none">
        <button class="btn btn-sm" onclick="loadMoreMail()">Indlæs mere…</button>
      </div>
    </div>
    <!-- Reading pane -->
    <div class="mail-reading" id="mail-reading-col">
      <div class="mail-empty">
        <div style="font-size:14px;color:var(--gray2)"></div>
        <div style="font-size:13px;font-weight:600;color:var(--gray)">Vælg en mail for at læse den</div>
      </div>
    </div>
  </div>`;
}

async function loadMailMessages(folder,append=false){
  activeMailFolder=folder;
  const listBody=document.getElementById('mail-list-body');
  const loading=document.getElementById('mail-list-loading');
  const folderLabel=document.getElementById('mail-folder-label');
  const loadMore=document.getElementById('mail-load-more');
  if(!listBody)return;
  if(!append){ listBody.innerHTML='<div style="padding:20px;text-align:center;font-size:11px;color:var(--gray)">Indlæser…</div>'; mailNextPageToken=null; }
  if(loading)loading.textContent='Indlæser…';
  const folderNames={'in:inbox':'Indbakke','in:sent':'Sendt','in:drafts':'Kladder','is:starred':'Stjernemarkeret','in:trash':'Papirkurv'};
  if(folderLabel)folderLabel.textContent=folderNames[folder]||folder.replace('q:','');
  // Update active folder button
  document.querySelectorAll('.mail-folder-btn').forEach(b=>b.classList.toggle('active',b.textContent.trim().includes(folderNames[folder]||'')));
  try{
    const q=folder.startsWith('q:')?folder.slice(2):folder;
    const url='/api/mail/messages?q='+encodeURIComponent(q)+(mailNextPageToken&&append?'&pageToken='+mailNextPageToken:'');
    const r=await fetch(url,{headers:ah()});
    const d=await r.json();
    if(loading)loading.textContent='';
    if(!append)listBody.innerHTML='';
    if(!d.messages||!d.messages.length){
      if(!append)listBody.innerHTML='<div style="padding:32px 16px;text-align:center;font-size:12px;color:var(--gray2)">Ingen mails her</div>';
    }else{
      d.messages.forEach(m=>{
        const div=document.createElement('div');
        div.className='mail-item'+(m.unread?' unread':'')+(m.id===activeMailId?' active':'');
        div.setAttribute('data-id',m.id);
        div.innerHTML=`
          <div class="mail-item-row1">
            ${m.unread?'<span class="mail-unread-dot"></span>':'<span style="width:7px;flex-shrink:0"></span>'}
            <span class="mail-from">${e(formatMailFrom(m.from))}</span>
            <span class="mail-date">${e(formatMailDate(m.date))}</span>
          </div>
          <div class="mail-subject">${e(m.subject)}</div>
          <div class="mail-snippet">${e(m.snippet)}</div>`;
        div.onclick=()=>openMailMessage(m.id,m.threadId);
        listBody.appendChild(div);
      });
    }
    mailNextPageToken=d.nextPageToken||null;
    if(loadMore)loadMore.style.display=mailNextPageToken?'':'none';
  }catch(err){
    if(loading)loading.textContent='';
    listBody.innerHTML='<div style="padding:20px;text-align:center;font-size:12px;color:#dc2626">Fejl: '+e(err.message)+'</div>';
  }
}

function switchMailFolder(q){
  activeMailFolder=q;
  mailNextPageToken=null;
  document.querySelectorAll('.mail-folder-btn').forEach(b=>b.classList.remove('active'));
  const folderNames={'in:inbox':'Indbakke','in:sent':'Sendt','in:drafts':'Kladder','is:starred':'Stjernemarkeret','in:trash':'Papirkurv'};
  document.querySelectorAll('.mail-folder-btn').forEach(b=>{if(b.textContent.trim().includes(folderNames[q]||''))b.classList.add('active');});
  loadMailMessages(q);
  // Clear reading pane
  const rp=document.getElementById('mail-reading-col');
  if(rp)rp.innerHTML='<div class="mail-empty"><div style="font-size:14px;color:var(--gray2)"></div><div style="font-size:13px;font-weight:600;color:var(--gray)">Vælg en mail for at læse den</div></div>';
  activeMailId=null;
}

function loadMoreMail(){ if(mailNextPageToken)loadMailMessages(activeMailFolder,true); }

async function openMailMessage(id,threadId){
  activeMailId=id;
  // Mark active in list
  document.querySelectorAll('.mail-item').forEach(el=>{
    el.classList.toggle('active',el.getAttribute('data-id')===id);
    if(el.getAttribute('data-id')===id)el.classList.remove('unread');
  });
  const rp=document.getElementById('mail-reading-col');
  if(!rp)return;
  rp.innerHTML='<div class="mail-empty"><div style="font-size:12px;opacity:.4"></div><div style="font-size:12px;color:var(--gray)">Indlæser…</div></div>';
  try{
    const r=await fetch('/api/mail/messages/'+id,{headers:ah()});
    const m=await r.json();
    rp.innerHTML=`
      <div class="mail-reading-hd">
        <div class="mail-reading-subject">${e(m.subject)}</div>
        <div class="mail-reading-meta">
          <div><strong>Fra:</strong> ${e(m.from)}</div>
          <div><strong>Til:</strong> ${e(m.to)}</div>
          <div><strong>Dato:</strong> ${e(m.date)}</div>
        </div>
      </div>
      <div class="mail-reading-actions">
        <button class="btn btn-sm btn-primary" onclick="showCompose({replyTo:'${e(m.id)}',to:'${e(m.from.replace(/"/g,"'"))}',subject:'${e((m.subject.startsWith('Re:')?m.subject:'Re: '+m.subject).replace(/'/g,"\\'")||"")}',threadId:'${e(m.threadId)}',quote:'${encodeURIComponent(m.body||'')}'})" >↩ Svar</button>
        <button class="btn btn-sm" onclick="showCompose({to:'',subject:'Fwd: ${e(m.subject.replace(/'/g,"\\'"))}',body:'\\n\\n--- Videresendt besked ---\\nFra: ${e(m.from.replace(/'/g,"\\'"))}\\nEmne: ${e(m.subject.replace(/'/g,"\\'"))}\\n\\n'})">⏩ Videresend</button>
        <button class="btn btn-sm" onclick="trashMail('${m.id}')" style="margin-left:auto;background:#fef2f2;color:#dc2626;border-color:#fecaca">Slet</button>
      </div>
      <div class="mail-reading-body" id="mail-body-content">
        ${m.isHtml
          ? `<iframe id="mail-iframe" style="width:100%;border:none;min-height:400px" sandbox="allow-same-origin"></iframe>`
          : `<pre>${e(m.body||'')}</pre>`}
      </div>`;
    if(m.isHtml){
      const iframe=document.getElementById('mail-iframe');
      if(iframe){
        iframe.onload=()=>{ try{iframe.style.height=(iframe.contentDocument.body.scrollHeight+20)+'px';}catch(ex){} };
        iframe.srcdoc=m.body||'';
      }
    }
  }catch(err){
    rp.innerHTML='<div class="mail-empty"><div style="font-size:12px;color:#dc2626">Fejl: '+e(err.message)+'</div></div>';
  }
}

async function trashMail(id){
  await fetch('/api/mail/messages/'+id,{method:'DELETE',headers:ah()});
  // Remove from list
  document.querySelector(`.mail-item[data-id="${id}"]`)?.remove();
  const rp=document.getElementById('mail-reading-col');
  if(rp)rp.innerHTML='<div class="mail-empty"><div style="font-size:14px;color:var(--gray2)"></div><div style="font-size:13px;font-weight:600;color:var(--gray)">Mail slettet</div></div>';
  showToast('Mail flyttet til papirkurv');
}

// ── Compose modal ──
let _composeOpts={};
function showCompose(opts){
  _composeOpts=opts||{};
  // Remove existing
  document.getElementById('mail-compose-modal')?.remove();
  const quote=opts.quote?'\n\n--- Oprindelig besked ---\n'+decodeURIComponent(opts.quote):'';
  const modal=document.createElement('div');
  modal.id='mail-compose-modal';
  modal.className='mail-compose-overlay';
  modal.innerHTML=`
    <div class="mail-compose-hd">
      <span>${opts.replyTo?'Svar':'Ny mail'}</span>
      <button onclick="document.getElementById('mail-compose-modal')?.remove()" style="background:none;border:none;color:#fff;font-size:16px;cursor:pointer;opacity:.7;line-height:1">✕</button>
    </div>
    <div class="mail-compose-field">
      <span class="mail-compose-label">Til</span>
      <input class="mail-compose-input" id="compose-to" placeholder="modtager@email.dk" value="${e(opts.to||'')}">
    </div>
    <div class="mail-compose-field">
      <span class="mail-compose-label">Emne</span>
      <input class="mail-compose-input" id="compose-subject" placeholder="Emne" value="${e(opts.subject||'')}">
    </div>
    <textarea class="mail-compose-body" id="compose-body" placeholder="Skriv din besked her…">${e(opts.body||'')}${e(quote)}</textarea>
    <div class="mail-compose-footer">
      <button class="btn btn-primary" onclick="sendComposedMail()" style="padding:8px 20px;font-size:13px">Send</button>
      <button class="btn btn-sm" onclick="document.getElementById('mail-compose-modal')?.remove()" style="color:var(--gray)">Annuller</button>
    </div>`;
  document.body.appendChild(modal);
  setTimeout(()=>document.getElementById('compose-to')?.focus(),50);
}

async function sendComposedMail(){
  const to=document.getElementById('compose-to')?.value.trim();
  const subject=document.getElementById('compose-subject')?.value.trim();
  const body=document.getElementById('compose-body')?.value;
  if(!to){showToast('Angiv modtager');return;}
  if(!subject){showToast('Angiv emne');return;}
  const sendBtn=document.querySelector('#mail-compose-modal .btn-primary');
  if(sendBtn){sendBtn.textContent='Sender…';sendBtn.disabled=true;}
  try{
    const r=await fetch('/api/mail/send',{method:'POST',headers:{...ah(),'Content-Type':'application/json'},body:JSON.stringify({to,subject,body,threadId:_composeOpts.threadId||null,replyTo:_composeOpts.replyTo||null})});
    const d=await r.json();
    if(d.error)throw new Error(d.error);
    document.getElementById('mail-compose-modal')?.remove();
    showToast('Mail sendt!');
  }catch(err){
    if(sendBtn){sendBtn.textContent='Send';sendBtn.disabled=false;}
    showToast('Fejl: '+err.message);
  }
}

// ── Shared HTML escape helper ──
function escHtml(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}

// ── Helpers ──
function formatMailFrom(from){
  const m=from.match(/^"?([^"<]+)"?\s*</);
  return m?m[1].trim():from.replace(/<[^>]+>/,'').trim()||from;
}
function formatMailDate(dateStr){
  if(!dateStr)return'';
  const d=new Date(dateStr);
  if(isNaN(d))return dateStr.slice(0,16);
  const today=new Date();
  const isToday=d.toDateString()===today.toDateString();
  if(isToday)return d.toLocaleTimeString('da-DK',{hour:'2-digit',minute:'2-digit'});
  return d.toLocaleDateString('da-DK',{day:'numeric',month:'short'});
}

// Check if navigated back with gmailConnected param
(()=>{ const p=new URLSearchParams(window.location.search); if(p.get('gmailConnected')){ history.replaceState({},'',window.location.pathname); if(typeof sv==='function')sv('mail'); } })();

// ═══════════════════════════════════════════════════════════════════════════
// CALENDAR
// ═══════════════════════════════════════════════════════════════════════════

let _calView='month'; // 'month' | 'week'
let _calDate=new Date(); // currently displayed month/week anchor
let _calEvents=[]; // cached events for current view range
let _calCalendars=[]; // list of user's Google calendars
let _calActiveCalId='primary';
let _calSyncing=false;

const CAL_COLORS=['#7c3aed','#2563eb','#059669','#d97706','#dc2626','#db2777','#0891b2','#65a30d'];

function calColorFor(calId){
  const idx=Math.abs((calId||'').split('').reduce((a,c)=>a+c.charCodeAt(0),0))%CAL_COLORS.length;
  return CAL_COLORS[idx];
}

// ── Main render ──────────────────────────────────────────────────────────
async function rCalendar(){
  const panel=document.getElementById('calendar-panel');
  if(!panel)return;
  // Check Google connection via calendar status
  let status;
  try{
    const r=await fetch('/api/calendar/status',{headers:ah()});
    status=await r.json();
  }catch(e){status={connected:false};}

  if(!status.connected){
    panel.innerHTML=`
    <div class="cal-connect-wrap">
      <svg width="56" height="56" viewBox="0 0 56 56" fill="none"><rect width="56" height="56" rx="14" fill="#f3f0ff"/><path d="M14 28h7M28 14v7M42 28h-7M28 42v-7" stroke="#7c3aed" stroke-width="2.5" stroke-linecap="round"/><rect x="20" y="20" width="16" height="16" rx="4" stroke="#7c3aed" stroke-width="2"/></svg>
      <div style="font-size:18px;font-weight:800;color:var(--pdarker)">Kalender</div>
      <div style="font-size:13px;color:var(--gray);text-align:center;max-width:320px">Forbind din Google-konto via <strong>Indstillinger → Gmail &amp; Google</strong> for at se og synkronisere din kalender.</div>
      <button onclick="sv('settings')" style="padding:10px 22px;background:var(--p1);color:#fff;border:none;border-radius:9px;font-size:13px;font-weight:700;cursor:pointer">Gå til Indstillinger</button>
    </div>`;
    return;
  }

  // Render layout
  panel.innerHTML=`
  <div class="cal-wrap">
    <div class="cal-sidebar" id="cal-sidebar">
      <button class="cal-create-btn" onclick="showCalEventModal(null)">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 2v10M2 7h10"/></svg>
        Ny begivenhed
      </button>
      <div class="cal-sidebar-hd">Mine kalendere</div>
      <div id="cal-cal-list"><div style="padding:8px;font-size:11px;color:var(--gray2)">Henter…</div></div>
    </div>
    <div class="cal-main">
      <div class="cal-toolbar">
        <button class="cal-nav-btn" onclick="calNav(-1)">‹</button>
        <div class="cal-month-title" id="cal-title"></div>
        <button class="cal-nav-btn" onclick="calNav(1)">›</button>
        <button class="cal-nav-btn" onclick="calGoToday()" style="font-size:11px;font-weight:700;padding:5px 10px">I dag</button>
        <div class="cal-view-toggle">
          <button class="cal-view-btn ${_calView==='month'?'active':''}" onclick="setCalView('month')">Måned</button>
          <button class="cal-view-btn ${_calView==='week'?'active':''}" onclick="setCalView('week')">Uge</button>
        </div>
        <button class="cal-sync-btn" id="cal-sync-btn" onclick="syncCalendar()">
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M11 2.5A5.5 5.5 0 1 0 12 6.5"/><path d="M9 1l2 1.5-1.5 2"/></svg>
          Synkroniser
        </button>
      </div>
      <div id="cal-body" style="flex:1;overflow:auto;display:flex;flex-direction:column"></div>
    </div>
  </div>`;

  calLoadCalendars();
  calRenderBody();
}

// ── Load sidebar calendars ───────────────────────────────────────────────
async function calLoadCalendars(){
  const el=document.getElementById('cal-cal-list');
  if(!el)return;
  try{
    const r=await fetch('/api/calendar/list',{headers:ah()});
    const data=await r.json();
    _calCalendars=data.calendars||[];
    el.innerHTML=_calCalendars.map(c=>`
      <button class="cal-sidebar-btn${c.id===_calActiveCalId?' active':''}" onclick="setActiveCalendar('${escHtml(c.id)}')">
        <span class="cal-color-dot" style="background:${c.backgroundColor||calColorFor(c.id)}"></span>
        <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${escHtml(c.summary||c.id)}</span>
      </button>`).join('');
  }catch(e){
    if(el)el.innerHTML='<div style="padding:8px;font-size:11px;color:var(--gray2)">Ikke tilgængelig</div>';
  }
}

function setActiveCalendar(id){
  _calActiveCalId=id;
  // Re-highlight
  document.querySelectorAll('.cal-sidebar-btn').forEach(b=>{
    b.classList.toggle('active', b.getAttribute('onclick').includes(id));
  });
  calLoadEvents().then(()=>calRenderBody());
}

// ── Navigation ───────────────────────────────────────────────────────────
function calNav(dir){
  if(_calView==='month'){
    _calDate=new Date(_calDate.getFullYear(), _calDate.getMonth()+dir, 1);
  } else {
    _calDate=new Date(_calDate.getTime()+dir*7*24*3600*1000);
  }
  calRenderBody();
}
function calGoToday(){ _calDate=new Date(); calRenderBody(); }
function setCalView(v){ _calView=v; calRenderBody(); }

// ── Load events for current range ────────────────────────────────────────
async function calLoadEvents(){
  let timeMin, timeMax;
  if(_calView==='month'){
    const y=_calDate.getFullYear(), m=_calDate.getMonth();
    timeMin=new Date(y,m,1).toISOString();
    timeMax=new Date(y,m+1,1).toISOString();
  } else {
    // Week: Monday–Sunday
    const d=new Date(_calDate);
    const day=d.getDay();
    const diff=d.getDate()-day+(day===0?-6:1);
    const mon=new Date(d.setDate(diff));
    mon.setHours(0,0,0,0);
    const sun=new Date(mon.getTime()+7*24*3600*1000);
    timeMin=mon.toISOString(); timeMax=sun.toISOString();
  }
  try{
    const r=await fetch(`/api/calendar/events?timeMin=${encodeURIComponent(timeMin)}&timeMax=${encodeURIComponent(timeMax)}&calendarId=${encodeURIComponent(_calActiveCalId)}`,{headers:ah()});
    const data=await r.json();
    _calEvents=data.events||[];
  }catch(e){ _calEvents=[]; }
}

// ── Render body (month or week) ───────────────────────────────────────────
async function calRenderBody(){
  const titleEl=document.getElementById('cal-title');
  const bodyEl=document.getElementById('cal-body');
  if(!bodyEl)return;

  // Update view toggle buttons
  document.querySelectorAll('.cal-view-btn').forEach(b=>{
    b.classList.toggle('active', b.textContent.trim()===(
      _calView==='month'?'Måned':'Uge'));
  });

  // Update title
  if(titleEl){
    if(_calView==='month'){
      titleEl.textContent=_calDate.toLocaleDateString('da-DK',{month:'long',year:'numeric'}).replace(/^\w/,c=>c.toUpperCase());
    } else {
      const d=new Date(_calDate);
      const day=d.getDay(); const diff=d.getDate()-day+(day===0?-6:1);
      const mon=new Date(new Date(d).setDate(diff));
      const sun=new Date(mon.getTime()+6*24*3600*1000);
      titleEl.textContent=mon.toLocaleDateString('da-DK',{day:'numeric',month:'short'})+' – '+sun.toLocaleDateString('da-DK',{day:'numeric',month:'short',year:'numeric'});
    }
  }

  bodyEl.innerHTML='<div style="padding:20px;text-align:center;color:var(--gray2);font-size:12px">Henter begivenheder…</div>';
  await calLoadEvents();

  if(_calView==='month') calRenderMonth(bodyEl);
  else calRenderWeek(bodyEl);
}

// ── Month view ───────────────────────────────────────────────────────────
function calRenderMonth(container){
  const y=_calDate.getFullYear(), m=_calDate.getMonth();
  const today=new Date(); today.setHours(0,0,0,0);
  const firstDay=new Date(y,m,1);
  const lastDay=new Date(y,m+1,0);
  // Start grid on Monday
  let startDow=firstDay.getDay(); startDow=startDow===0?6:startDow-1;
  const days=['Man','Tir','Ons','Tor','Fre','Lør','Søn'];

  // Build event map: dateStr → events[]
  const evMap={};
  _calEvents.forEach(ev=>{
    const ds=calEventDateStr(ev);
    if(!evMap[ds]) evMap[ds]=[];
    evMap[ds].push(ev);
  });

  let cells='';
  // Header
  cells+=days.map(d=>`<div class="cal-day-name">${d}</div>`).join('');

  // Pad before first day
  for(let i=0;i<startDow;i++){
    const date=new Date(y,m,1-startDow+i);
    cells+=`<div class="cal-cell other-month" onclick="showCalEventModal({date:'${calFmtDate(date)}'})">
      <div class="cal-day-num">${date.getDate()}</div>
    </div>`;
  }

  // Days of month
  for(let d=1;d<=lastDay.getDate();d++){
    const date=new Date(y,m,d); date.setHours(0,0,0,0);
    const iso=calFmtDate(date);
    const isToday=date.getTime()===today.getTime();
    const evs=evMap[iso]||[];
    const maxShow=3;
    const evHtml=evs.slice(0,maxShow).map(ev=>{
      const col=ev._calColor||calColorFor(_calActiveCalId);
      const title=escHtml(ev.summary||'(Ingen titel)');
      const timeStr=ev.start?.dateTime?new Date(ev.start.dateTime).toLocaleTimeString('da-DK',{hour:'2-digit',minute:'2-digit'})+' ':'';
      return `<div class="cal-event-pill" style="background:${col}20;color:${col}" onclick="event.stopPropagation();showCalEventDetail('${escHtml(ev.id)}')" title="${title}">${timeStr}${title}</div>`;
    }).join('');
    const more=evs.length>maxShow?`<div class="cal-more-link" onclick="event.stopPropagation();showCalDayEvents('${iso}')">+${evs.length-maxShow} mere</div>`:'';

    cells+=`<div class="cal-cell${isToday?' today':''}" onclick="showCalEventModal({date:'${iso}'})">
      <div class="cal-day-num">${d}</div>
      ${evHtml}${more}
    </div>`;
  }

  // Pad after last day
  const lastDow=lastDay.getDay(); const afterPad=lastDow===0?0:7-lastDow;
  for(let i=1;i<=afterPad;i++){
    const date=new Date(y,m+1,i);
    cells+=`<div class="cal-cell other-month" onclick="showCalEventModal({date:'${calFmtDate(date)}'})">
      <div class="cal-day-num">${date.getDate()}</div>
    </div>`;
  }

  container.innerHTML=`<div class="cal-grid-wrap"><div class="cal-grid">${cells}</div></div>`;
}

// ── Week view ────────────────────────────────────────────────────────────
function calRenderWeek(container){
  const anchor=new Date(_calDate);
  const dow=anchor.getDay();
  const diff=anchor.getDate()-dow+(dow===0?-6:1);
  const monday=new Date(new Date(anchor).setDate(diff));
  monday.setHours(0,0,0,0);
  const today=new Date(); today.setHours(0,0,0,0);
  const hours=Array.from({length:24},(_,i)=>i);
  const dayNames=['Man','Tir','Ons','Tor','Fre','Lør','Søn'];

  // Build event map: dayIndex → events[]
  const evMap={0:[],1:[],2:[],3:[],4:[],5:[],6:[]};
  _calEvents.forEach(ev=>{
    const ds=calEventDateStr(ev);
    const d=new Date(ds+'T00:00:00');
    const di=Math.round((d-monday)/(24*3600*1000));
    if(di>=0&&di<7){evMap[di].push(ev);}
  });

  // Column headers
  const headerCols=Array.from({length:7},(_,i)=>{
    const d=new Date(monday.getTime()+i*24*3600*1000);
    const isToday=d.getTime()===today.getTime();
    return `<div class="cal-week-day-hd${isToday?' today':''}">${dayNames[i]}<br><span style="font-size:17px;font-weight:800">${d.getDate()}</span></div>`;
  }).join('');

  // Grid columns with hour cells + events
  const cols=Array.from({length:7},(_,di)=>{
    const dayDate=new Date(monday.getTime()+di*24*3600*1000);
    const dayCells=hours.map(h=>`<div class="cal-week-cell" onclick="showCalEventModal({date:'${calFmtDate(dayDate)}',hour:${h}})"></div>`).join('');
    const evPills=evMap[di].map(ev=>{
      const col=ev._calColor||calColorFor(_calActiveCalId);
      const startDt=ev.start?.dateTime?new Date(ev.start.dateTime):null;
      const endDt=ev.end?.dateTime?new Date(ev.end.dateTime):null;
      const top=startDt?(startDt.getHours()*56+Math.round(startDt.getMinutes()/60*56)):0;
      const h=endDt&&startDt?Math.max(20,Math.round((endDt-startDt)/3600000*56)):56;
      return `<div class="cal-week-event" style="top:${40+top}px;height:${h}px;background:${col}20;color:${col};border-left:3px solid ${col}" onclick="event.stopPropagation();showCalEventDetail('${escHtml(ev.id)}')">${escHtml(ev.summary||'(Ingen titel)')}</div>`;
    }).join('');
    return `<div class="cal-week-col" style="position:relative">${dayCells}${evPills}</div>`;
  }).join('');

  const timeCells=hours.map(h=>`<div class="cal-week-hour-label">${String(h).padStart(2,'0')}:00</div>`).join('');

  container.innerHTML=`
  <div class="cal-week-wrap">
    <div style="display:flex;flex-direction:column">
      <div style="height:40px"></div><!-- spacer for header -->
      <div class="cal-week-time">${timeCells}</div>
    </div>
    <div style="flex:1;overflow:auto">
      <div style="display:grid;grid-template-columns:repeat(7,1fr);position:sticky;top:0;z-index:2;background:#fff;border-bottom:1px solid var(--border)">${headerCols}</div>
      <div style="display:grid;grid-template-columns:repeat(7,1fr)">${cols}</div>
    </div>
  </div>`;
}

// ── Sync ──────────────────────────────────────────────────────────────────
async function syncCalendar(){
  if(_calSyncing)return;
  _calSyncing=true;
  const btn=document.getElementById('cal-sync-btn');
  if(btn){btn.classList.add('syncing');btn.innerHTML='<svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.8" style="animation:spin .8s linear infinite"><path d="M11 2.5A5.5 5.5 0 1 0 12 6.5"/><path d="M9 1l2 1.5-1.5 2"/></svg> Synkroniserer…';}
  await calRenderBody();
  _calSyncing=false;
  if(btn){btn.classList.remove('syncing');btn.innerHTML='<svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M11 2.5A5.5 5.5 0 1 0 12 6.5"/><path d="M9 1l2 1.5-1.5 2"/></svg> Synkroniser';}
}

// ── Event detail modal ────────────────────────────────────────────────────
function showCalEventDetail(evId){
  const ev=_calEvents.find(e=>e.id===evId);
  if(!ev)return;
  const col=ev._calColor||calColorFor(_calActiveCalId);
  const title=escHtml(ev.summary||'(Ingen titel)');
  const startStr=ev.start?.dateTime?new Date(ev.start.dateTime).toLocaleString('da-DK',{weekday:'long',day:'numeric',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'}):ev.start?.date||'';
  const endStr=ev.end?.dateTime?new Date(ev.end.dateTime).toLocaleString('da-DK',{hour:'2-digit',minute:'2-digit'}):ev.end?.date||'';
  const desc=ev.description?`<div style="font-size:13px;color:var(--gray);line-height:1.6;margin-top:4px">${escHtml(ev.description)}</div>`:'';
  const location=ev.location?`<div style="font-size:12px;color:var(--gray);display:flex;align-items:center;gap:6px;margin-top:4px"><svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6" cy="5" r="2"/><path d="M6 1a4 4 0 0 1 4 4c0 3-4 7-4 7S2 8 2 5a4 4 0 0 1 4-4Z"/></svg>${escHtml(ev.location)}</div>`:'';

  const overlay=document.createElement('div');
  overlay.className='cal-modal-overlay';
  overlay.innerHTML=`
  <div class="cal-modal" style="max-width:420px" onclick="event.stopPropagation()">
    <div class="cal-modal-hd" style="border-left:4px solid ${col}">
      <div class="cal-modal-title">${title}</div>
      <button onclick="editCalEvent('${escHtml(evId)}')" style="padding:5px 10px;border:1px solid var(--border);border-radius:7px;background:#fff;font-size:11px;font-weight:600;cursor:pointer;color:var(--pdarker)">Rediger</button>
      <button onclick="deleteCalEvent('${escHtml(evId)}')" style="padding:5px 10px;border:none;border-radius:7px;background:#fee2e2;font-size:11px;font-weight:600;cursor:pointer;color:#dc2626">Slet</button>
      <button onclick="this.closest('.cal-modal-overlay').remove()" style="margin-left:4px;border:none;background:none;font-size:18px;cursor:pointer;color:var(--gray);line-height:1">×</button>
    </div>
    <div class="cal-modal-body" style="gap:8px">
      <div style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--pdarker);font-weight:600">
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="1" y="1.5" width="11" height="10" rx="1.2"/><path d="M1 5h11M4 .5v2M9 .5v2"/></svg>
        ${startStr}${endStr?' – '+endStr:''}
      </div>
      ${location}${desc}
    </div>
  </div>`;
  overlay.addEventListener('click',()=>overlay.remove());
  document.body.appendChild(overlay);
}

// ── Create / edit event modal ──────────────────────────────────────────────
function showCalEventModal(opts){
  // opts: null = new, {date, hour} = pre-filled, full ev object = edit
  const isEdit=opts&&opts.id;
  const title=isEdit?(opts.summary||''):'';
  const dateVal=isEdit?(opts.start?.date||opts.start?.dateTime?.slice(0,10)||''):(opts?.date||calFmtDate(new Date()));
  const timeStart=isEdit?(opts.start?.dateTime?.slice(11,16)||''):(opts?.hour!=null?String(opts.hour).padStart(2,'0')+':00':'09:00');
  const timeEnd=isEdit?(opts.end?.dateTime?.slice(11,16)||''):(opts?.hour!=null?String((opts.hour+1)%24).padStart(2,'0')+':00':'10:00');
  const desc=isEdit?(opts.description||''):'';
  const loc=isEdit?(opts.location||''):'';
  const allDay=isEdit?(!!opts.start?.date&&!opts.start?.dateTime):false;

  const overlay=document.createElement('div');
  overlay.className='cal-modal-overlay';
  overlay.innerHTML=`
  <div class="cal-modal" onclick="event.stopPropagation()">
    <div class="cal-modal-hd">
      <div class="cal-modal-title">${isEdit?'Rediger begivenhed':'Ny begivenhed'}</div>
      <button onclick="this.closest('.cal-modal-overlay').remove()" style="border:none;background:none;font-size:18px;cursor:pointer;color:var(--gray);line-height:1">×</button>
    </div>
    <div class="cal-modal-body">
      <div class="cal-form-row">
        <label class="cal-form-label">Titel</label>
        <input class="cal-form-input" id="cef-title" placeholder="Tilføj titel" value="${escHtml(title)}">
      </div>
      <div class="cal-form-row-2">
        <div class="cal-form-row">
          <label class="cal-form-label">Dato</label>
          <input class="cal-form-input" id="cef-date" type="date" value="${dateVal}">
        </div>
        <div class="cal-form-row" id="cef-allday-toggle">
          <label class="cal-form-label">Heldagsbegivenhed</label>
          <input type="checkbox" id="cef-allday" ${allDay?'checked':''} onchange="document.getElementById('cef-times').style.display=this.checked?'none':'grid'" style="width:16px;height:16px;margin-top:6px;accent-color:var(--p1)">
        </div>
      </div>
      <div class="cal-form-row-2" id="cef-times" style="display:${allDay?'none':'grid'}">
        <div class="cal-form-row">
          <label class="cal-form-label">Start</label>
          <input class="cal-form-input" id="cef-start" type="time" value="${timeStart}">
        </div>
        <div class="cal-form-row">
          <label class="cal-form-label">Slut</label>
          <input class="cal-form-input" id="cef-end" type="time" value="${timeEnd}">
        </div>
      </div>
      <div class="cal-form-row">
        <label class="cal-form-label">Lokation</label>
        <input class="cal-form-input" id="cef-location" placeholder="Tilføj lokation" value="${escHtml(loc)}">
      </div>
      <div class="cal-form-row">
        <label class="cal-form-label">Beskrivelse</label>
        <textarea class="cal-form-input" id="cef-desc" rows="3" placeholder="Tilføj beskrivelse" style="resize:vertical">${escHtml(desc)}</textarea>
      </div>
    </div>
    <div class="cal-modal-footer">
      <button onclick="this.closest('.cal-modal-overlay').remove()" style="padding:8px 16px;border:1px solid var(--border);border-radius:8px;background:#fff;font-size:12px;font-weight:600;cursor:pointer;color:var(--gray)">Annuller</button>
      <button onclick="saveCalEvent('${isEdit?escHtml(opts.id):''}')" style="padding:8px 20px;background:var(--p1);color:#fff;border:none;border-radius:8px;font-size:12px;font-weight:700;cursor:pointer">${isEdit?'Gem ændringer':'Opret begivenhed'}</button>
    </div>
  </div>`;
  overlay.addEventListener('click',()=>overlay.remove());
  document.body.appendChild(overlay);
  setTimeout(()=>document.getElementById('cef-title')?.focus(),50);
}

function editCalEvent(evId){
  document.querySelectorAll('.cal-modal-overlay').forEach(e=>e.remove());
  const ev=_calEvents.find(e=>e.id===evId);
  if(ev)showCalEventModal(ev);
}

async function saveCalEvent(evId){
  const titleEl=document.getElementById('cef-title');
  const title=titleEl?.value?.trim();
  if(!title){titleEl?.focus();return;}
  const date=document.getElementById('cef-date')?.value;
  const allDay=document.getElementById('cef-allday')?.checked;
  const startTime=document.getElementById('cef-start')?.value||'00:00';
  const endTime=document.getElementById('cef-end')?.value||'01:00';
  const location=document.getElementById('cef-location')?.value?.trim()||'';
  const desc=document.getElementById('cef-desc')?.value?.trim()||'';

  const body={
    summary:title,
    location,
    description:desc,
    start:allDay?{date}:{dateTime:`${date}T${startTime}:00`,timeZone:Intl.DateTimeFormat().resolvedOptions().timeZone},
    end:allDay?{date}:{dateTime:`${date}T${endTime}:00`,timeZone:Intl.DateTimeFormat().resolvedOptions().timeZone}
  };

  const saveBtn=document.querySelector('.cal-modal-footer button:last-child');
  if(saveBtn){saveBtn.disabled=true;saveBtn.textContent='Gemmer…';}

  try{
    const url=evId?`/api/calendar/events/${encodeURIComponent(evId)}`:'/api/calendar/events';
    const method=evId?'PATCH':'POST';
    const r=await fetch(url,{method,headers:ah(),body:JSON.stringify({...body,calendarId:_calActiveCalId})});
    if(!r.ok)throw new Error(await r.text());
    document.querySelectorAll('.cal-modal-overlay').forEach(e=>e.remove());
    await calRenderBody();
  }catch(e){
    if(saveBtn){saveBtn.disabled=false;saveBtn.textContent=evId?'Gem ændringer':'Opret begivenhed';}
    alert('Fejl: '+e.message);
  }
}

async function deleteCalEvent(evId){
  if(!confirm('Slet begivenheden?'))return;
  document.querySelectorAll('.cal-modal-overlay').forEach(e=>e.remove());
  try{
    await fetch(`/api/calendar/events/${encodeURIComponent(evId)}?calendarId=${encodeURIComponent(_calActiveCalId)}`,{method:'DELETE',headers:ah()});
    await calRenderBody();
  }catch(e){alert('Kunne ikke slette: '+e.message);}
}

function showCalDayEvents(dateStr){
  const evs=_calEvents.filter(ev=>calEventDateStr(ev)===dateStr);
  const overlay=document.createElement('div');
  overlay.className='cal-modal-overlay';
  overlay.innerHTML=`
  <div class="cal-modal" style="max-width:360px" onclick="event.stopPropagation()">
    <div class="cal-modal-hd">
      <div class="cal-modal-title">${new Date(dateStr+'T12:00:00').toLocaleDateString('da-DK',{weekday:'long',day:'numeric',month:'long'})}</div>
      <button onclick="this.closest('.cal-modal-overlay').remove()" style="border:none;background:none;font-size:18px;cursor:pointer;color:var(--gray)">×</button>
    </div>
    <div class="cal-modal-body" style="gap:6px;max-height:60vh;overflow-y:auto">
      ${evs.map(ev=>{
        const col=ev._calColor||calColorFor(_calActiveCalId);
        const ts=ev.start?.dateTime?new Date(ev.start.dateTime).toLocaleTimeString('da-DK',{hour:'2-digit',minute:'2-digit'})+' – '+(new Date(ev.end?.dateTime).toLocaleTimeString('da-DK',{hour:'2-digit',minute:'2-digit'})):'Hele dagen';
        return `<div style="display:flex;gap:10px;align-items:flex-start;padding:8px 0;border-bottom:1px solid var(--border);cursor:pointer" onclick="document.querySelector('.cal-modal-overlay').remove();showCalEventDetail('${escHtml(ev.id)}')">
          <div style="width:3px;height:36px;border-radius:3px;background:${col};flex-shrink:0;margin-top:2px"></div>
          <div>
            <div style="font-size:13px;font-weight:700;color:var(--pdarker)">${escHtml(ev.summary||'(Ingen titel)')}</div>
            <div style="font-size:11px;color:var(--gray)">${ts}</div>
          </div>
        </div>`;
      }).join('')}
    </div>
  </div>`;
  overlay.addEventListener('click',()=>overlay.remove());
  document.body.appendChild(overlay);
}

// ── Helpers ───────────────────────────────────────────────────────────────
function calEventDateStr(ev){
  if(ev.start?.date) return ev.start.date;
  if(ev.start?.dateTime) return ev.start.dateTime.slice(0,10);
  return '';
}
function calFmtDate(d){
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
}

// Check if navigated back with gmailConnected param
(()=>{ const p=new URLSearchParams(window.location.search); if(p.get('gmailConnected')){ history.replaceState({},'',window.location.pathname); if(typeof sv==='function')sv('mail'); } })();
</script>
</body>
</html>
